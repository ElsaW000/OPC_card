/* custom-tab-bar.wxss */

.tab-bar {
  position: fixed !important;
  bottom: 0 !important;
  left: 0 !important;
  right: 0 !important;
  height: 100rpx !important;
  background: #ffffff !important;
  z-index: 9999 !important;
  display: flex !important;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06) !important;
  border-top: 1rpx solid #f1f5f9 !important;
  padding-bottom: 0 !important;
  visibility: visible !important;
  opacity: 1 !important;
}

.tab-item {
  flex: 1 !important;
  display: flex !important;
  flex-direction: column !important;
  align-items: center !important;
  justify-content: center !important;
  padding: 12rpx 0 !important;
  transition: all 0.3s ease !important;
  position: relative !important;
}

/* Normal tab styles */
.normal-tab {
  display: flex !important;
  flex-direction: column !important;
  align-items: center !important;
  gap: 4rpx !important;
}

.tab-icon {
  font-size: 32rpx !important;
  line-height: 1 !important;
  margin-bottom: 4rpx !important;
}

.tab-text {
  font-size: 18rpx !important;
  color: #999 !important;
  font-weight: 500 !important;
}

.active .tab-text {
  color: #2F65EE !important;
  font-weight: 600 !important;
}

/* Center tab special styles */
.center-tab {
  display: flex !important;
  flex-direction: column !important;
  align-items: center !important;
  gap: 4rpx !important;
  margin-top: -20rpx !important;
}

.center-icon {
  width: 80rpx !important;
  height: 80rpx !important;
  border-radius: 50% !important;
  background: #2563eb !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.3) !important;
  margin-bottom: 8rpx !important;
  visibility: visible !important;
  opacity: 1 !important;
  transition: transform 0.2s ease !important;
}

.center-icon:active {
  transform: scale(0.95) !important;
}

.center-text {
  font-size: 36rpx !important;
  line-height: 1 !important;
}

.active .center-icon {
  box-shadow: 0 8rpx 32rpx rgba(37, 99, 235, 0.5) !important;
  background: #1d4ed8 !important;
}
