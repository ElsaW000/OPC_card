/* custom-tab-bar.wxss - 5个tab的TabBar */

.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #ffffff;
  z-index: 999;
  display: flex;
  align-items: flex-start;
  padding-top: 16rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  border-top: 1rpx solid #f1f5f9;
}

/* 左侧普通tab */
.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding-top: 8rpx;
  position: relative;
}

.tab-item.left {
  flex: 0.8;
}

.tab-item.right {
  flex: 1;
}

.tab-icon-wrap {
  position: relative;
}

.tab-icon {
  font-size: 40rpx;
}

.tab-text {
  font-size: 20rpx;
  color: #6b7280;
  margin-top: 4rpx;
  font-weight: 500;
}

.tab-item.active .tab-text {
  color: #111827;
  font-weight: 600;
}

/* 红色Badge */
.badge {
  position: absolute;
  top: -8rpx;
  right: -16rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: #ef4444;
  border-radius: 16rpx;
  font-size: 18rpx;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  font-weight: 600;
}

/* 中间突出按钮 */
.tab-center {
  flex: 0;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding-top: 0;
}

.exchange-btn {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.4);
  margin-top: -30rpx;
}

.exchange-icon {
  font-size: 36rpx;
}

.exchange-text {
  font-size: 20rpx;
  color: #fff;
  font-weight: 700;
  margin-top: 2rpx;
}

/* 右侧我的名片激活态 */
.tab-item.right.active {
  background: linear-gradient(180deg, #eff6ff 0%, #dbeafe 100%);
}

.tab-item.right .tab-text {
  color: #2563eb;
  font-weight: 600;
}

.active-line {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: #2563eb;
  border-radius: 3rpx 3rpx 0 0;
}
