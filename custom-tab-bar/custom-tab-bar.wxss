/* custom-tab-bar.wxss */

.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #ffffff;
  z-index: 999;
  display: flex;
  border-top: 1rpx solid #e5e7eb;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  background: #fff;
}

.tab-item.active {
  background: #eff6ff;
}

.tab-icon-box {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 4rpx;
}

.icon-text {
  font-size: 32rpx;
  color: #9ca3af;
}

.tab-item.active .icon-text {
  color: #2563eb;
}

.tab-text {
  font-size: 22rpx;
  color: #9ca3af;
}

.tab-item.active .tab-text {
  color: #2563eb;
  font-weight: bold;
}
