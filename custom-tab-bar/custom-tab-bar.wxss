/* custom-tab-bar.wxss */

.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #ffffff;
  z-index: 999;
  display: flex !important;
  flex-direction: row;
  align-items: center;
  justify-content: space-around;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.tab-bar-border {
  display: none;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 10rpx 0;
}

.tab-icon {
  font-size: 44rpx;
  margin-bottom: 4rpx;
  line-height: 1;
}

.tab-text {
  font-size: 22rpx;
  color: #9ca3af;
}

.tab-text.active {
  color: #2563eb;
  font-weight: 600;
}

.tab-indicator {
  display: none;
}
