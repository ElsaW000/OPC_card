<!--custom-tab-bar.wxml-->
<view class="tab-bar">
  <view class="tab-bar-border"></view>
  <block wx:for="{{list}}" wx:key="index">
    <view class="tab-item" bindtap="switchTab" data-path="{{item.pagePath}}" data-index="{{index}}">
      <view class="tab-icon">{{item.icon}}</view>
      <view class="tab-text {{selected === index ? 'active' : ''}}">{{item.text}}</view>
      <view class="tab-indicator {{selected === index ? 'active' : ''}}"></view>
    </view>
  </block>
</view>
