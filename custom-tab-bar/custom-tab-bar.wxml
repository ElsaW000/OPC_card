<!--custom-tab-bar.wxml -->
<view class="tab-bar">
  <view 
    wx:for="{{list}}" 
    wx:key="index" 
    class="tab-item {{selected === index ? 'active' : ''}}" 
    bindtap="switchTab" 
    data-path="{{item.pagePath}}" 
    data-index="{{index}}"
  >
    <view class="tab-icon-box">
      <text wx:if="{{index === 0}}" class="icon-text">格</text>
      <text wx:elif="{{index === 1}}" class="icon-text">名</text>
      <text wx:elif="{{index === 2}}" class="icon-text">人</text>
      <text wx:else class="icon-text">设</text>
    </view>
    <text class="tab-text">{{item.text}}</text>
  </view>
</view>
