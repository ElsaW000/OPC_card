# deploy/aliyun/systemd/eseat-api.service

[Unit]
Description=eSeat FastAPI API
After=network.target

[Service]
Type=simple
User=admin
WorkingDirectory=/opt/eseat/OPC_card
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/eseat/OPC_card/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8001 --app-dir backend
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
