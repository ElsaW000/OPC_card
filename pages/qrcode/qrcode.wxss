page {
  background: #f8fafc;
}

.qrcode-page {
  min-height: 100vh;
  padding: 32rpx 24rpx;
  box-sizing: border-box;
}

.qrcode-card {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 36rpx 28rpx 32rpx;
  box-shadow: 0 18rpx 42rpx rgba(15, 23, 42, 0.08);
}

.qrcode-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #0f172a;
}

.qrcode-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
}

.card-preview {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 28rpx;
}

.card-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #2f65ee, #1d4ed8);
}

.card-avatar.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-avatar-text {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
}

.card-meta {
  flex: 1;
}

.card-name {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
}

.card-role {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #64748b;
}

.qr-area {
  width: 420rpx;
  height: 420rpx;
  margin: 36rpx auto 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qr-image {
  width: 420rpx;
  height: 420rpx;
  border-radius: 16rpx;
}

.qr-loading {
  width: 420rpx;
  height: 420rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f8fafc;
  border-radius: 28rpx;
}

.qr-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #e2e8f0;
  border-top-color: #2563eb;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.fake-qr {
  width: 420rpx;
  height: 420rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: #f8fafc;
}

.fake-qr-grid {
  display: flex;
  flex-wrap: wrap;
  width: 372rpx;
  height: 372rpx;
}

.fake-qr-cell {
  width: 33.818rpx;
  height: 33.818rpx;
  background: #ffffff;
}

.fake-qr-cell.active {
  background: #0f172a;
}

.path-label {
  display: block;
  margin-top: 28rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #64748b;
  word-break: break-all;
  text-align: center;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  border: none;
  background: #eff6ff;
  color: #1d4ed8;
  font-size: 28rpx;
  font-weight: 600;
}

.action-btn::after {
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #2f65ee 0%, #2563eb 100%);
  color: #ffffff;
}

.action-row-2 {
  margin-top: 16rpx;
}

.action-btn-save {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  border: none;
  background: #f1f5f9;
  color: #475569;
  font-size: 28rpx;
  font-weight: 600;
}

.action-btn-save::after {
  border: none;
}