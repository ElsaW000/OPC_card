<!--exchange.wxml - 交换名片 -->
<view class="container">
  <!-- 顶部切换 -->
  <view class="tab-switcher">
    <view class="tab-item {{currentTab === 0 ? 'active' : ''}}" bindtap="switchTab" data-index="0">
      <text>我要递出</text>
    </view>
    <view class="tab-item {{currentTab === 1 ? 'active' : ''}}" bindtap="switchTab" data-index="1">
      <text>我要接收</text>
    </view>
  </view>

  <!-- 当前名片预览 -->
  <view class="card-preview">
    <view class="card-header">
      <text class="card-title">当前使用名片</text>
      <text class="card-action" bindtap="changeCard">换一张 ›</text>
    </view>
    <view class="card-info">
      <text class="card-name">{{currentCard.name}}</text>
      <text class="card-role">{{currentCard.role}}</text>
      <text class="card-company">{{currentCard.company}}</text>
    </view>
  </view>

  <!-- 扫码区域 -->
  <view class="scan-section">
    <view class="scan-frame">
      <view class="scan-line"></view>
    </view>
    <text class="scan-hint">将二维码/条形码放入框内，即可自动扫描</text>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-buttons">
    <button class="btn btn-secondary" bindtap="searchManual">
      <text class="btn-icon">🔍</text>
      <text>搜索交换</text>
    </button>
    <button class="btn btn-primary" bindtap="startScan">
      <text class="btn-icon">📷</text>
      <text>开始扫描</text>
    </button>
  </view>
</view>