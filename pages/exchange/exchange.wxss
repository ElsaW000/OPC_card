page {
  background: #f5f7fb;
}

.container {
  min-height: 100vh;
  padding: 32rpx 28rpx 160rpx;
}

.tab-switcher {
  display: flex;
  padding: 8rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 14rpx 36rpx rgba(15, 23, 42, 0.06);
}

.tab-item {
  flex: 1;
  height: 84rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #64748b;
  font-weight: 600;
}

.tab-item.active {
  background: linear-gradient(135deg, #2f65ee 0%, #2563eb 100%);
  color: #fff;
  box-shadow: 0 14rpx 28rpx rgba(37, 99, 235, 0.24);
}

.card-preview,
.qrcode-card,
.receive-card {
  margin-top: 24rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.98);
  padding: 26rpx;
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.07);
}

.card-header,
.card-info,
.section-head,
.code-box,
.receive-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-title,
.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}

.card-sub,
.section-sub,
.receive-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #94a3b8;
}

.card-action {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #eff6ff;
  color: #2563eb;
  font-size: 22rpx;
  font-weight: 700;
}

.card-shell {
  position: relative;
  margin-top: 20rpx;
  height: 260rpx;
  border-radius: 28rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #0f172a, #1e293b);
}

.card-bg,
.card-overlay {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.card-overlay {
  background: linear-gradient(180deg, rgba(15, 23, 42, 0.16), rgba(15, 23, 42, 0.68));
}

.card-info {
  position: relative;
  z-index: 1;
  height: 100%;
  padding: 24rpx;
  align-items: flex-end;
  gap: 18rpx;
}

.card-name {
  display: block;
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #fff;
}

.card-role {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.92);
}

.card-company {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: rgba(255,255,255,0.72);
}

.card-avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 26rpx;
  border: 4rpx solid rgba(255,255,255,0.4);
}

.card-avatar.fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.18);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}

.qr-board {
  margin-top: 20rpx;
  display: flex;
  justify-content: center;
}

.qr-grid {
  width: 360rpx;
  height: 360rpx;
  padding: 18rpx;
  border-radius: 28rpx;
  background: #fff;
  display: grid;
  grid-template-columns: repeat(11, 1fr);
  gap: 8rpx;
  box-shadow: inset 0 0 0 2rpx #e2e8f0;
}

.qr-cell {
  border-radius: 6rpx;
  background: #e2e8f0;
}

.qr-cell.active {
  background: #0f172a;
}

.action-list {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.action-btn {
  height: 92rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
}

.action-btn::after {
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #2f65ee 0%, #2563eb 100%);
  color: #fff;
  box-shadow: 0 16rpx 30rpx rgba(37, 99, 235, 0.24);
}

.action-btn.secondary {
  background: #eff6ff;
  color: #2563eb;
}

.action-btn.ghost {
  background: #f8fafc;
  color: #475569;
}

.receive-desc {
  margin-top: 14rpx;
}

.scan-btn,
.code-submit {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.scan-btn {
  margin-top: 24rpx;
  width: 100%;
  height: 92rpx;
  background: linear-gradient(135deg, #2f65ee 0%, #2563eb 100%);
  color: #fff;
  box-shadow: 0 16rpx 30rpx rgba(37, 99, 235, 0.24);
}

.code-box {
  gap: 14rpx;
  margin-top: 20rpx;
  align-items: stretch;
}

.code-input {
  flex: 1;
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: #f8fafc;
  font-size: 24rpx;
  color: #111827;
}

.code-placeholder {
  color: #9ca3af;
}

.code-submit {
  flex: 0 0 188rpx;
  background: #eff6ff;
  color: #2563eb;
}