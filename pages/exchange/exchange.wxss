/* exchange.wxss */

page { background-color: #f3f4f6; }
.container { min-height: 100vh; padding-bottom: 120rpx; }

.header { padding: 48rpx 32rpx 24rpx; background: #fff; }
.header-title { font-size: 40rpx; font-weight: bold; color: #000; }

.stats-row { display: flex; gap: 20rpx; padding: 24rpx 32rpx; background: #fff; }
.stat-card { flex: 1; display: flex; flex-direction: column; align-items: center; padding: 24rpx; background: #f8f9fa; border-radius: 16rpx; }
.stat-value { font-size: 40rpx; font-weight: bold; color: #2563eb; }
.stat-label { font-size: 22rpx; color: #999; margin-top: 8rpx; }

.record-list { padding: 24rpx 32rpx; }
.record-item { display: flex; align-items: center; background: #fff; border-radius: 20rpx; padding: 24rpx; margin-bottom: 16rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05); }
.record-avatar { width: 88rpx; height: 88rpx; border-radius: 50%; margin-right: 20rpx; }
.record-info { flex: 1; }
.record-name { display: block; font-size: 28rpx; font-weight: 600; color: #000; }
.record-role { display: block; font-size: 22rpx; color: #666; margin-top: 4rpx; }
.record-time { display: block; font-size: 20rpx; color: #bbb; margin-top: 4rpx; }
.record-status { padding: 8rpx 16rpx; border-radius: 12rpx; font-size: 20rpx; }
.record-status.success { background: #d1fae5; color: #059669; }
.record-status.pending { background: #fef3c7; color: #d97706; }
