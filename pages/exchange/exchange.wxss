/* exchange.wxss - 交换名片 */

page {
  background-color: #f8f9fa;
}

.container {
  min-height: 100vh;
  padding: 32rpx;
}

/* Tab Switcher */
.tab-switcher {
  display: flex;
  background: #fff;
  border-radius: 24rpx;
  padding: 8rpx;
  margin-bottom: 32rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 16rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background: #2563EB;
  color: #fff;
  font-weight: 600;
}

/* Card Preview */
.card-preview {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 28rpx;
  color: #666;
}

.card-action {
  font-size: 24rpx;
  color: #2563EB;
}

.card-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.card-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #000;
}

.card-role {
  font-size: 28rpx;
  color: #666;
}

.card-company {
  font-size: 24rpx;
  color: #999;
}

/* Scan Section */
.scan-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.scan-frame {
  width: 400rpx;
  height: 400rpx;
  border: 4rpx solid #2563EB;
  border-radius: 24rpx;
  position: relative;
  margin-bottom: 32rpx;
  overflow: hidden;
}

.scan-line {
  width: 100%;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, #2563EB, transparent);
  position: absolute;
  top: 0;
  animation: scan 2s linear infinite;
}

@keyframes scan {
  0% { top: 0; }
  100% { top: 100%; }
}

.scan-hint {
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

/* Bottom Buttons */
.bottom-buttons {
  display: flex;
  gap: 24rpx;
}

.btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 28rpx 0;
  border-radius: 24rpx;
  font-size: 28rpx;
  border: none;
}

.btn::after {
  border: none;
}

.btn-secondary {
  background: #fff;
  color: #000;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.btn-primary {
  background: linear-gradient(135deg, #2563EB 0%, #1d4ed8 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.3);
}

.btn-icon {
  font-size: 32rpx;
}