<view class="container">
  <view class="header">
    <view class="header-title">{{labels.title}}</view>
    <view class="header-subtitle">{{labels.subtitle}}</view>
  </view>

  <view class="filter-tabs">
    <view class="tab {{currentTab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all">{{labels.tabAll}}</view>
    <view class="tab {{currentTab === 'today' ? 'active' : ''}}" bindtap="switchTab" data-tab="today">{{labels.tabToday}}</view>
    <view class="tab {{currentTab === 'week' ? 'active' : ''}}" bindtap="switchTab" data-tab="week">{{labels.tabWeek}}</view>
  </view>

  <view class="visitor-list" wx:if="{{visitors.length}}">
    <block wx:for="{{visitors}}" wx:key="id">
      <view class="visitor-item">
        <view class="visitor-avatar">
          <image src="{{item.avatarUrl}}" mode="aspectFill" />
        </view>
        <view class="visitor-info">
          <view class="visitor-header">
            <text class="visitor-name">{{item.name}}</text>
            <text class="visitor-time">{{item.viewTime}}</text>
          </view>
          <text class="visitor-role">{{item.role}}</text>
          <view class="visitor-source">
            <text>{{labels.sourcePrefix}}{{item.source}}</text>
          </view>
        </view>
        <view class="visitor-action">
          <button class="exchange-btn" bindtap="exchangeCard" data-id="{{item.id}}">{{labels.exchange}}</button>
        </view>
      </view>
    </block>
  </view>

  <view class="empty-state" wx:else>
    <text class="empty-text">{{labels.empty}}</text>
  </view>
</view>