<!--home.wxml-->
<view class="container">
  <!-- ID Card Section (Swipeable) -->
  <view class="id-section">
    <scroll-view class="card-scroll" scroll-x="true" enhanced="true" show-scrollbar="false">
      <view class="card-wrapper">
        <view class="id-card">
          <view class="id-header">
            <view class="id-badge">默认</view>
            <view class="id-qr">QR</view>
          </view>
          <view class="id-content">
            <view class="id-info">
              <text class="id-name">陈小独立</text>
              <text class="id-role">全栈开发工程师</text>
              <text class="id-company">CODEFLOW AI STUDIO</text>
            </view>
            <view class="id-avatar">
              <image src="https://images.unsplash.com/photo-1701463387028-3947648f1337?w=400" mode="aspectFill"></image>
            </view>
          </view>
          <view class="id-actions">
            <view class="id-action" bindtap="editCard">
              <text>编辑</text>
            </view>
            <view class="id-action" bindtap="shareCard">
              <text>分享名片</text>
            </view>
          </view>
        </view>
        
        <!-- Card 2 -->
        <view class="id-card biz">
          <view class="id-header">
            <view class="id-badge">商务</view>
          </view>
          <view class="id-content">
            <view class="id-info">
              <text class="id-name">Independent Chen</text>
              <text class="id-role">Founder & CEO</text>
              <text class="id-company">ONE PERSON COMPANY</text>
            </view>
            <view class="id-avatar">
              <image src="https://images.unsplash.com/photo-1701463387028-3947648f1337?w=400" mode="aspectFill"></image>
            </view>
          </view>
          <view class="id-actions">
            <view class="id-action" bindtap="editCard">
              <text>编辑</text>
            </view>
            <view class="id-action" bindtap="shareCard">
              <text>分享名片</text>
            </view>
          </view>
        </view>
        
        <!-- Card 3 -->
        <view class="id-card social">
          <view class="id-header">
            <view class="id-badge">社交</view>
          </view>
          <view class="id-content">
            <view class="id-info">
              <text class="id-name">阿力</text>
              <text class="id-role">摄影爱好者</text>
              <text class="id-company">自由职业</text>
            </view>
            <view class="id-avatar">
              <image src="https://images.unsplash.com/photo-1701463387028-3947648f1337?w=400" mode="aspectFill"></image>
            </view>
          </view>
          <view class="id-actions">
            <view class="id-action" bindtap="editCard">
              <text>编辑</text>
            </view>
            <view class="id-action" bindtap="shareCard">
              <text>分享名片</text>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
    
    <!-- Page Indicators -->
    <view class="page-indicators">
      <view class="indicator active"></view>
      <view class="indicator"></view>
      <view class="indicator"></view>
    </view>
  </view>

  <!-- 2x2 Grid -->
  <view class="grid-section">
    <view class="grid-row">
      <view class="grid-item">
        <view class="grid-icon blue"><text>+</text></view>
        <text class="grid-text">创建名片</text>
      </view>
      <view class="grid-item">
        <view class="grid-icon gold"><text>*</text></view>
        <text class="grid-text">星标联系人</text>
      </view>
    </view>
    <view class="grid-row">
      <view class="grid-item">
        <view class="grid-icon orange"><text>#</text></view>
        <text class="grid-text">数据分析</text>
      </view>
      <view class="grid-item">
        <view class="grid-icon darkblue"><text>S</text></view>
        <text class="grid-text">系统设置</text>
      </view>
    </view>
  </view>

  <!-- Data Cards -->
  <view class="data-section">
    <view class="data-card">
      <text class="data-title">访客趋势</text>
      <view class="chart">
        <view class="bar" style="height:40rpx;"></view>
        <view class="bar" style="height:60rpx;"></view>
        <view class="bar" style="height:35rpx;"></view>
        <view class="bar" style="height:80rpx;"></view>
        <view class="bar" style="height:55rpx;"></view>
        <view class="bar" style="height:70rpx;"></view>
        <view class="bar" style="height:45rpx;"></view>
      </view>
    </view>
    <view class="data-card">
      <text class="data-title">最近访客</text>
      <view class="visitor-list">
        <view class="visitor-item">
          <view class="visitor-avatar">李</view>
          <text class="visitor-name">李伟</text>
          <text class="visitor-time">1分钟前</text>
        </view>
        <view class="visitor-item">
          <view class="visitor-avatar">王</view>
          <text class="visitor-name">王五</text>
          <text class="visitor-time">1小时前</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Multi-Card Analytics -->
  <view class="analytics-section">
    <view class="section-title">多名片数据分析</view>
    <view class="analytics-card">
      <view class="mini-card blue"></view>
      <view class="mini-card gray"></view>
      <view class="mini-card green"></view>
    </view>
  </view>

  <!-- Bottom Spacer -->
  <view class="bottom-spacer"></view>
</view>
