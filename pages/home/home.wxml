<!--home.wxml-->
<view class="container">
  <!-- ID Card Section (Swipeable) -->
  <view class="id-section">
    <scroll-view 
      class="card-scroll" 
      scroll-x="true" 
      enhanced="true" 
      show-scrollbar="false"
      bindscroll="onScroll"
      data-length="{{3}}"
    >
      <view class="card-wrapper">
        <view class="id-card">
          <view class="id-header">
            <view class="id-badge">默认</view>
            <view class="id-qr">QR</view>
          </view>
          <view class="id-content">
            <view class="id-info">
              <text class="id-name">陈小独立</text>
              <text class="id-role">全栈开发工程师</text>
              <text class="id-company">CODEFLOW AI STUDIO</text>
            </view>
            <view class="id-avatar">
              <image src="https://images.unsplash.com/photo-1701463387028-3947648f1337?w=400" mode="aspectFill"></image>
            </view>
          </view>
          <view class="id-actions">
            <view class="id-action" bindtap="editCard">
              <text>编辑</text>
            </view>
            <view class="id-action" bindtap="shareCard">
              <text>分享名片</text>
            </view>
          </view>
        </view>
        
        <!-- Card 2 -->
        <view class="id-card biz">
          <view class="id-header">
            <view class="id-badge">商务</view>
          </view>
          <view class="id-content">
            <view class="id-info">
              <text class="id-name">Independent Chen</text>
              <text class="id-role">Founder & CEO</text>
              <text class="id-company">ONE PERSON COMPANY</text>
            </view>
            <view class="id-avatar">
              <image src="https://images.unsplash.com/photo-1701463387028-3947648f1337?w=400" mode="aspectFill"></image>
            </view>
          </view>
          <view class="id-actions">
            <view class="id-action" bindtap="editCard">
              <text>编辑</text>
            </view>
            <view class="id-action" bindtap="shareCard">
              <text>分享名片</text>
            </view>
          </view>
        </view>
        
        <!-- Card 3 -->
        <view class="id-card social">
          <view class="id-header">
            <view class="id-badge">社交</view>
          </view>
          <view class="id-content">
            <view class="id-info">
              <text class="id-name">阿力</text>
              <text class="id-role">摄影爱好者</text>
              <text class="id-company">自由职业</text>
            </view>
            <view class="id-avatar">
              <image src="https://images.unsplash.com/photo-1701463387028-3947648f1337?w=400" mode="aspectFill"></image>
            </view>
          </view>
          <view class="id-actions">
            <view class="id-action" bindtap="editCard">
              <text>编辑</text>
            </view>
            <view class="id-action" bindtap="shareCard">
              <text>分享名片</text>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
    
    <!-- Page Indicators -->
    <view class="page-indicators">
      <view class="indicator {{currentIndex === 0 ? 'active' : ''}}"></view>
      <view class="indicator {{currentIndex === 1 ? 'active' : ''}}"></view>
      <view class="indicator {{currentIndex === 2 ? 'active' : ''}}"></view>
    </view>
  </view>

  <!-- 2x2 Grid -->
  <view class="grid-section">
    <view class="grid-row">
      <view class="grid-item">
        <view class="grid-icon blue"><text>+</text></view>
        <text class="grid-text">创建名片</text>
      </view>
      <view class="grid-item">
        <view class="grid-icon gold"><text>*</text></view>
        <text class="grid-text">星标联系人</text>
      </view>
    </view>
    <view class="grid-row">
      <view class="grid-item">
        <view class="grid-icon orange"><text>#</text></view>
        <text class="grid-text">数据分析</text>
      </view>
      <view class="grid-item">
        <view class="grid-icon darkblue"><text>S</text></view>
        <text class="grid-text">系统设置</text>
      </view>
    </view>
  </view>

  <!-- Data Cards -->
  <view class="data-section">
    <view class="data-card wide">
      <view class="data-header">
        <text class="data-title">访客趋势</text>
        <view class="time-filter">
          <text class="filter-item {{timeRange === 'day' ? 'active' : ''}}" bindtap="setTimeRange" data-range="day">日</text>
          <text class="filter-item {{timeRange === 'week' ? 'active' : ''}}" bindtap="setTimeRange" data-range="week">周</text>
          <text class="filter-item {{timeRange === 'month' ? 'active' : ''}}" bindtap="setTimeRange" data-range="month">月</text>
        </view>
      </view>
      <view class="chart-container">
        <view class="chart-y">
          <text>100</text>
          <text>50</text>
          <text>0</text>
        </view>
        <view class="chart-area">
          <view class="chart-bars">
            <view class="bar-wrapper">
              <view class="bar" style="height:60%;"></view>
              <text class="bar-label">周一</text>
            </view>
            <view class="bar-wrapper">
              <view class="bar" style="height:80%;"></view>
              <text class="bar-label">周二</text>
            </view>
            <view class="bar-wrapper">
              <view class="bar" style="height:45%;"></view>
              <text class="bar-label">周三</text>
            </view>
            <view class="bar-wrapper">
              <view class="bar" style="height:90%;"></view>
              <text class="bar-label">周四</text>
            </view>
            <view class="bar-wrapper">
              <view class="bar" style="height:70%;"></view>
              <text class="bar-label">周五</text>
            </view>
            <view class="bar-wrapper">
              <view class="bar" style="height:30%;"></view>
              <text class="bar-label">周六</text>
            </view>
            <view class="bar-wrapper">
              <view class="bar" style="height:25%;"></view>
              <text class="bar-label">周日</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- Recent Visitors -->
  <view class="data-section">
    <view class="data-card">
      <text class="data-title">最近访客</text>
      <view class="visitor-list">
        <view class="visitor-item">
          <view class="visitor-avatar">李</view>
          <view class="visitor-info">
            <text class="visitor-name">李伟</text>
            <text class="visitor-time">1分钟前</text>
          </view>
        </view>
        <view class="visitor-item">
          <view class="visitor-avatar">王</view>
          <view class="visitor-info">
            <text class="visitor-name">王五</text>
            <text class="visitor-time">1小时前</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- Multi-Card Analytics -->
  <view class="analytics-section">
    <view class="section-title">多名片数据分析</view>
    <view class="analytics-card">
      <view class="mini-card blue"></view>
      <view class="mini-card gray"></view>
      <view class="mini-card green"></view>
    </view>
  </view>

  <!-- Bottom Spacer -->
  <view class="bottom-spacer"></view>
</view>
