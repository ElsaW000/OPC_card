<!--home.wxml-->
<view class="container">
  <!-- Header Section -->
  <view class="header-bg"></view>
  <view class="header-card">
    <view class="card-header">
      <view class="card-badge">
        <text class="badge-text">默认</text>
      </view>
      <view class="card-qr">QR</view>
    </view>
    <view class="card-body">
      <view class="card-info">
        <text class="card-name">陈小独立</text>
        <text class="card-role">全栈开发工程师</text>
      </view>
      <view class="card-avatar">
        <image src="https://images.unsplash.com/photo-1701463387028-3947648f1337?w=400" mode="aspectFill"></image>
      </view>
    </view>
  </view>
  
  <!-- Action Buttons -->
  <view class="action-buttons">
    <view class="action-btn"><text>编辑</text></view>
    <view class="action-btn"><text>分享</text></view>
    <view class="action-btn toggle"><text>设为默认</text></view>
  </view>

  <!-- 2x2 Grid -->
  <view class="grid-section">
    <view class="grid-row">
      <view class="grid-item">
        <view class="grid-icon blue"><text>+</text></view>
        <text class="grid-text">创建名片</text>
      </view>
      <view class="grid-item">
        <view class="grid-icon gold"><text>*</text></view>
        <text class="grid-text">星标联系人</text>
      </view>
    </view>
    <view class="grid-row">
      <view class="grid-item">
        <view class="grid-icon orange"><text>#</text></view>
        <text class="grid-text">数据分析</text>
      </view>
      <view class="grid-item">
        <view class="grid-icon darkblue"><text>S</text></view>
        <text class="grid-text">系统设置</text>
      </view>
    </view>
  </view>

  <!-- Data Cards -->
  <view class="data-section">
    <view class="data-card">
      <text class="data-title">访客趋势</text>
      <view class="chart">
        <view class="bar" style="height:40rpx;"></view>
        <view class="bar" style="height:60rpx;"></view>
        <view class="bar" style="height:35rpx;"></view>
        <view class="bar" style="height:80rpx;"></view>
        <view class="bar" style="height:55rpx;"></view>
        <view class="bar" style="height:70rpx;"></view>
        <view class="bar" style="height:45rpx;"></view>
      </view>
    </view>
    <view class="data-card">
      <text class="data-title">最近访客</text>
      <view class="visitor-list">
        <view class="visitor-item">
          <view class="visitor-avatar">李</view>
          <text class="visitor-name">李伟</text>
          <text class="visitor-time">1分钟前</text>
        </view>
        <view class="visitor-item">
          <view class="visitor-avatar">王</view>
          <text class="visitor-name">王五</text>
          <text class="visitor-time">1小时前</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Multi-Card Analytics -->
  <view class="analytics-section">
    <view class="section-title">多名片数据分析</view>
    <view class="analytics-card">
      <view class="mini-card blue"></view>
      <view class="mini-card gray"></view>
      <view class="mini-card green"></view>
    </view>
  </view>

  <!-- Bottom Spacer -->
  <view class="bottom-spacer"></view>
</view>
