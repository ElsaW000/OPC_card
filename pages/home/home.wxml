<view class="container">
  <view class="wb-header">
    <text class="wb-title">{{labels.workbench}}</text>
    <text class="wb-subtitle">{{labels.opcWorkbench}}</text>
  </view>

  <view class="wb-card" bindtap="editDefaultCard">
    <image wx:if="{{defaultCard && defaultCard.bannerUrl}}" class="wb-card-bg" src="{{defaultCard.bannerUrl}}" mode="aspectFill"></image>
    <view class="wb-card-overlay"></view>
    <view class="wb-card-content">
      <view class="wb-card-top">
        <text class="wb-badge">{{labels.defaultBadge}}</text>
        <view class="wb-qr" catchtap="showQR">{{labels.qrCode}}</view>
      </view>
      <view class="wb-card-middle">
        <view class="wb-card-info">
          <text class="wb-card-name">{{displayCardName}}</text>
          <text class="wb-card-role">{{displayCardRole}}</text>
          <text class="wb-card-company" wx:if="{{displayCardCompany}}">{{displayCardCompany}}</text>
        </view>
        <image wx:if="{{defaultCard && defaultCard.avatarUrl}}" class="wb-card-avatar" src="{{defaultCard.avatarUrl}}" mode="aspectFill"></image>
        <view wx:else class="wb-card-avatar wb-card-avatar-fallback">OPC</view>
      </view>
    </view>
  </view>

  <view class="summary-card">
    <text class="summary-label">{{labels.weeklyViews}}</text>
    <text class="summary-value">{{weeklyViews}}</text>
    <text class="summary-unit">{{labels.visitorsUnit}}</text>
  </view>

  <view class="quick-card">
    <view class="quick-grid">
      <block wx:for="{{quickActions}}" wx:key="key">
        <view class="quick-item" bindtap="handleQuickAction" data-action="{{item.action}}">
          <view class="quick-icon"><text>{{item.iconText}}</text></view>
          <text class="quick-label">{{item.label}}</text>
        </view>
      </block>
    </view>
  </view>

  <view class="persona-card" wx:if="{{personaTags.length}}">
    <view class="persona-header">
      <text class="persona-title">AI Persona</text>
    </view>
    <view class="persona-tags">
      <view class="persona-tag" wx:for="{{personaTags}}" wx:key="label" style="width: {{item.size}}rpx; height: {{item.size}}rpx;">
        <text class="persona-tag-text">{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="visitor-card">
    <view class="visitor-card-header">
      <text class="visitor-title">{{labels.recentVisitors}}</text>
      <text class="visitor-more" bindtap="goToVisitors">{{labels.viewMore}}</text>
    </view>
    <view wx:if="{{recentVisitors.length}}" class="visitor-items">
      <block wx:for="{{recentVisitors}}" wx:key="id">
        <view class="visitor-row" bindtap="goToVisitors">
          <view class="visitor-avatar-box">{{item.avatarText}}</view>
          <view class="visitor-detail">
            <text class="visitor-name">{{item.name}}</text>
            <text class="visitor-time">{{item.time}}</text>
          </view>
        </view>
      </block>
    </view>
    <view wx:else class="visitor-empty" bindtap="goToVisitors">
      <text class="visitor-empty-text">{{labels.noVisitors}}</text>
    </view>
  </view>

  <view class="contact-card-home">
    <view class="visitor-card-header">
      <text class="visitor-title">{{labels.starredContacts}}</text>
      <text class="visitor-more" bindtap="goToContacts">{{labels.viewMore}}</text>
    </view>
    <view wx:if="{{starredContacts.length}}" class="contact-items-home">
      <block wx:for="{{starredContacts}}" wx:key="id">
        <view class="contact-row-home" bindtap="goToContacts">
          <image wx:if="{{item.avatarUrl}}" class="contact-avatar-home" src="{{item.avatarUrl}}" mode="aspectFill"></image>
          <view wx:else class="contact-avatar-home fallback">{{item.avatarText}}</view>
          <view class="contact-detail-home">
            <text class="contact-name-home">{{item.name}}</text>
            <text class="contact-role-home">{{item.role}}</text>
          </view>
        </view>
      </block>
    </view>
    <view wx:else class="visitor-empty" bindtap="goToContacts">
      <text class="visitor-empty-text">{{labels.noContacts}}</text>
    </view>
  </view>
</view>