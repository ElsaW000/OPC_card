<!--home.wxml-->
<view class="container">
  <!-- Top: Premium Card Preview -->
  <view class="header-card">
    <view class="card-bg-gradient">
      <view class="gradient-inner"></view>
    </view>
    <view class="header-content">
      <view class="header-info">
        <text class="header-name">Independent Chen</text>
        <text class="header-role">Founder</text>
        <text class="header-company">CODEFLOW AI STUDIO</text>
      </view>
      <view class="header-avatar">
        <image src="https://images.unsplash.com/photo-1701463387028-3947648f1337?w=400" mode="aspectFill"></image>
      </view>
    </view>
  </view>

  <!-- Middle: 2x2 Grid -->
  <view class="grid-section">
    <view class="grid-card">
      <view class="grid-2x2">
        <view class="grid-item" bindtap="goToMyCards">
          <view class="grid-icon" style="background: linear-gradient(135deg, #dbeafe, #93c5fd);">
            <text style="font-size: 40rpx;">&#x1F4BC;</text>
          </view>
          <text class="grid-text">My Cards</text>
        </view>
        <view class="grid-item" bindtap="goToVisitor">
          <view class="grid-icon" style="background: linear-gradient(135deg, #fce7f3, #f9a8d4);">
            <text style="font-size: 40rpx;">&#x1F441;</text>
          </view>
          <text class="grid-text">Visitor Records</text>
        </view>
        <view class="grid-item" bindtap="goToContacts">
          <view class="grid-icon" style="background: linear-gradient(135deg, #d1fae5, #6ee7b7);">
            <text style="font-size: 40rpx;">&#x1F4DD;</text>
          </view>
          <text class="grid-text">Exchange History</text>
        </view>
        <view class="grid-item" bindtap="goToAnalytics">
          <view class="grid-icon" style="background: linear-gradient(135deg, #e0e7ff, #a5b4fc);">
            <text style="font-size: 40rpx;">&#x1F4CA;</text>
          </view>
          <text class="grid-text">Data Analytics</text>
        </view>
      </view>
    </view>
  </view>

  <!-- AI Section -->
  <view class="ai-section">
    <view class="ai-card">
      <view class="ai-header">
        <view class="ai-icon">&#x1F916;</view>
        <text class="ai-title">AI Assistant</text>
      </view>
      <view class="ai-features">
        <view class="ai-feature">
          <text class="ai-feature-text">One-click Card Generation</text>
        </view>
        <view class="ai-feature">
          <text class="ai-feature-text">Smart Tag Recommendation</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Member Banner -->
  <view class="member-banner">
    <view class="member-icon">&#x1F6E1;</view>
    <view class="member-content">
      <text class="member-title">PRO Member</text>
      <text class="member-desc">Upgrade to view all visitor details</text>
    </view>
    <view class="member-btn">Upgrade</view>
  </view>

  <!-- Recent Visitors -->
  <view class="visitors-section">
    <view class="section-header">
      <text class="section-title">Recent Visitors</text>
      <text class="section-more">View All</text>
    </view>
    <view class="visitor-list">
      <view class="visitor-item">
        <image class="visitor-avatar" src="https://images.unsplash.com/photo-1573164713791-0dfcd2a183a7?w=200" />
        <view class="visitor-info">
          <text class="visitor-name">Sarah Zhang</text>
          <text class="visitor-role">PM @ ByteDance</text>
        </view>
        <view class="visitor-meta">
          <text class="visitor-source">&#x1F4F7;</text>
          <text class="visitor-time">2m ago</text>
        </view>
      </view>
      <view class="visitor-item">
        <image class="visitor-avatar" src="https://images.unsplash.com/photo-1664101606938-e664f5852fac?w=200" />
        <view class="visitor-info">
          <text class="visitor-name">David Li</text>
          <text class="visitor-role">Indie Developer</text>
        </view>
        <view class="visitor-meta">
          <text class="visitor-source">&#x1F4F7;</text>
          <text class="visitor-time">2h ago</text>
        </view>
      </view>
      <view class="visitor-item">
        <image class="visitor-avatar" src="https://images.unsplash.com/photo-1645951252284-4aa663bf59ca?w=200" />
        <view class="visitor-info">
          <text class="visitor-name">Emily Wang</text>
          <text class="visitor-role">Designer @ Adobe</text>
        </view>
        <view class="visitor-meta">
          <text class="visitor-source">&#x1F4F7;</text>
          <text class="visitor-time">1d ago</text>
        </view>
      </view>
    </view>
  </view>
</view>
