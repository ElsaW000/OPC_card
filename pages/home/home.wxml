<!--home.wxml - 工作台 -->
<view class="container">
  <!-- 当前名片展示 -->
  <view class="current-card">
    <view class="card-bg">
      <image src="{{currentCard.bannerUrl}}" mode="aspectFill"></image>
    </view>
    <view class="card-content">
      <view class="card-info">
        <text class="card-name">{{currentCard.name}}</text>
        <text class="card-role">{{currentCard.role}}</text>
        <text class="card-location">{{currentCard.locationCountry}}，{{currentCard.locationCity}}</text>
      </view>
      <view class="card-avatar">
        <image src="{{currentCard.avatarUrl}}" mode="aspectFill"></image>
      </view>
    </view>
  </view>

  <!-- 快捷操作 -->
  <view class="quick-actions">
    <view class="action-item" bindtap="goToMyCards">
      <text class="action-icon">📇</text>
      <text class="action-text">我的名片</text>
    </view>
    <view class="action-item" bindtap="goToContacts">
      <text class="action-icon">👥</text>
      <text class="action-text">联系人</text>
    </view>
    <view class="action-item" bindtap="goToVisitor">
      <text class="action-icon">👁</text>
      <text class="action-text">访客</text>
    </view>
    <view class="action-item" bindtap="goToAnalytics">
      <text class="action-icon">📊</text>
      <text class="action-text">数据</text>
    </view>
  </view>

  <!-- 作品集 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">作品集</text>
    </view>
    <view class="project-list">
      <view class="project-card" wx:for="{{projects}}" wx:key="id" bindtap="onProjectTap" data-link="{{item.link}}">
        <image class="project-thumb" src="{{item.thumbnail}}" mode="aspectFill"></image>
        <view class="project-info">
          <text class="project-title">{{item.title}}</text>
          <text class="project-desc">{{item.description}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部浮动按钮 -->
  <view class="fab-container">
    <view class="fab-primary" bindtap="onExchangeTap">
      <text>交换名片</text>
    </view>
  </view>
</view>
