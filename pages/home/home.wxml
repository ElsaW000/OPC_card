<!--home.wxml-->
<view class="container">
  <!-- Header with Card -->
  <view class="header-section">
    <view class="header-bg"></view>
    <view class="header-card">
      <view class="card-badge">
        <text class="badge-icon">*</text>
        <text class="badge-text">Default</text>
        <text class="qr-icon">QR</text>
      </view>
      <view class="card-content">
        <view class="card-info">
          <text class="card-name">Chen Xiao Duli</text>
          <text class="card-role">Full-stack Developer</text>
        </view>
        <view class="card-avatar">
          <image src="https://images.unsplash.com/photo-1701463387028-3947648f1337?w=400" mode="aspectFill"></image>
        </view>
      </view>
    </view>
    <!-- Card Actions -->
    <view class="card-actions">
      <view class="action-btn">
        <text>Edit</text>
      </view>
      <view class="action-btn">
        <text>Share</text>
      </view>
      <view class="action-toggle">
        <text>Set Default</text>
        <view class="toggle-switch"></view>
      </view>
    </view>
  </view>

  <!-- 2x2 Grid -->
  <view class="grid-section">
    <view class="grid-card">
      <view class="grid-2x2">
        <view class="grid-item">
          <view class="grid-icon blue">
            <text class="grid-icon-text">+</text>
          </view>
          <text class="grid-text">Create Card</text>
        </view>
        <view class="grid-item">
          <view class="grid-icon gold">
            <text class="grid-icon-text">*</text>
          </view>
          <text class="grid-text">Starred</text>
        </view>
        <view class="grid-item">
          <view class="grid-icon orange">
            <text class="grid-icon-text">#</text>
          </view>
          <text class="grid-text">Analytics</text>
        </view>
        <view class="grid-item">
          <view class="grid-icon blue2">
            <text class="grid-icon-text">S</text>
          </view>
          <text class="grid-text">Settings</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Data Overview -->
  <view class="data-section">
    <view class="data-card">
      <view class="data-header">
        <text class="data-title">Visitor Activity</text>
      </view>
      <view class="data-chart">
        <view class="chart-bars">
          <view class="bar" style="height: 40%;"></view>
          <view class="bar" style="height: 60%;"></view>
          <view class="bar" style="height: 35%;"></view>
          <view class="bar" style="height: 80%;"></view>
          <view class="bar" style="height: 55%;"></view>
          <view class="bar" style="height: 70%;"></view>
          <view class="bar" style="height: 45%;"></view>
        </view>
        <text class="chart-label">Visitors per day</text>
      </view>
    </view>
    <view class="data-card">
      <view class="data-header">
        <text class="data-title">Recent Visitors</text>
      </view>
      <view class="visitor-mini-list">
        <view class="visitor-mini">
          <view class="visitor-mini-avatar">L</view>
          <view class="visitor-mini-info">
            <text class="visitor-mini-name">Li Wei</text>
            <text class="visitor-mini-time">1m ago</text>
          </view>
        </view>
        <view class="visitor-mini">
          <view class="visitor-mini-avatar">J</view>
          <view class="visitor-mini-info">
            <text class="visitor-mini-name">Jane Doe</text>
            <text class="visitor-mini-time">1h ago</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- Multi-Card Analytics -->
  <view class="analytics-section">
    <view class="section-title">Multi-Card Analytics</view>
    <view class="analytics-card">
      <view class="mini-cards">
        <view class="mini-card blue"></view>
        <view class="mini-card gray"></view>
        <view class="mini-card green"></view>
      </view>
    </view>
  </view>

  <!-- Management Actions -->
  <view class="actions-section">
    <view class="action-list-card">
      <view class="action-list-item">
        <text class="action-list-icon">C</text>
        <text class="action-list-text">Card Settings</text>
        <text class="action-list-arrow">></text>
      </view>
      <view class="action-list-item">
        <text class="action-list-icon">N</text>
        <text class="action-list-text">Notification Preferences</text>
        <text class="action-list-arrow">></text>
      </view>
      <view class="action-list-item">
        <text class="action-list-icon">H</text>
        <text class="action-list-text">Help & Support</text>
        <text class="action-list-arrow">></text>
      </view>
    </view>
  </view>

  <!-- Bottom Spacer for TabBar -->
  <view class="bottom-spacer"></view>
</view>
