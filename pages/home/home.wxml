<view class="home-page">
  <view class="assistant-card section-card">
    <text class="section-label">{{labels.aiTitle}}</text>
    <view class="assistant-input-row {{aiInputFocused ? 'focused' : ''}}">
      <input class="assistant-input" value="{{aiInput}}" bindinput="onAiInputChange" bindfocus="onAiInputFocus" bindblur="onAiInputBlur" placeholder="{{labels.aiPlaceholder}}" placeholder-class="assistant-placeholder" confirm-type="send" bindconfirm="openAiChat" />
    </view>
    <view class="assistant-prompt" bindtap="useAiPrompt" data-prompt="{{aiPrompt}}">
      <text class="assistant-prompt-text">{{aiPrompt}}</text>
    </view>
    <view class="assistant-pills">
      <view class="assistant-pill assistant-pill-{{item.tone}}" wx:for="{{modelPills}}" wx:key="index">
        <text class="assistant-pill-text assistant-pill-text-{{item.tone}}">{{item.text}}</text>
      </view>
    </view>
  </view>

  <view class="data-card section-card">
    <view class="data-header">
      <view>
        <text class="section-label">{{labels.dataTitle}}</text>
        <text class="data-subtitle">{{labels.weeklyViews}}</text>
      </view>
      <view class="data-link" bindtap="openAnalytics"></view>
    </view>
    <view class="data-body">
      <view class="data-value-block">
        <text class="data-value">{{weeklyViews}}</text>
      </view>
      <view class="bubble-cloud" hover-class="bubble-cloud-active" hover-stay-time="120">
        <view class="bubble bubble-tone-{{item.tone}} bubble-{{item.emphasis}}" hover-class="bubble-hover" hover-stay-time="120" wx:for="{{personaTags}}" wx:key="id" style="width: {{item.size}}rpx; height: {{item.size}}rpx;">
          <text class="bubble-text">{{item.label}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="contacts-card section-card">
    <view class="contacts-header">
      <text class="section-label">{{labels.starredTitle}}</text>
      <view class="contacts-more" bindtap="openStarredContacts"></view>
    </view>
    <scroll-view scroll-x="true" class="contacts-scroll" enhanced="true" show-scrollbar="false">
      <view class="contacts-row" wx:if="{{starredContacts.length}}">
        <view class="contact-pill" hover-class="contact-pill-hover" hover-stay-time="120" wx:for="{{starredContacts}}" wx:key="id" bindtap="openContactDetail" data-id="{{item.id}}" data-card-id="{{item.cardId}}">
          <image wx:if="{{item.avatarUrl}}" class="contact-avatar" src="{{item.avatarUrl}}" mode="aspectFill"></image>
          <view wx:else class="contact-avatar contact-avatar-fallback">{{item.avatarText}}</view>
          <view class="contact-main">
            <view class="contact-name-row">
              <text class="contact-name">{{item.name}}</text>
              <view class="contact-red-dot" wx:if="{{item.hasUpdate}}"></view>
            </view>
            <text class="contact-role">{{item.role}}</text>
            <text class="contact-update">{{item.updateText}}</text>
          </view>
        </view>
      </view>
      <view wx:else class="contacts-empty">
        <text class="contacts-empty-text">{{labels.noContacts}}</text>
      </view>
    </scroll-view>
  </view>

  <view class="settings-card section-card">
    <text class="section-label">{{labels.settingsTitle}}</text>
    <view class="setting-item" hover-class="setting-item-hover" hover-stay-time="80" bindtap="cycleAiTone">
      <view class="setting-left">
        <text class="setting-title">{{labels.aiTone}}</text>
      </view>
      <view class="setting-right">
        <text class="setting-value">{{settingsSummary.aiTone}}</text>
        <text class="setting-arrow">></text>
      </view>
    </view>
    <view class="setting-item" hover-class="setting-item-hover" hover-stay-time="80" bindtap="togglePublicDynamics">
      <view class="setting-left">
        <text class="setting-title">{{labels.publicDynamics}}</text>
      </view>
      <view class="setting-right">
        <text class="setting-value">{{settingsSummary.publicDynamics ? 'ON' : 'OFF'}}</text>
        <text class="setting-arrow">></text>
      </view>
    </view>
    <view class="setting-item last" hover-class="setting-item-hover" hover-stay-time="80" bindtap="openBlacklist">
      <view class="setting-left">
        <text class="setting-title">{{labels.blacklist}}</text>
      </view>
      <view class="setting-right">
        <text class="setting-value">{{settingsSummary.blacklistCount}}</text>
        <text class="setting-arrow">></text>
      </view>
    </view>
  </view>

  <view class="bottom-links">
    <view class="bottom-link" bindtap="openMember">
      <text class="bottom-link-text">{{labels.membership}}</text>
    </view>
    <view class="bottom-link" bindtap="openSuggestionForm">
      <text class="bottom-link-text">{{labels.contactUs}}</text>
    </view>
  </view>

  <view class="sheet-mask" wx:if="{{showSuggestionForm}}" bindtap="closeSuggestionForm"></view>
  <view class="sheet-panel" wx:if="{{showSuggestionForm}}">
    <text class="sheet-title">{{labels.contactUs}}</text>
    <textarea class="sheet-textarea" value="{{suggestionContent}}" bindinput="onSuggestionContentInput" placeholder="{{labels.suggestionPlaceholder}}" placeholder-class="assistant-placeholder"></textarea>
    <input class="sheet-input" value="{{suggestionContact}}" bindinput="onSuggestionContactInput" placeholder="{{labels.contactPlaceholder}}" placeholder-class="assistant-placeholder" />
    <view class="sheet-actions">
      <view class="sheet-btn secondary" bindtap="closeSuggestionForm">{{labels.cancel}}</view>
      <view class="sheet-btn primary" bindtap="submitSuggestion">{{labels.submit}}</view>
    </view>
  </view>
</view>