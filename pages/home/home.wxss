/* home.wxss */

page { background-color: #f8f9fa; }
.container { min-height: 100vh; padding: 0 24rpx 140rpx; }

/* ID Card Section */
.id-section { padding-top: 24rpx; margin-bottom: 32rpx; }
.card-scroll { width: 100%; white-space: nowrap; }
.card-wrapper { display: flex; gap: 20rpx; padding: 0 24rpx; box-sizing: border-box; }

/* ID Card */
.id-card { width: 100%; height: 400rpx; border-radius: 24rpx; position: relative; overflow: hidden; flex-shrink: 0; }

.card-bg { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; }
.card-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(255,255,255,0.2); z-index: 2; }
.card-content { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 3; padding: 20rpx; display: flex; flex-direction: column; justify-content: space-between; box-sizing: border-box; }

.card-bottom { display: flex; gap: 16rpx; margin-top: -16rpx; }

/* Card Top - Badge & QR */
.card-top { display: flex; justify-content: space-between; align-items: center; }
.id-badge { background: rgba(0,0,0,0.5); padding: 8rpx 20rpx; border-radius: 8rpx; font-size: 22rpx; color: #fff; font-weight: bold; }
.id-qr-btn { width: 56rpx; height: 56rpx; background: rgba(0,0,0,0.5); border-radius: 12rpx; display: flex; align-items: center; justify-content: center; }
.qr-grid { display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: 1fr 1fr; gap: 4rpx; width: 32rpx; height: 32rpx; }
.qr-dot { background: #fff; border-radius: 2rpx; }

/* Card Middle - Info & Avatar */
.card-middle { display: flex; justify-content: space-between; align-items: flex-end; }
.id-info { }
.id-name { display: block; color: #fff; font-size: 40rpx; font-weight: bold; text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.3); }
.id-role { display: block; color: rgba(255,255,255,0.9); font-size: 26rpx; margin-top: 6rpx; text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.3); }
.id-avatar { width: 96rpx; height: 96rpx; border-radius: 20rpx; overflow: hidden; border: 4rpx solid rgba(255,255,255,0.6); box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.2); }
.id-avatar image { width: 100%; height: 100%; }

/* Card Bottom - Actions */
.card-bottom { display: flex; gap: 16rpx; }
.id-action { flex: 1; background: rgba(0,0,0,0.5); border-radius: 16rpx; padding: 18rpx 0; text-align: center; }
.id-action text { color: #fff; font-size: 24rpx; }

/* Page Indicators */
.page-indicators { display: flex; justify-content: center; gap: 12rpx; margin-top: 20rpx; }
.indicator { width: 12rpx; height: 12rpx; border-radius: 6rpx; background: #d1d5db; }
.indicator.active { background: #2563eb; width: 32rpx; }

/* Grid */
.grid-section { background: #fff; border-radius: 24rpx; padding: 24rpx; margin-bottom: 24rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06); }
.grid-row { display: flex; gap: 16rpx; margin-bottom: 16rpx; }
.grid-row:last-child { margin-bottom: 0; }
.grid-item { flex: 1; display: flex; flex-direction: column; align-items: center; padding: 20rpx; }
.grid-icon { width: 64rpx; height: 64rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 12rpx; }
.grid-icon.blue { background: #3b82f6; }
.grid-icon.gold { background: #ffd700; }
.grid-icon.orange { background: #f97316; }
.grid-icon.darkblue { background: #1e40af; }
.grid-icon text { color: #fff; font-size: 28rpx; font-weight: bold; }
.grid-text { font-size: 24rpx; color: #333; }

/* Data Section */
.data-section { margin-bottom: 24rpx; }
.data-card { background: #fff; border-radius: 24rpx; padding: 24rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06); }
.data-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.data-title { font-size: 28rpx; font-weight: bold; color: #333; }

/* Time Filter */
.time-filter { display: flex; gap: 8rpx; }
.filter-item { padding: 8rpx 20rpx; background: #f3f4f6; border-radius: 20rpx; font-size: 22rpx; color: #666; }
.filter-item.active { background: #2563eb; color: #fff; }

/* Chart */
.chart-container { display: flex; gap: 12rpx; }
.chart-y { display: flex; flex-direction: column; justify-content: space-between; padding-bottom: 32rpx; }
.chart-y text { font-size: 18rpx; color: #999; text-align: right; width: 40rpx; }
.chart-area { flex: 1; }
.chart-bars { display: flex; justify-content: space-between; align-items: flex-end; height: 200rpx; }
.bar-wrapper { display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.bar { width: 32rpx; background: #2563eb; border-radius: 6rpx 6rpx 0 0; }
.bar-label { font-size: 18rpx; color: #999; }

/* Visitors */
.visitor-list { }
.visitor-item { display: flex; align-items: center; gap: 16rpx; margin-bottom: 16rpx; }
.visitor-item:last-child { margin-bottom: 0; }
.visitor-avatar { width: 56rpx; height: 56rpx; border-radius: 50%; background: #e5e7eb; display: flex; align-items: center; justify-content: center; font-size: 24rpx; color: #666; }
.visitor-info { flex: 1; display: flex; justify-content: space-between; align-items: center; }
.visitor-name { font-size: 26rpx; color: #333; }
.visitor-time { font-size: 22rpx; color: #999; }

/* Bottom Spacer */
.bottom-spacer { height: 120rpx; }
