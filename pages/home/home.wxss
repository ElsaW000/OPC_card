/* home.wxss */

page { background-color: #f8f9fa; }
.container { min-height: 100vh; padding-bottom: 200rpx; }

/* 顶部 */
.header { padding: 48rpx 32rpx 24rpx; background: #fff; }
.header-title { font-size: 44rpx; font-weight: bold; color: #000; }
.header-subtitle { font-size: 20rpx; color: #999; letter-spacing: 2rpx; margin-top: 8rpx; display: block; }

/* 数据指标 */
.stats-row { display: flex; gap: 24rpx; padding: 0 32rpx; }
.stat-card { flex: 1; background: #fff; border-radius: 24rpx; padding: 24rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06); }
.stat-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.stat-label { font-size: 22rpx; color: #666; }
.stat-growth { font-size: 20rpx; color: #10b981; font-weight: 600; }
.stat-sub { font-size: 20rpx; color: #999; }
.stat-value { font-size: 44rpx; font-weight: bold; color: #000; }

/* 行动提醒 */
.todo-card { margin: 24rpx 32rpx; background: #fef9e7; border-radius: 20rpx; padding: 24rpx; display: flex; align-items: center; }
.todo-icon { font-size: 40rpx; margin-right: 16rpx; }
.todo-content { flex: 1; }
.todo-title { display: block; font-size: 26rpx; font-weight: 600; color: #92400e; }
.todo-desc { display: block; font-size: 22rpx; color: #a16207; margin-top: 4rpx; }
.todo-arrow { font-size: 36rpx; color: #d97706; }

/* 快捷功能 */
.quick-section { padding: 0 32rpx; margin-bottom: 24rpx; }
.section-title { font-size: 28rpx; font-weight: bold; color: #000; display: block; margin-bottom: 20rpx; }
.quick-grid { display: flex; flex-wrap: wrap; gap: 20rpx; background: #fff; border-radius: 24rpx; padding: 24rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06); }
.quick-item { width: calc(50% - 10rpx); display: flex; flex-direction: column; align-items: center; padding: 24rpx 0; }
.quick-icon { font-size: 56rpx; margin-bottom: 12rpx; }
.quick-text { font-size: 24rpx; color: #333; }

/* 最近访客 */
.visitors-section { padding: 0 32rpx; margin-bottom: 24rpx; }
.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.view-all { font-size: 24rpx; color: #999; }
.visitor-list { background: #fff; border-radius: 24rpx; overflow: hidden; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06); }
.visitor-item { display: flex; align-items: center; padding: 24rpx; border-bottom: 1rpx solid #f5f5f5; }
.visitor-item:last-child { border-bottom: none; }
.visitor-avatar { width: 80rpx; height: 80rpx; border-radius: 50%; margin-right: 20rpx; }
.visitor-info { flex: 1; }
.visitor-name { display: block; font-size: 28rpx; font-weight: 600; color: #000; }
.visitor-role { display: block; font-size: 22rpx; color: #999; margin-top: 4rpx; }
.visitor-time { font-size: 22rpx; color: #bbb; }

/* 当前名片预览 */
.card-preview { padding: 0 32rpx; }
.preview-header { margin-bottom: 16rpx; }
.preview-title { font-size: 28rpx; font-weight: bold; color: #000; }
.preview-card { position: relative; height: 200rpx; border-radius: 24rpx; overflow: hidden; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1); }
.preview-bg { position: absolute; inset: 0; }
.preview-bg image { width: 100%; height: 100%; filter: blur(8rpx); }
.preview-content { position: relative; z-index: 2; height: 100%; padding: 24rpx; display: flex; align-items: flex-end; justify-content: space-between; color: #fff; }
.preview-info { flex: 1; }
.preview-name { display: block; font-size: 36rpx; font-weight: bold; }
.preview-role { display: block; font-size: 24rpx; opacity: 0.9; margin-top: 4rpx; }
.preview-avatar { width: 100rpx; height: 100rpx; border-radius: 20rpx; overflow: hidden; border: 3rpx solid rgba(255,255,255,0.5); }
.preview-avatar image { width: 100%; height: 100%; }
