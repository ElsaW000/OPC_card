page { background: #f7f8fb; }
.container { min-height: 100vh; padding: 32rpx 28rpx 160rpx; }

.wb-header { margin-bottom: 28rpx; }
.wb-title { display: block; font-size: 44rpx; font-weight: 700; color: #111827; }
.wb-subtitle { display: block; margin-top: 10rpx; font-size: 20rpx; letter-spacing: 4rpx; color: #94a3b8; font-weight: 700; }

.wb-card { position: relative; height: 360rpx; border-radius: 36rpx; overflow: hidden; margin-bottom: 24rpx; background: linear-gradient(135deg, #0f172a, #1e293b); box-shadow: 0 24rpx 80rpx rgba(15, 23, 42, 0.18); }
.wb-card-bg { position: absolute; inset: 0; width: 100%; height: 100%; }
.wb-card-overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(15,23,42,0.18), rgba(15,23,42,0.68)); }
.wb-card-content { position: relative; z-index: 1; height: 100%; padding: 28rpx; display: flex; flex-direction: column; justify-content: space-between; }
.wb-card-top { display: flex; justify-content: space-between; align-items: center; }
.wb-badge { padding: 10rpx 20rpx; border-radius: 18rpx; background: rgba(255,255,255,0.18); color: #fff; font-size: 22rpx; font-weight: 700; }
.wb-qr { min-width: 68rpx; height: 68rpx; padding: 0 18rpx; border-radius: 22rpx; background: rgba(255,255,255,0.16); color: #fff; font-size: 22rpx; font-weight: 700; display: flex; align-items: center; justify-content: center; }
.wb-card-middle { display: flex; justify-content: space-between; align-items: flex-end; gap: 24rpx; }
.wb-card-info { flex: 1; }
.wb-card-name { display: block; font-size: 42rpx; line-height: 1.2; font-weight: 700; color: #fff; }
.wb-card-role { display: block; margin-top: 8rpx; font-size: 24rpx; line-height: 1.5; color: rgba(255,255,255,0.92); }
.wb-card-company { display: block; margin-top: 6rpx; font-size: 22rpx; color: rgba(255,255,255,0.72); }
.wb-card-avatar { width: 112rpx; height: 112rpx; border-radius: 28rpx; border: 4rpx solid rgba(255,255,255,0.4); background: rgba(255,255,255,0.2); }
.wb-card-avatar-fallback { display: flex; align-items: center; justify-content: center; color: #fff; font-size: 24rpx; font-weight: 700; }

.summary-card, .quick-card, .visitor-card, .persona-card, .contact-card-home { background: #ffffff; border-radius: 28rpx; padding: 24rpx; margin-bottom: 24rpx; box-shadow: 0 12rpx 40rpx rgba(15, 23, 42, 0.06); }
.summary-card { display: flex; align-items: baseline; gap: 12rpx; }
.summary-label { font-size: 24rpx; color: #64748b; font-weight: 600; }
.summary-value { font-size: 52rpx; color: #2563eb; font-weight: 800; line-height: 1; }
.summary-unit { font-size: 24rpx; color: #94a3b8; font-weight: 600; }

.quick-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12rpx; }
.quick-item { display: flex; flex-direction: column; align-items: center; gap: 10rpx; padding: 18rpx 6rpx; border-radius: 24rpx; }
.quick-item:active { background: #f8fafc; }
.quick-icon { width: 78rpx; height: 78rpx; border-radius: 24rpx; background: linear-gradient(135deg, #eff6ff, #dbeafe); display: flex; align-items: center; justify-content: center; }
.quick-icon text { font-size: 28rpx; color: #2563eb; font-weight: 800; }
.quick-label { text-align: center; font-size: 22rpx; line-height: 1.35; color: #334155; font-weight: 600; }

.persona-header, .visitor-card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20rpx; }
.persona-title, .visitor-title { font-size: 30rpx; font-weight: 700; color: #111827; }
.visitor-more { font-size: 22rpx; color: #94a3b8; }
.persona-tags { display: flex; gap: 18rpx; flex-wrap: wrap; }
.persona-tag { border-radius: 999rpx; background: linear-gradient(135deg, #eff6ff, #dbeafe); display: flex; align-items: center; justify-content: center; }
.persona-tag-text { font-size: 22rpx; color: #1d4ed8; font-weight: 700; }

.visitor-items, .contact-items-home { display: flex; flex-direction: column; gap: 14rpx; }
.visitor-row, .contact-row-home { display: flex; align-items: center; gap: 16rpx; padding: 16rpx; border-radius: 20rpx; }
.visitor-row:active, .contact-row-home:active { background: #f8fafc; }
.visitor-avatar-box, .contact-avatar-home { width: 64rpx; height: 64rpx; border-radius: 18rpx; background: linear-gradient(135deg, #dbeafe, #bfdbfe); color: #1d4ed8; display: flex; align-items: center; justify-content: center; font-size: 26rpx; font-weight: 700; overflow: hidden; }
.contact-avatar-home.fallback { background: linear-gradient(135deg, #dcfce7, #bbf7d0); color: #15803d; }
.visitor-detail, .contact-detail-home { flex: 1; display: flex; justify-content: space-between; align-items: center; gap: 16rpx; }
.contact-detail-home { display: block; }
.visitor-name, .contact-name-home { flex: 1; font-size: 26rpx; color: #111827; font-weight: 600; }
.visitor-time, .contact-role-home { font-size: 22rpx; color: #94a3b8; }
.contact-role-home { display: block; margin-top: 6rpx; line-height: 1.5; }
.visitor-empty { padding: 18rpx 8rpx; }
.visitor-empty-text { font-size: 24rpx; color: #94a3b8; }