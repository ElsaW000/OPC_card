/* home.wxss */

page { background-color: #f3f4f6; }
.container { min-height: 100vh; padding-bottom: 120rpx; }

.header { padding: 48rpx 32rpx 24rpx; background: #fff; }
.header-title { font-size: 44rpx; font-weight: bold; color: #000; }
.header-subtitle { font-size: 24rpx; color: #999; margin-top: 8rpx; display: block; }

.stats-row { display: flex; gap: 20rpx; padding: 0 32rpx; margin-top: 24rpx; }
.stat-card { flex: 1; border-radius: 28rpx; padding: 28rpx; position: relative; overflow: hidden; }
.card-blue { background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%); }
.card-green { background: linear-gradient(135deg, #10b981 0%, #059669 100%); }
.stat-header { margin-bottom: 16rpx; }
.stat-title-row { display: flex; align-items: center; gap: 8rpx; }
.stat-icon { font-size: 24rpx; }
.stat-label { font-size: 22rpx; color: rgba(255,255,255,0.9); }
.stat-main { margin-bottom: 8rpx; }
.stat-value { font-size: 48rpx; font-weight: bold; color: #fff; }
.stat-growth { font-size: 20rpx; color: rgba(255,255,255,0.8); margin-left: 8rpx; }
.stat-nums { display: flex; align-items: center; gap: 12rpx; font-size: 20rpx; color: rgba(255,255,255,0.7); margin-bottom: 12rpx; }
.stat-sep { opacity: 0.5; }
.stat-progress { margin-top: 16rpx; }
.progress-bar { height: 8rpx; background: rgba(255,255,255,0.2); border-radius: 4rpx; overflow: hidden; }
.progress-fill { height: 100%; background: #fff; border-radius: 4rpx; }
.progress-bar.orange .progress-fill { background: linear-gradient(90deg, #fbbf24, #d97706); }

.stat-split { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.stat-left { display: flex; align-items: baseline; }
.stat-sub { font-size: 24rpx; color: rgba(255,255,255,0.7); margin-left: 8rpx; }
.donut-ring { width: 72rpx; height: 72rpx; border: 6rpx solid rgba(255,255,255,0.3); border-radius: 50%; position: relative; display: flex; align-items: center; justify-content: center; }
.donut-bg { position: absolute; inset: 6rpx; background: linear-gradient(135deg, #10b981, #059669); border-radius: 50%; }
.donut-text { position: relative; z-index: 2; font-size: 24rpx; font-weight: bold; color: #fff; }
.stat-active { font-size: 22rpx; color: rgba(255,255,255,0.8); }

.todo-card { margin: 24rpx 32rpx; background: #fefce8; border-radius: 24rpx; padding: 24rpx; display: flex; }
.todo-icon-box { width: 48rpx; height: 48rpx; background: #fef08a; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24rpx; margin-right: 16rpx; flex-shrink: 0; }
.todo-content { flex: 1; }
.todo-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8rpx; }
.todo-title { font-size: 26rpx; font-weight: bold; color: #92400e; }
.todo-action { font-size: 22rpx; color: #2563eb; font-weight: 600; }
.todo-body { font-size: 22rpx; color: #a16207; line-height: 1.5; display: block; margin-bottom: 12rpx; }
.todo-progress { display: flex; align-items: center; gap: 12rpx; }
.todo-progress .progress-bar { flex: 1; height: 6rpx; background: #e5e7eb; }
.progress-text { font-size: 20rpx; color: #999; }

.grid-section { padding: 0 32rpx; margin-bottom: 24rpx; }
.grid-card { background: #fff; border-radius: 24rpx; padding: 32rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06); }
.grid-2x2 { display: flex; flex-wrap: wrap; gap: 24rpx; }
.grid-item { width: calc(50% - 12rpx); display: flex; flex-direction: column; align-items: center; padding: 24rpx 0; }
.grid-icon-box { width: 96rpx; height: 96rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 44rpx; margin-bottom: 16rpx; }
.grid-icon-box.purple { background: linear-gradient(135deg, #f3e8ff, #d8b4fe); }
.grid-icon-box.pink { background: linear-gradient(135deg, #fce7f3, #f9a8d4); }
.grid-icon-box.green { background: linear-gradient(135deg, #d1fae5, #6ee7b7); }
.grid-icon-box.blue { background: linear-gradient(135deg, #dbeafe, #93c5fd); }
.grid-text { font-size: 24rpx; color: #333; font-weight: 500; }

.visitors-section { padding: 0 32rpx; }
.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.section-title { font-size: 30rpx; font-weight: bold; color: #000; }
.view-all { font-size: 24rpx; color: #2563eb; }
.visitor-card { background: #fff; border-radius: 24rpx; padding: 24rpx; margin-bottom: 16rpx; display: flex; align-items: center; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06); }
.visitor-avatar { width: 80rpx; height: 80rpx; border-radius: 50%; margin-right: 20rpx; flex-shrink: 0; }
.visitor-info { flex: 1; }
.visitor-name { display: block; font-size: 28rpx; font-weight: bold; color: #000; }
.visitor-role { display: block; font-size: 22rpx; color: #666; margin-top: 4rpx; }
.visitor-actions { display: flex; gap: 12rpx; flex-shrink: 0; }
.action-pill { padding: 10rpx 20rpx; background: #f3f4f6; border-radius: 20rpx; font-size: 22rpx; color: #666; }
