/* home.wxss */

page { background: #f8f9fa; }
.container { min-height: 100vh; padding: 0 32rpx 160rpx; }

/* ID Card Section - Original Style */
.id-section { padding-top: 24rpx; margin-bottom: 32rpx; }
.card-scroll { width: 100%; white-space: nowrap; }
.card-wrapper { display: flex; gap: 20rpx; }

.id-card { width: 100%; height: 400rpx; border-radius: 24rpx; position: relative; overflow: hidden; flex-shrink: 0; }
.card-bg { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
.card-overlay { position: absolute; inset: 0; background: rgba(255,255,255,0.2); }
.card-content { position: absolute; inset: 0; z-index: 2; padding: 24rpx; display: flex; flex-direction: column; justify-content: space-between; }

.card-top { display: flex; justify-content: space-between; align-items: center; }
.id-badge { background: rgba(0,0,0,0.5); padding: 8rpx 20rpx; border-radius: 8rpx; font-size: 22rpx; color: #fff; font-weight: bold; }
.id-qr { width: 56rpx; height: 56rpx; background: rgba(0,0,0,0.5); border-radius: 12rpx; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 28rpx; }

.card-middle { display: flex; justify-content: space-between; align-items: flex-end; }
.id-info { }
.id-name { display: block; color: #fff; font-size: 40rpx; font-weight: bold; text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.3); }
.id-role { display: block; color: rgba(255,255,255,0.9); font-size: 26rpx; margin-top: 6rpx; text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.3); }
.id-avatar { width: 96rpx; height: 96rpx; border-radius: 20rpx; overflow: hidden; border: 4rpx solid rgba(255,255,255,0.5); }
.id-avatar image { width: 100%; height: 100%; }

.card-bottom { display: flex; gap: 16rpx; margin-top: -16rpx; }
.id-action { flex: 1; background: rgba(0,0,0,0.5); border-radius: 16rpx; padding: 18rpx 0; text-align: center; }
.id-action text { color: #fff; font-size: 24rpx; }

/* Dots */
.dots { display: flex; justify-content: center; gap: 12rpx; margin-top: 20rpx; }
.dot { width: 12rpx; height: 12rpx; border-radius: 6rpx; background: #d1d5db; }
.dot.active { background: #2563eb; width: 32rpx; }

/* Quick Actions - v3.0 */
.quick-section { margin-bottom: 24rpx; }
.quick-card { background: #fff; border-radius: 32rpx; padding: 24rpx; box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.06); }
.quick-grid { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 12rpx; }
.quick-item { display: flex; flex-direction: column; align-items: center; padding: 20rpx 8rpx; border-radius: 20rpx; }
.quick-item:active { background: #f8fafc; }

.quick-icon { width: 80rpx; height: 80rpx; border-radius: 20rpx; display: flex; align-items: center; justify-content: center; font-size: 36rpx; margin-bottom: 10rpx; }
.quick-icon.blue { background: linear-gradient(135deg, #3b82f6, #2563eb); }
.quick-icon.yellow { background: linear-gradient(135deg, #fbbf24, #f59e0b); }
.quick-icon.orange { background: linear-gradient(135deg, #f97316, #ea580c); }
.quick-icon.gray { background: linear-gradient(135deg, #64748b, #475569); }

.quick-label { font-size: 22rpx; color: #334155; font-weight: 500; }

/* Data Sections - v3.0 */
.data-section { margin-bottom: 24rpx; }
.trend-card, .visitor-card { background: #fff; border-radius: 32rpx; padding: 24rpx; box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.06); }

.trend-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.trend-title { font-size: 30rpx; font-weight: 700; color: #0f172a; }
.trend-tabs { display: flex; gap: 8rpx; }
.trend-tab { padding: 8rpx 20rpx; border-radius: 16rpx; font-size: 22rpx; color: #64748b; background: #f1f5f9; }
.trend-tab.active { background: #2563eb; color: #fff; }

.trend-chart { display: flex; gap: 12rpx; }
.trend-y { display: flex; flex-direction: column; justify-content: space-between; padding-bottom: 36rpx; }
.trend-y text { font-size: 18rpx; color: #94a3b8; text-align: right; width: 40rpx; }
.trend-bars { flex: 1; display: flex; justify-content: space-around; align-items: flex-end; height: 180rpx; }
.trend-bar-item { display: flex; flex-direction: column; align-items: center; gap: 10rpx; flex: 1; }
.trend-bar { width: 100%; max-width: 44rpx; background: linear-gradient(180deg, #3b82f6, #1d4ed8); border-radius: 8rpx 8rpx 0 0; }
.trend-label { font-size: 20rpx; color: #64748b; }

.visitor-title { font-size: 30rpx; font-weight: 700; color: #0f172a; margin-bottom: 20rpx; display: block; }
.visitor-items { display: flex; flex-direction: column; gap: 16rpx; }
.visitor-row { display: flex; align-items: center; gap: 16rpx; padding: 14rpx; border-radius: 16rpx; }
.visitor-row:active { background: #f8fafc; }

.visitor-avatar-box { width: 64rpx; height: 64rpx; border-radius: 16rpx; background: linear-gradient(135deg, #e2e8f0, #cbd5e1); display: flex; align-items: center; justify-content: center; font-size: 26rpx; color: #475569; font-weight: 600; }
.visitor-detail { flex: 1; display: flex; justify-content: space-between; align-items: center; }
.visitor-name { font-size: 26rpx; font-weight: 600; color: #0f172a; }
.visitor-time { font-size: 22rpx; color: #94a3b8; }

.spacer { height: 120rpx; }
