/* home.wxss */

page { background-color: #f8f9fa; }
.container { min-height: 100vh; padding: 0 24rpx 140rpx; position: relative; }

/* Header BG */
.header-bg { position: absolute; top: 0; left: 0; right: 0; height: 320rpx; background: linear-gradient(135deg, #3b82f6, #fef3c7); border-radius: 0 0 64rpx 64rpx; }

/* Header Card */
.header-card { position: relative; background: linear-gradient(135deg, #2563eb, #1d4ed8); border-radius: 32rpx; padding: 32rpx; margin-top: 120rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1); }
.card-header { display: flex; justify-content: space-between; margin-bottom: 20rpx; }
.card-badge { background: #ffd700; padding: 6rpx 16rpx; border-radius: 8rpx; }
.badge-text { font-size: 20rpx; color: #000; font-weight: bold; }
.card-qr { background: rgba(255,255,255,0.2); padding: 6rpx 16rpx; border-radius: 8rpx; color: #fff; font-size: 20rpx; }
.card-body { display: flex; justify-content: space-between; align-items: flex-end; }
.card-info { }
.card-name { display: block; color: #fff; font-size: 44rpx; font-weight: bold; }
.card-role { display: block; color: rgba(255,255,255,0.9); font-size: 26rpx; margin-top: 8rpx; }
.card-avatar { width: 100rpx; height: 100rpx; border-radius: 20rpx; overflow: hidden; border: 3rpx solid rgba(255,255,255,0.5); }
.card-avatar image { width: 100%; height: 100%; }

/* Action Buttons */
.action-buttons { display: flex; gap: 16rpx; margin-top: 24rpx; margin-bottom: 32rpx; }
.action-btn { flex: 1; background: #fff; border-radius: 32rpx; padding: 20rpx 0; text-align: center; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06); }
.action-btn text { font-size: 26rpx; color: #333; }
.action-btn.toggle { background: #2563eb; }
.action-btn.toggle text { color: #fff; }

/* Grid */
.grid-section { background: #fff; border-radius: 24rpx; padding: 24rpx; margin-bottom: 24rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06); }
.grid-row { display: flex; gap: 16rpx; margin-bottom: 16rpx; }
.grid-row:last-child { margin-bottom: 0; }
.grid-item { flex: 1; display: flex; flex-direction: column; align-items: center; padding: 20rpx; }
.grid-icon { width: 64rpx; height: 64rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 12rpx; }
.grid-icon.blue { background: #3b82f6; }
.grid-icon.gold { background: #ffd700; }
.grid-icon.orange { background: #f97316; }
.grid-icon.darkblue { background: #1e40af; }
.grid-icon text { color: #fff; font-size: 28rpx; font-weight: bold; }
.grid-text { font-size: 24rpx; color: #333; }

/* Data Section */
.data-section { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.data-card { flex: 1; background: #fff; border-radius: 24rpx; padding: 20rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06); }
.data-title { font-size: 24rpx; font-weight: bold; color: #333; display: block; margin-bottom: 16rpx; }
.chart { display: flex; align-items: flex-end; justify-content: space-between; height: 80rpx; }
.bar { width: 24rpx; background: #2563eb; border-radius: 4rpx 4rpx 0 0; }

.visitor-list { }
.visitor-item { display: flex; align-items: center; gap: 12rpx; margin-bottom: 12rpx; }
.visitor-avatar { width: 48rpx; height: 48rpx; border-radius: 50%; background: #e5e7eb; display: flex; align-items: center; justify-content: center; font-size: 22rpx; color: #666; }
.visitor-name { font-size: 22rpx; color: #333; flex: 1; }
.visitor-time { font-size: 20rpx; color: #999; }

/* Analytics */
.analytics-section { margin-bottom: 24rpx; }
.section-title { font-size: 28rpx; font-weight: bold; color: #000; margin-bottom: 16rpx; display: block; }
.analytics-card { background: #fff; border-radius: 24rpx; padding: 24rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06); display: flex; gap: 16rpx; }
.mini-card { flex: 1; height: 80rpx; border-radius: 16rpx; }
.mini-card.blue { background: linear-gradient(135deg, #3b82f6, #1d4ed8); }
.mini-card.gray { background: linear-gradient(135deg, #475569, #334155); }
.mini-card.green { background: linear-gradient(135deg, #10b981, #059669); }

/* Bottom Spacer */
.bottom-spacer { height: 120rpx; }
