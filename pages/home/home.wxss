/* home.wxss */

page { background-color: #f8f9fa; }
.container { min-height: 100vh; padding-bottom: 200rpx; }

/* 当前名片 */
.current-card { position: relative; height: 360rpx; overflow: hidden; }
.card-bg { position: absolute; inset: 0; }
.card-bg image { width: 100%; height: 100%; filter: blur(12rpx); }
.card-content { position: relative; z-index: 2; height: 100%; padding: 48rpx; display: flex; align-items: flex-end; justify-content: space-between; color: #fff; }
.card-info { flex: 1; }
.card-name { display: block; font-size: 44rpx; font-weight: bold; }
.card-role { display: block; font-size: 26rpx; opacity: 0.9; margin-top: 8rpx; }
.card-location { display: block; font-size: 24rpx; opacity: 0.8; margin-top: 8rpx; }
.card-avatar { width: 140rpx; height: 140rpx; border-radius: 24rpx; overflow: hidden; border: 4rpx solid rgba(255,255,255,0.5); box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.2); }
.card-avatar image { width: 100%; height: 100%; }

/* 快捷操作 */
.quick-actions { display: flex; gap: 24rpx; padding: 32rpx; background: #fff; margin-bottom: 16rpx; }
.action-item { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.action-icon { font-size: 48rpx; }
.action-text { font-size: 22rpx; color: #666; }

/* 作品集 */
.section { padding: 0 32rpx 32rpx; }
.section-header { display: flex; justify-content: space-between; margin-bottom: 24rpx; }
.section-title { font-size: 32rpx; font-weight: bold; color: #000; }
.project-list { display: flex; flex-direction: column; gap: 24rpx; }
.project-card { background: #fff; border-radius: 24rpx; overflow: hidden; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06); }
.project-thumb { width: 100%; height: 280rpx; }
.project-info { padding: 24rpx; }
.project-title { display: block; font-size: 28rpx; font-weight: 600; color: #000; margin-bottom: 8rpx; }
.project-desc { display: block; font-size: 24rpx; color: #666; line-height: 1.5; }

/* 底部浮动 */
.fab-container { position: fixed; bottom: 200rpx; left: 50%; transform: translateX(-50%); }
.fab-primary { padding: 24rpx 64rpx; background: #2F65EE; border-radius: 60rpx; box-shadow: 0 16rpx 48rpx rgba(47,101,238,0.3); }
.fab-primary text { color: #fff; font-size: 28rpx; font-weight: 600; }
