/* home.wxss */

page { background-color: #f8f9fa; }
.container { min-height: 100vh; padding-bottom: 120rpx; }

/* Header Card */
.header-card { position: relative; height: 320rpx; overflow: hidden; margin: 24rpx; border-radius: 32rpx; }
.header-bg { position: absolute; inset: 0; }
.header-bg image { width: 100%; height: 100%; filter: blur(12rpx); }
.header-content { position: relative; z-index: 2; height: 100%; padding: 32rpx; display: flex; justify-content: space-between; align-items: flex-end; color: #fff; }
.header-info { flex: 1; }
.header-name { display: block; font-size: 44rpx; font-weight: bold; }
.header-role { display: block; font-size: 26rpx; opacity: 0.9; margin-top: 8rpx; }
.header-company { display: block; font-size: 22rpx; opacity: 0.7; margin-top: 4rpx; }
.header-avatar { width: 120rpx; height: 120rpx; border-radius: 24rpx; overflow: hidden; border: 4rpx solid rgba(255,255,255,0.5); }
.header-avatar image { width: 100%; height: 100%; }

/* Grid */
.grid-section { padding: 0 24rpx; margin-bottom: 24rpx; }
.grid-card { background: #fff; border-radius: 24rpx; padding: 24rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06); }
.grid-2x2 { display: flex; flex-wrap: wrap; gap: 24rpx; }
.grid-item { width: calc(50% - 12rpx); display: flex; flex-direction: column; align-items: center; padding: 24rpx 0; }
.grid-icon { width: 80rpx; height: 80rpx; border-radius: 20rpx; display: flex; align-items: center; justify-content: center; font-size: 36rpx; margin-bottom: 12rpx; }
.grid-icon.purple { background: linear-gradient(135deg, #e0e7ff, #c7d2fe); }
.grid-icon.pink { background: linear-gradient(135deg, #ffe4e6, #fecdd3); }
.grid-icon.green { background: linear-gradient(135deg, #d1fae5, #6ee7b7); }
.grid-icon.blue { background: linear-gradient(135deg, #dbeafe, #93c5fd); }
.grid-icon.gold { background: linear-gradient(135deg, #fef3c7, #fcd34d); }
.grid-icon.indigo { background: linear-gradient(135deg, #e0e7ff, #a5b4fc); }
.grid-text { font-size: 24rpx; color: #333; }

/* Visitors */
.visitors-section { padding: 0 24rpx; }
.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.section-title { font-size: 28rpx; font-weight: bold; color: #000; }
.section-more { font-size: 24rpx; color: #2563eb; }
.visitor-list { display: flex; flex-direction: column; gap: 16rpx; }
.visitor-item { display: flex; align-items: center; background: #fff; padding: 20rpx; border-radius: 20rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06); }
.visitor-avatar { width: 80rpx; height: 80rpx; border-radius: 16rpx; margin-right: 16rpx; }
.visitor-info { flex: 1; }
.visitor-name { display: block; font-size: 28rpx; font-weight: bold; color: #000; }
.visitor-role { display: block; font-size: 22rpx; color: #666; margin-top: 4rpx; }
.visitor-time { font-size: 22rpx; color: #999; }
