/* home.wxss */

page { background-color: #f8f9fa; }
.container { min-height: 100vh; padding-bottom: 140rpx; }

/* Header Section */
.header-section { position: relative; padding: 24rpx; }
.header-bg { position: absolute; top: 0; left: 0; right: 0; height: 200rpx; background: linear-gradient(135deg, #3b82f6, #fef3c7); border-radius: 0 0 48rpx 48rpx; }

/* Header Card */
.header-card { position: relative; background: linear-gradient(135deg, #3b82f6, #1d4ed8); border-radius: 32rpx; padding: 32rpx; margin-top: 80rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1); }
.card-badge { display: flex; align-items: center; gap: 8rpx; margin-bottom: 16rpx; }
.badge-icon { color: #ffd700; font-size: 24rpx; }
.badge-text { color: #fff; font-size: 20rpx; background: rgba(255,255,255,0.2); padding: 4rpx 12rpx; border-radius: 8rpx; }
.qr-icon { margin-left: auto; color: #fff; font-size: 20rpx; background: rgba(255,255,255,0.2); padding: 4rpx 12rpx; border-radius: 8rpx; }
.card-content { display: flex; justify-content: space-between; align-items: flex-end; }
.card-info { }
.card-name { display: block; color: #fff; font-size: 40rpx; font-weight: bold; }
.card-role { display: block; color: rgba(255,255,255,0.9); font-size: 26rpx; margin-top: 8rpx; }
.card-avatar { width: 100rpx; height: 100rpx; border-radius: 20rpx; overflow: hidden; border: 3rpx solid rgba(255,255,255,0.5); }
.card-avatar image { width: 100%; height: 100%; }

/* Card Actions */
.card-actions { display: flex; gap: 16rpx; margin-top: 24rpx; }
.action-btn { flex: 1; background: #fff; border-radius: 16rpx; padding: 20rpx; text-align: center; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06); }
.action-btn text { font-size: 26rpx; color: #333; }
.action-toggle { flex: 1.5; background: #fff; border-radius: 16rpx; padding: 20rpx; display: flex; align-items: center; justify-content: space-between; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06); }
.action-toggle text { font-size: 26rpx; color: #333; }
.toggle-switch { width: 80rpx; height: 40rpx; background: #2563eb; border-radius: 20rpx; position: relative; }
.toggle-switch::after { content: ''; position: absolute; width: 32rpx; height: 32rpx; background: #fff; border-radius: 50%; top: 4rpx; right: 4rpx; }

/* Grid Section */
.grid-section { padding: 0 24rpx; margin-bottom: 24rpx; }
.grid-card { background: #fff; border-radius: 24rpx; padding: 24rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06); }
.grid-2x2 { display: flex; flex-wrap: wrap; gap: 16rpx; }
.grid-item { width: calc(50% - 8rpx); display: flex; flex-direction: column; align-items: center; padding: 20rpx; }
.grid-icon { width: 64rpx; height: 64rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 8rpx; }
.grid-icon.blue { background: #3b82f6; }
.grid-icon.gold { background: #ffd700; }
.grid-icon.orange { background: #f97316; }
.grid-icon.blue2 { background: #2563eb; }
.grid-icon-text { color: #fff; font-size: 28rpx; font-weight: bold; }
.grid-text { font-size: 22rpx; color: #333; }

/* Data Section */
.data-section { display: flex; gap: 16rpx; padding: 0 24rpx; margin-bottom: 24rpx; }
.data-card { flex: 1; background: #fff; border-radius: 24rpx; padding: 20rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06); }
.data-header { margin-bottom: 16rpx; }
.data-title { font-size: 24rpx; font-weight: bold; color: #333; }
.data-chart { }
.chart-bars { display: flex; align-items: flex-end; justify-content: space-between; height: 80rpx; margin-bottom: 8rpx; }
.bar { width: 24rpx; background: #2563eb; border-radius: 4rpx 4rpx 0 0; }
.chart-label { font-size: 18rpx; color: #999; }

.visitor-mini-list { }
.visitor-mini { display: flex; align-items: center; gap: 12rpx; margin-bottom: 12rpx; }
.visitor-mini-avatar { width: 48rpx; height: 48rpx; border-radius: 50%; background: #e5e7eb; display: flex; align-items: center; justify-content: center; font-size: 20rpx; color: #666; }
.visitor-mini-info { }
.visitor-mini-name { display: block; font-size: 22rpx; color: #333; }
.visitor-mini-time { display: block; font-size: 18rpx; color: #999; }

/* Analytics Section */
.analytics-section { padding: 0 24rpx; margin-bottom: 24rpx; }
.section-title { font-size: 28rpx; font-weight: bold; color: #000; margin-bottom: 16rpx; }
.analytics-card { background: #fff; border-radius: 24rpx; padding: 24rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06); }
.mini-cards { display: flex; gap: 16rpx; }
.mini-card { width: 120rpx; height: 80rpx; border-radius: 16rpx; }
.mini-card.blue { background: linear-gradient(135deg, #3b82f6, #1d4ed8); }
.mini-card.gray { background: linear-gradient(135deg, #475569, #334155); }
.mini-card.green { background: linear-gradient(135deg, #10b981, #059669); }

/* Actions Section */
.actions-section { padding: 0 24rpx; margin-bottom: 24rpx; }
.action-list-card { background: #fff; border-radius: 24rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06); }
.action-list-item { display: flex; align-items: center; padding: 24rpx; border-bottom: 1rpx solid #f0f0f0; }
.action-list-item:last-child { border-bottom: none; }
.action-list-icon { width: 48rpx; height: 48rpx; background: #f0f9ff; border-radius: 12rpx; display: flex; align-items: center; justify-content: center; font-size: 24rpx; color: #2563eb; margin-right: 16rpx; }
.action-list-text { flex: 1; font-size: 26rpx; color: #333; }
.action-list-arrow { color: #ccc; font-size: 28rpx; }

/* Bottom Spacer */
.bottom-spacer { height: 120rpx; }
