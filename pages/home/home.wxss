/* home.wxss */

page { background-color: #f8f9fa; }
.container { min-height: 100vh; padding: 0 24rpx 140rpx; }

/* ID Card Section */
.id-section { padding-top: 24rpx; margin-bottom: 32rpx; }
.card-scroll { width: 100%; white-space: nowrap; }
.card-wrapper { display: flex; gap: 20rpx; padding: 0 24rpx; box-sizing: border-box; }

/* ID Card */
.id-card { width: 100%; height: 400rpx; border-radius: 32rpx; position: relative; overflow: hidden; flex-shrink: 0; }

.card-bg { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; }
.card-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(255,255,255,0.2); z-index: 2; }
.card-content { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 3; padding: 20rpx; display: flex; flex-direction: column; justify-content: space-between; box-sizing: border-box; }

.card-top { display: flex; justify-content: space-between; align-items: center; }
.id-badge { background: rgba(0,0,0,0.5); padding: 8rpx 20rpx; border-radius: 8rpx; font-size: 22rpx; color: #fff; font-weight: bold; }
.id-qr-btn { width: 56rpx; height: 56rpx; background: rgba(0,0,0,0.5); border-radius: 12rpx; display: flex; align-items: center; justify-content: center; }
.qr-box { display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: 1fr 1fr; gap: 3rpx; width: 28rpx; height: 28rpx; }
.qr-dot { background: #fff; border-radius: 2rpx; }

.card-middle { display: flex; justify-content: space-between; align-items: flex-end; }
.id-info { }
.id-name { display: block; color: #fff; font-size: 40rpx; font-weight: 600; text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.3); }
.id-role { display: block; color: rgba(255,255,255,0.9); font-size: 26rpx; margin-top: 6rpx; text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.3); }
.id-avatar { width: 96rpx; height: 96rpx; border-radius: 20rpx; overflow: hidden; border: 4rpx solid rgba(255,255,255,0.6); box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.2); }
.id-avatar image { width: 100%; height: 100%; }

.card-bottom { display: flex; gap: 16rpx; margin-top: -16rpx; }
.id-action { flex: 1; background: rgba(0,0,0,0.5); border-radius: 16rpx; padding: 18rpx 0; text-align: center; }
.id-action text { color: #fff; font-size: 24rpx; }

/* Page Indicators */
.page-indicators { display: flex; justify-content: center; gap: 12rpx; margin-top: 20rpx; }
.indicator { width: 12rpx; height: 12rpx; border-radius: 6rpx; background: #d1d5db; }
.indicator.active { background: #2563eb; width: 32rpx; }

/* Grid Section - Premium */
.grid-section { margin-bottom: 24rpx; }
.grid-card { background: #fff; border-radius: 24rpx; padding: 24rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06); }
.grid-row { display: flex; gap: 24rpx; margin-bottom: 20rpx; }
.grid-row:last-child { margin-bottom: 0; }
.grid-item { flex: 1; display: flex; flex-direction: column; align-items: center; padding: 20rpx 0; }

.grid-icon-wrap { width: 80rpx; height: 80rpx; border-radius: 20rpx; display: flex; align-items: center; justify-content: center; margin-bottom: 12rpx; position: relative; overflow: hidden; }
.grid-icon-wrap.blue { background: linear-gradient(135deg, #3b82f6, #1d4ed8); }
.grid-icon-wrap.gold { background: linear-gradient(135deg, #fbbf24, #d97706); }
.grid-icon-wrap.orange { background: linear-gradient(135deg, #f97316, #ea580c); }
.grid-icon-wrap.dark { background: linear-gradient(135deg, #475569, #1e293b); }

/* Premium Icons - Using CSS shapes */
.icon-plus { width: 24rpx; height: 24rpx; border: 4rpx solid #fff; border-radius: 4rpx; position: relative; }
.icon-plus::after { content: ''; position: absolute; top: 50%; left: -4rpx; right: -4rpx; height: 4rpx; background: #fff; transform: translateY(-50%); }
.icon-plus::before { content: ''; position: absolute; left: 50%; top: -4rpx; bottom: -4rpx; width: 4rpx; background: #fff; transform: translateX(-50%); }

.icon-star { width: 20rpx; height: 20rpx; background: #fff; clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%); }

.icon-chart { width: 28rpx; height: 24rpx; border: 3rpx solid #fff; border-radius: 2rpx; position: relative; background: transparent; }
.icon-chart::before { content: ''; position: absolute; bottom: 0; left: 4rpx; width: 6rpx; height: 12rpx; background: #fff; border-radius: 2rpx; }
.icon-chart::after { content: ''; position: absolute; bottom: 0; right: 4rpx; width: 6rpx; height: 18rpx; background: #fff; border-radius: 2rpx; }

.icon-setting { width: 24rpx; height: 24rpx; border: 4rpx solid #fff; border-radius: 50%; position: relative; }
.icon-setting::after { content: ''; position: absolute; top: 50%; left: 50%; width: 8rpx; height: 8rpx; background: #fff; border-radius: 50%; transform: translate(-50%, -50%); }

.grid-text { font-size: 24rpx; color: #333; font-weight: 500; }

/* Data Section */
.data-section { margin-bottom: 24rpx; }
.data-card { background: #fff; border-radius: 24rpx; padding: 24rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06); }
.data-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.data-title { font-size: 28rpx; font-weight: 600; color: #121212; }

/* Time Filter */
.time-filter { display: flex; gap: 8rpx; }
.filter-item { padding: 8rpx 20rpx; background: #f1f5f9; border-radius: 20rpx; font-size: 22rpx; color: #64748b; }
.filter-item.active { background: #2563eb; color: #fff; }

/* Chart */
.chart-container { display: flex; gap: 12rpx; }
.chart-y { display: flex; flex-direction: column; justify-content: space-between; padding-bottom: 32rpx; }
.chart-y text { font-size: 18rpx; color: #94a3b8; text-align: right; width: 40rpx; }
.chart-area { flex: 1; }
.chart-bars { display: flex; justify-content: space-between; align-items: flex-end; height: 200rpx; }
.bar-wrapper { display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.bar { width: 32rpx; background: linear-gradient(180deg, #3b82f6, #1d4ed8); border-radius: 6rpx 6rpx 0 0; }
.bar-label { font-size: 18rpx; color: #94a3b8; }

/* Visitors */
.visitor-list { }
.visitor-item { display: flex; align-items: center; gap: 16rpx; margin-bottom: 16rpx; }
.visitor-item:last-child { margin-bottom: 0; }
.visitor-avatar { width: 56rpx; height: 56rpx; border-radius: 16rpx; background: #e2e8f0; display: flex; align-items: center; justify-content: center; font-size: 24rpx; color: #475569; font-weight: 600; }
.visitor-info { flex: 1; display: flex; justify-content: space-between; align-items: center; }
.visitor-name { font-size: 26rpx; color: #121212; font-weight: 500; }
.visitor-time { font-size: 22rpx; color: #94a3b8; }

/* Bottom Spacer */
.bottom-spacer { height: 120rpx; }
