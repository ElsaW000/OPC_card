/**home.wxss - 响应式工作台 */

page {
  background-color: #f8fafc;
}

.container {
  width: 100%;
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: 120rpx;
  overflow-x: hidden;
}

/* Header */
.header {
  width: 100%;
  padding: 32rpx 32rpx 24rpx;
  background: #fff;
  box-sizing: border-box;
  border-bottom-left-radius: 32rpx;
  border-bottom-right-radius: 32rpx;
}

.header-title {
  font-size: 48rpx;
  font-weight: 900;
  color: #111;
}

.header-subtitle {
  font-size: 26rpx;
  color: #64748b;
  margin-top: 8rpx;
}

/* Stats Row */
.stats-row {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  box-sizing: border-box;
}

.stat-card {
  flex: 1;
  border-radius: 28rpx;
  padding: 28rpx;
  box-sizing: border-box;
  min-width: 0;
}

.card-blue {
  background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%);
}

.card-green {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
}

/* Todo Card */
.todo-card {
  margin: 0 32rpx 24rpx;
  background: linear-gradient(135deg, #fefce8 0%, #fef9c3 100%);
  border-radius: 24rpx;
  padding: 24rpx;
  display: flex;
  box-sizing: border-box;
}

/* Grid Section - 2x2 */
.grid-section {
  padding: 0 32rpx 24rpx;
  box-sizing: border-box;
}

.grid-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.grid-2x2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
}

.grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  box-sizing: border-box;
}

.grid-item:nth-child(odd) {
  border-right: 1rpx solid #f1f5f9;
}

.grid-item:nth-child(1),
.grid-item:nth-child(2) {
  border-bottom: 1rpx solid #f1f5f9;
}

/* Visitors */
.visitors-section {
  padding: 0 32rpx 32rpx;
  box-sizing: border-box;
}

/* 响应式 */
@media (max-width: 375px) {
  .header, .stats-row, .todo-card, .grid-section, .visitors-section {
    padding-left: 20rpx;
    padding-right: 20rpx;
  }
  
  .stats-row {
    gap: 12rpx;
  }
  
  .stat-card {
    padding: 20rpx;
  }
}

@media (min-width: 400px) {
  .header, .stats-row, .todo-card, .grid-section, .visitors-section {
    padding-left: 40rpx;
    padding-right: 40rpx;
  }
}
