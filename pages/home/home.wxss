/* home.wxss - v3.0 Design */

page { background: #f8f9fa; }
.container { min-height: 100vh; padding: 0 32rpx 160rpx; }

/* ID Card Section */
.id-section { padding-top: 32rpx; margin-bottom: 32rpx; }
.card-scroll { width: 100%; }
.card-wrapper { display: flex; gap: 24rpx; }

.id-card { 
  width: 100%; 
  height: 380rpx; 
  border-radius: 40rpx; 
  position: relative; 
  overflow: hidden; 
  flex-shrink: 0; 
  flex: 1;
}

.card-bg { position: absolute; inset: 0; width: 100%; height: 100%; }
.card-overlay { 
  position: absolute; inset: 0; 
  background: linear-gradient(135deg, rgba(255,255,255,0.15), rgba(255,255,255,0.05)); 
}
.card-content { 
  position: relative; z-index: 2; 
  height: 100%; padding: 32rpx; 
  display: flex; flex-direction: column; 
  justify-content: space-between; 
  box-sizing: border-box;
}

/* Glass Effect */
.glass-badge { 
  background: rgba(255,255,255,0.25); 
  backdrop-filter: blur(20rpx);
  padding: 10rpx 24rpx; border-radius: 12rpx; 
  font-size: 22rpx; color: #fff; font-weight: 600;
}

.glass-qr { 
  width: 60rpx; height: 60rpx; 
  background: rgba(255,255,255,0.25); 
  backdrop-filter: blur(20rpx);
  border-radius: 16rpx; 
  display: flex; align-items: center; justify-content: center;
  color: #fff; font-size: 32rpx;
}

.card-body { display: flex; justify-content: space-between; align-items: flex-end; }
.card-text { }
.glass-name { 
  display: block; color: #fff; 
  font-size: 44rpx; font-weight: 700; 
  text-shadow: 0 4rpx 12rpx rgba(0,0,0,0.2);
}
.glass-role { 
  display: block; color: rgba(255,255,255,0.9); 
  font-size: 28rpx; margin-top: 8rpx;
}

.glass-avatar { 
  width: 100rpx; height: 100rpx; 
  border-radius: 24rpx; 
  overflow: hidden; 
  border: 4rpx solid rgba(255,255,255,0.4);
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15);
}
.glass-avatar image { width: 100%; height: 100%; }

.card-actions { display: flex; gap: 16rpx; }
.glass-btn { 
  flex: 1; 
  background: rgba(255,255,255,0.25); 
  backdrop-filter: blur(20rpx);
  border-radius: 20rpx; padding: 20rpx 0; 
  text-align: center; color: #fff; font-size: 26rpx;
}

/* Dots */
.dots { display: flex; justify-content: center; gap: 16rpx; margin-top: 24rpx; }
.dot { width: 12rpx; height: 12rpx; border-radius: 50%; background: #cbd5e1; transition: all 0.3s; }
.dot.active { width: 32rpx; background: #2563eb; border-radius: 6rpx; }

/* Quick Actions */
.quick-section { margin-bottom: 24rpx; }
.quick-card { 
  background: #fff; border-radius: 32rpx; 
  padding: 32rpx; 
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.06);
}
.quick-grid { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 16rpx; }
.quick-item { 
  display: flex; flex-direction: column; align-items: center; 
  padding: 24rpx 8rpx; 
  border-radius: 24rpx;
}
.quick-item:active { background: #f8fafc; }

.quick-icon { 
  width: 88rpx; height: 88rpx; 
  border-radius: 24rpx; 
  display: flex; align-items: center; justify-content: center;
  font-size: 40rpx; margin-bottom: 12rpx;
}
.quick-icon.blue { background: linear-gradient(135deg, #3b82f6, #2563eb); color: #fff; }
.quick-icon.yellow { background: linear-gradient(135deg, #fbbf24, #f59e0b); color: #fff; }
.quick-icon.orange { background: linear-gradient(135deg, #f97316, #ea580c); color: #fff; }
.quick-icon.gray { background: linear-gradient(135deg, #64748b, #475569); color: #fff; }

.quick-label { font-size: 24rpx; color: #334155; font-weight: 500; }

/* Data Section */
.data-section { margin-bottom: 24rpx; }
.trend-card, .visitor-card { 
  background: #fff; border-radius: 32rpx; 
  padding: 32rpx; 
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.06);
}

.trend-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32rpx; }
.trend-title { font-size: 32rpx; font-weight: 700; color: #0f172a; }
.trend-tabs { display: flex; gap: 8rpx; }
.trend-tab { 
  padding: 10rpx 24rpx; border-radius: 20rpx; 
  font-size: 24rpx; color: #64748b; background: #f1f5f9;
}
.trend-tab.active { background: #2563eb; color: #fff; }

/* Chart */
.trend-chart { display: flex; gap: 12rpx; }
.trend-y { display: flex; flex-direction: column; justify-content: space-between; padding-bottom: 40rpx; }
.trend-y text { font-size: 20rpx; color: #94a3b8; text-align: right; width: 48rpx; }
.trend-bars { flex: 1; display: flex; justify-content: space-around; align-items: flex-end; height: 200rpx; }
.trend-bar-item { display: flex; flex-direction: column; align-items: center; gap: 12rpx; flex: 1; }
.trend-bar { 
  width: 100%; max-width: 48rpx; 
  background: linear-gradient(180deg, #3b82f6, #1d4ed8); 
  border-radius: 12rpx 12rpx 0 0; 
}
.trend-label { font-size: 22rpx; color: #64748b; }

/* Visitors */
.visitor-title { font-size: 32rpx; font-weight: 700; color: #0f172a; margin-bottom: 24rpx; display: block; }
.visitor-items { display: flex; flex-direction: column; gap: 20rpx; }
.visitor-row { display: flex; align-items: center; gap: 20rpx; padding: 16rpx; border-radius: 20rpx; }
.visitor-row:active { background: #f8fafc; }

.visitor-avatar-box { 
  width: 72rpx; height: 72rpx; 
  border-radius: 20rpx; 
  background: linear-gradient(135deg, #e2e8f0, #cbd5e1);
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; color: #475569; font-weight: 600;
}
.visitor-detail { flex: 1; display: flex; justify-content: space-between; align-items: center; }
.visitor-name { font-size: 28rpx; font-weight: 600; color: #0f172a; }
.visitor-time { font-size: 24rpx; color: #94a3b8; }

/* Spacer */
.spacer { height: 140rpx; }
