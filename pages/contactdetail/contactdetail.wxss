/* contactdetail.wxss */

page { background-color: #f3f4f6; }
.container { min-height: 100vh; padding-bottom: 120rpx; }

.profile-card { position: relative; height: 360rpx; overflow: hidden; }
.profile-bg { position: absolute; inset: 0; }
.profile-bg image { width: 100%; height: 100%; filter: blur(12rpx); }
.profile-content { position: relative; z-index: 2; height: 100%; padding: 48rpx; display: flex; align-items: flex-end; color: #fff; }
.profile-avatar { width: 140rpx; height: 140rpx; border-radius: 24rpx; border: 4rpx solid rgba(255,255,255,0.5); margin-right: 24rpx; }
.profile-info { flex: 1; }
.profile-name { display: block; font-size: 44rpx; font-weight: bold; }
.profile-role { display: block; font-size: 26rpx; opacity: 0.9; margin-top: 8rpx; }
.profile-location { display: block; font-size: 24rpx; opacity: 0.8; margin-top: 8rpx; }

.section { background: #fff; margin-bottom: 16rpx; padding: 32rpx; }
.section-title { font-size: 28rpx; font-weight: 600; color: #000; display: block; margin-bottom: 16rpx; }
.section-content { font-size: 26rpx; color: #666; line-height: 1.6; }

.contact-list { display: flex; flex-direction: column; gap: 20rpx; }
.contact-item { display: flex; align-items: center; padding: 20rpx; background: #f8f9fa; border-radius: 16rpx; }
.contact-icon { font-size: 36rpx; margin-right: 20rpx; }
.contact-value { font-size: 28rpx; color: #333; }

.actions { display: flex; gap: 20rpx; padding: 32rpx; position: fixed; bottom: 0; left: 0; right: 0; background: #fff; }
.btn-primary { flex: 1; padding: 24rpx; background: #2563eb; border-radius: 16rpx; text-align: center; }
.btn-primary text { color: #fff; font-size: 28rpx; font-weight: 600; }
.btn-secondary { flex: 1; padding: 24rpx; background: #fff; border-radius: 16rpx; border: 2rpx solid #e5e7eb; text-align: center; }
.btn-secondary text { color: #333; font-size: 28rpx; font-weight: 600; }
