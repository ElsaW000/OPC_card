<!--analytics.wxml - 数据分析 -->
<view class="container">
  <view class="header">
    <view class="header-title">数据分析</view>
    <view class="header-subtitle">Analytics Overview</view>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-grid">
    <view class="stat-card">
      <text class="stat-value">{{stats.totalViews}}</text>
      <text class="stat-label">总浏览量</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{stats.totalExchanges}}</text>
      <text class="stat-label">交换次数</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{stats.totalContacts}}</text>
      <text class="stat-label">联系人</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{stats.weekViews}}</text>
      <text class="stat-label">本周浏览</text>
    </view>
  </view>

  <!-- 趋势图（简化版） -->
  <view class="chart-section">
    <view class="section-title">浏览趋势</view>
    <view class="trend-chart">
      <view class="chart-bars">
        <block wx:for="{{trendData}}" wx:key="day">
          <view class="bar-item">
            <view class="bar" style="height: {{item.value}}%"></view>
            <text class="bar-label">{{item.day}}</text>
          </view>
        </block>
      </view>
    </view>
  </view>

  <!-- 来源分析 -->
  <view class="source-section">
    <view class="section-title">访问来源</view>
    <view class="source-list">
      <view class="source-item" wx:for="{{sources}}" wx:key="name">
        <view class="source-info">
          <text class="source-name">{{item.name}}</text>
          <text class="source-count">{{item.count}} 次</text>
        </view>
        <view class="source-bar">
          <view class="source-bar-inner" style="width: {{item.percent}}%"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 热门名片 -->
  <view class="popular-section">
    <view class="section-title">热门名片</view>
    <view class="popular-list">
      <view class="popular-item" wx:for="{{popularCards}}" wx:key="id">
        <text class="popular-rank">{{index + 1}}</text>
        <text class="popular-name">{{item.name}}</text>
        <text class="popular-views">{{item.views}} 次</text>
      </view>
    </view>
  </view>
</view>
