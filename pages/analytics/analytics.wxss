/* analytics.wxss - 响应式 */

page {
  background-color: #f8fafc;
  --safe-top: env(safe-area-inset-top);
  --safe-bottom: env(safe-area-inset-bottom);
}

.container {
  min-height: 100vh;
  min-height: calc(100vh + var(--safe-top));
  padding-bottom: calc(140rpx + var(--safe-bottom));
  box-sizing: border-box;
}

.header {
  padding: calc(32rpx + var(--safe-top)) 24rpx 24rpx;
  background-color: #fff;
  border-bottom-left-radius: 28rpx;
  border-bottom-right-radius: 28rpx;
}

.header-title {
  font-size: 48rpx;
  font-weight: 900;
  color: #111;
}

.header-subtitle {
  font-size: 20rpx;
  font-weight: 700;
  color: #94a3b8;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  margin-top: 6rpx;
}

/* 2x2 统计卡片 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 24rpx;
}

.stat-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: 900;
  color: #111;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #64748b;
  margin-top: 6rpx;
}

.chart-section, .source-section, .popular-section {
  margin: 0 24rpx 24rpx;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #111;
  margin-bottom: 20rpx;
}

.trend-chart {
  height: 280rpx;
}

.chart-bars {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 220rpx;
}

.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  flex: 1;
}

.bar {
  width: 28rpx;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
  border-radius: 6rpx 6rpx 0 0;
  transition: height 0.3s;
}

.bar-label {
  font-size: 20rpx;
  color: #94a3b8;
}

.source-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.source-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.source-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.source-name {
  font-size: 28rpx;
  color: #111;
  font-weight: 500;
}

.source-count {
  font-size: 22rpx;
  color: #94a3b8;
}

.source-bar {
  height: 12rpx;
  background-color: #f1f5f9;
  border-radius: 6rpx;
  overflow: hidden;
}

.source-bar-inner {
  height: 100%;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  border-radius: 6rpx;
}

.popular-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.popular-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
}

.popular-rank {
  width: 40rpx;
  height: 40rpx;
  background-color: #f1f5f9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #64748b;
  flex-shrink: 0;
}

.popular-name {
  flex: 1;
  font-size: 28rpx;
  color: #111;
  font-weight: 500;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.popular-views {
  font-size: 22rpx;
  color: #94a3b8;
  flex-shrink: 0;
}

/* 响应式 */
@media (max-width: 320px) {
  .stats-grid {
    gap: 12rpx;
    padding: 16rpx;
  }
  
  .stat-card {
    padding: 20rpx;
  }
  
  .stat-value {
    font-size: 40rpx;
  }
  
  .chart-bars {
    height: 180rpx;
  }
  
  .bar {
    width: 20rpx;
  }
}

@media (min-width: 400px) {
  .header {
    padding: calc(40rpx + var(--safe-top)) 32rpx 28rpx;
  }
  
  .stats-grid {
    gap: 24rpx;
    padding: 32rpx;
  }
  
  .stat-card {
    padding: 36rpx;
  }
  
  .stat-value {
    font-size: 56rpx;
  }
  
  .chart-section, .source-section, .popular-section {
    margin: 0 32rpx 32rpx;
    padding: 32rpx;
  }
  
  .trend-chart {
    height: 320rpx;
  }
  
  .chart-bars {
    height: 260rpx;
  }
}
