/* analytics.wxss */

.container {
  min-height: 100vh;
  background-color: #f9fafb;
  padding-bottom: 48rpx;
}

.header {
  padding: 48rpx 32rpx 32rpx;
  background-color: #fff;
}

.header-title {
  font-size: 48rpx;
  font-weight: 900;
  color: #111;
}

.header-subtitle {
  font-size: 24rpx;
  font-weight: 700;
  color: #9ca3af;
  text-transform: uppercase;
  letter-spacing: 4rpx;
  margin-top: 8rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  padding: 32rpx;
}

.stat-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #111;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 8rpx;
}

.chart-section, .source-section, .popular-section {
  margin: 32rpx;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111;
  margin-bottom: 24rpx;
}

.trend-chart {
  height: 300rpx;
}

.chart-bars {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 240rpx;
}

.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.bar {
  width: 32rpx;
  background: linear-gradient(180deg, #667eea, #764ba2);
  border-radius: 8rpx 8rpx 0 0;
}

.bar-label {
  font-size: 22rpx;
  color: #9ca3af;
}

.source-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.source-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.source-info {
  display: flex;
  justify-content: space-between;
}

.source-name {
  font-size: 28rpx;
  color: #111;
}

.source-count {
  font-size: 24rpx;
  color: #9ca3af;
}

.source-bar {
  height: 12rpx;
  background-color: #f3f4f6;
  border-radius: 6rpx;
  overflow: hidden;
}

.source-bar-inner {
  height: 100%;
  background: linear-gradient(90deg, #667eea, #764ba2);
  border-radius: 6rpx;
}

.popular-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.popular-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.popular-rank {
  width: 40rpx;
  height: 40rpx;
  background-color: #f3f4f6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  color: #6b7280;
}

.popular-name {
  flex: 1;
  font-size: 28rpx;
  color: #111;
}

.popular-views {
  font-size: 24rpx;
  color: #9ca3af;
}
