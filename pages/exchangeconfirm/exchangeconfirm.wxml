<view class="container">
  <view class="header">
    <text class="header-title">交换名片</text>
    <text class="header-desc">请确认将向对方发送你的默认名片</text>
  </view>

  <view class="card-preview">
    <view class="preview-bg">
      <image src="{{card.bannerUrl}}" mode="aspectFill"></image>
    </view>
    <view class="preview-content">
      <view class="preview-info">
        <text class="preview-name">{{card.name}}</text>
        <text class="preview-role">{{card.role}}</text>
        <text class="preview-company" wx:if="{{card.company}}">{{card.company}}</text>
      </view>
      <view class="preview-avatar">
        <image src="{{card.avatarUrl}}" mode="aspectFill"></image>
      </view>
    </view>
  </view>

  <view class="exchange-info">
    <view class="info-item">
      <text class="info-icon">提示</text>
      <text class="info-text">发起交换后，对方会在联系人中收到一条待处理请求。</text>
    </view>
    <view class="info-item">
      <text class="info-icon">同步</text>
      <text class="info-text">当对方同意后，双方都会自动进入联系人列表。</text>
    </view>
  </view>

  <view class="actions">
    <view class="btn-primary" bindtap="confirmExchange">
      <text>{{loading ? '发送中...' : '确认交换'}}</text>
    </view>
    <view class="btn-secondary" bindtap="cancelExchange">
      <text>取消</text>
    </view>
  </view>
</view>