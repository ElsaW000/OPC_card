/* exchangeconfirm.wxss */

page { background-color: #f3f4f6; }
.container { min-height: 100vh; padding: 32rpx; }

.header { margin-bottom: 32rpx; }
.header-title { font-size: 40rpx; font-weight: bold; color: #000; display: block; }
.header-desc { font-size: 26rpx; color: #999; margin-top: 8rpx; display: block; }

.card-preview { position: relative; height: 280rpx; border-radius: 24rpx; overflow: hidden; margin-bottom: 32rpx; box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.1); }
.preview-bg { position: absolute; inset: 0; }
.preview-bg image { width: 100%; height: 100%; filter: blur(8rpx); }
.preview-content { position: relative; z-index: 2; height: 100%; padding: 32rpx; display: flex; align-items: flex-end; justify-content: space-between; color: #fff; }
.preview-info { flex: 1; }
.preview-name { display: block; font-size: 40rpx; font-weight: bold; }
.preview-role { display: block; font-size: 26rpx; opacity: 0.9; margin-top: 8rpx; }
.preview-company { display: block; font-size: 24rpx; opacity: 0.8; margin-top: 4rpx; }
.preview-avatar { width: 100rpx; height: 100rpx; border-radius: 20rpx; overflow: hidden; border: 3rpx solid rgba(255,255,255,0.5); }
.preview-avatar image { width: 100%; height: 100%; }

.exchange-info { background: #fff; border-radius: 24rpx; padding: 24rpx; margin-bottom: 48rpx; }
.info-item { display: flex; align-items: flex-start; margin-bottom: 20rpx; }
.info-item:last-child { margin-bottom: 0; }
.info-icon { font-size: 28rpx; margin-right: 16rpx; }
.info-text { font-size: 24rpx; color: #666; line-height: 1.5; }

.actions { display: flex; flex-direction: column; gap: 20rpx; }
.btn-primary { padding: 28rpx; background: #2563eb; border-radius: 16rpx; text-align: center; }
.btn-primary text { color: #fff; font-size: 30rpx; font-weight: 600; }
.btn-secondary { padding: 28rpx; background: #fff; border-radius: 16rpx; text-align: center; border: 2rpx solid #e5e7eb; }
.btn-secondary text { color: #666; font-size: 30rpx; }
