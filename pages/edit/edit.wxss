/**edit.wxss**/

.edit-container {
  padding: 32rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* AI ä¸€é”®ç”ŸæˆåŒºåŸŸ */
.ai-section {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.ai-section .section-title {
  color: #fff;
}

.ai-tip {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 16rpx;
}

.ai-input {
  width: 100%;
  height: 200rpx;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 28rpx;
  line-height: 1.5;
  box-sizing: border-box;
  margin-bottom: 16rpx;
}

.ai-generate-btn {
  width: 100%;
  height: 80rpx;
  background-color: #fff;
  color: #667eea;
  border: none;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.form-section {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111;
  margin-bottom: 24rpx;
  display: block;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.ai-btn-small {
  font-size: 22rpx;
  color: #4b5563;
  background-color: #f3f4f6;
  border: none;
  border-radius: 24rpx;
  padding: 8rpx 16rpx;
}

.section-header .section-title {
  margin-bottom: 0;
}

/* æ¨¡æ¿é€‰æ‹© */
.template-list {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.template-item {
  padding: 16rpx 32rpx;
  background-color: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  text-align: center;
}

.template-item.active {
  background-color: #2563eb;
  border-color: #2563eb;
}

.template-item .template-name {
  font-size: 26rpx;
  color: #6b7280;
}

.template-item.active .template-name {
  color: #fff;
}

/* AI æŒ‰é’® */
.ai-buttons {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}

.ai-btn {
  font-size: 24rpx;
  color: #4b5563;
  background-color: #f3f4f6;
  border: none;
  border-radius: 24rpx;
  padding: 12rpx 20rpx;
}

/* AI æŽ¨èæ ‡ç­¾ */
.ai-suggested-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.ai-suggested-tags .tag {
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  background-color: #fef3c7;
  color: #92400e;
  border-radius: 9999rpx;
  border: 1rpx solid #fcd34d;
}

/* è‡ªå®šä¹‰å¡ç‰‡ */
.tip-text {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 16rpx;
}

.custom-card-item {
  margin-bottom: 24rpx;
  padding: 24rpx;
  background-color: #f9fafb;
  border-radius: 16rpx;
  border: 1rpx solid #f3f4f6;
}

.custom-card-form .form-item:last-child {
  margin-bottom: 0;
}

.add-btn {
  font-size: 24rpx;
  color: #4b5563;
  background-color: #f3f4f6;
  border: none;
  border-radius: 24rpx;
  padding: 12rpx 24rpx;
  flex-shrink: 0;
}

/* Banner & Avatar */
.banner-upload, .avatar-upload {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.banner-preview {
  width: 100%;
  height: 200rpx;
  border-radius: 16rpx;
}

.avatar-preview {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
}

.upload-btn {
  font-size: 24rpx;
  color: #4b5563;
  background-color: #f3f4f6;
  border: none;
  border-radius: 24rpx;
  padding: 12rpx 24rpx;
}

/* Form Items */
.form-item {
  margin-bottom: 24rpx;
}

.label {
  font-size: 26rpx;
  color: #6b7280;
  display: block;
  margin-bottom: 8rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.input-with-btn {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.input-with-btn .input {
  flex: 1;
}

.textarea {
  width: 100%;
  height: 160rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

/* Project Item */
.project-item {
  margin-bottom: 24rpx;
  padding: 24rpx;
  background-color: #f9fafb;
  border-radius: 16rpx;
  border: 1rpx solid #f3f4f6;
}

.project-form .form-item:last-child {
  margin-bottom: 0;
}

.remove-btn {
  font-size: 24rpx;
  color: #ef4444;
  background-color: #fef2f2;
  border: none;
  border-radius: 8rpx;
  padding: 12rpx 24rpx;
  margin-top: 16rpx;
}

/* Action */
.action-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
  z-index: 20;
}

.save-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  padding: 0;
  background-color: #111;
  color: #fff;
  border: none;
  border-radius: 9999rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.save-btn::after {
  border: none;
}
