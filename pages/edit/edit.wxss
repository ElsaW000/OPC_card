/**edit.wxss - 优化版 + 响应式适配 **/

/* 全局重置 */
page {
  background-color: #f8fafc;
  --safe-top: env(safe-area-inset-top);
  --safe-bottom: env(safe-area-inset-bottom);
}

.edit-container {
  min-height: 100vh;
  min-height: calc(100vh + var(--safe-top));
  background-color: #f8fafc;
}

/* Header */
.edit-header {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(24rpx + var(--safe-top)) 24rpx 20rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 2rpx solid #f1f5f9;
}

.header-left {
  width: 80rpx;
}

.back-icon {
  font-size: 36rpx;
  color: #64748b;
}

.header-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #111;
  flex: 1;
  text-align: center;
}

.header-right {
  width: 100rpx;
  text-align: right;
}

.save-btn {
  font-size: 26rpx;
  font-weight: 700;
  color: #2563eb;
  background: #eff6ff;
  padding: 10rpx 20rpx;
  border-radius: 9999rpx;
  display: inline-block;
}

/* Scroll */
.edit-scroll {
  padding: 20rpx;
  padding-bottom: calc(140rpx + var(--safe-bottom));
}

/* Form Section */
.form-section {
  background: #fff;
  border-radius: 28rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.02);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-label {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.label-dot {
  width: 6rpx;
  height: 28rpx;
  background: linear-gradient(180deg, #2563eb 0%, #4f46e5 100%);
  border-radius: 3rpx;
}

.label-dot.blue { background: linear-gradient(180deg, #2563eb 0%, #4f46e5 100%); }
.label-dot.purple { background: linear-gradient(180deg, #8b5cf6 0%, #a855f7 100%); }
.label-dot.pink { background: linear-gradient(180deg, #ec4899 0%, #f472b6 100%); }
.label-dot.gold { background: linear-gradient(180deg, #f59e0b 0%, #fbbf24 100%); }
.label-dot.green { background: linear-gradient(180deg, #10b981 0%, #34d399 100%); }
.label-dot.red { background: linear-gradient(180deg, #ef4444 0%, #f87171 100%); }

.section-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #111;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.section-title.danger {
  color: #ef4444;
}

/* AI Section */
.ai-section {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.ai-section .section-title {
  color: #fff;
}

.ai-tip {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 12rpx;
}

.ai-input {
  width: 100%;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 18rpx;
  padding: 18rpx;
  font-size: 26rpx;
  line-height: 1.5;
  box-sizing: border-box;
  margin-bottom: 12rpx;
  border: none;
}

.ai-generate-btn {
  width: 100%;
  height: 80rpx;
  background: #fff;
  color: #667eea;
  border: none;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.ai-btn-icon {
  font-size: 28rpx;
}

/* Type Selector */
.type-selector {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
  overflow-x: auto;
  padding-bottom: 6rpx;
}

.type-option {
  flex: 1;
  min-width: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 18rpx 14rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 18rpx;
}

.type-option.active {
  background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
  border-color: #2563eb;
}

.type-icon {
  font-size: 32rpx;
}

.type-name {
  font-size: 20rpx;
  font-weight: 700;
  color: #64748b;
}

.type-option.active .type-name {
  color: #2563eb;
}

/* Avatar Section */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 28rpx;
}

.avatar-upload {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.avatar-preview-wrapper {
  position: relative;
  width: 168rpx;
  height: 168rpx;
}

.avatar-preview {
  width: 100%;
  height: 100%;
  border-radius: 36rpx;
  border: 6rpx solid #fff;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.08);
}

.avatar-edit-btn {
  position: absolute;
  bottom: -6rpx;
  right: -6rpx;
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #2563eb 0%, #4f46e5 100%);
  border-radius: 18rpx;
  border: 4rpx solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.avatar-tip {
  font-size: 20rpx;
  color: #94a3b8;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

/* Banner Upload */
.banner-upload {
  position: relative;
  width: 100%;
  height: 200rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.banner-preview {
  width: 100%;
  height: 100%;
}

.upload-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.banner-upload:active .upload-mask {
  opacity: 1;
}

.upload-icon {
  font-size: 40rpx;
}

.upload-text {
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
}

/* Form Items */
.form-item {
  margin-bottom: 20rpx;
}

.label {
  font-size: 22rpx;
  color: #64748b;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.ai-opt-btn {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 6rpx 14rpx;
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  border-radius: 10rpx;
  font-size: 18rpx;
  font-weight: 700;
  color: #d97706;
}

.ai-opt-icon {
  font-size: 18rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 18rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.input:focus {
  background: #fff;
  border-color: #2563eb;
  box-shadow: 0 0 0 4rpx rgba(37, 99, 235, 0.1);
}

.input-row {
  display: flex;
  gap: 12rpx;
}

.input.half {
  flex: 1;
}

.input-with-icon {
  position: relative;
  display: flex;
  align-items: center;
}

.input-icon {
  position: absolute;
  left: 20rpx;
  font-size: 28rpx;
  z-index: 1;
}

.input-with-icon .input {
  padding-left: 64rpx;
}

.textarea {
  width: 100%;
  height: 160rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 18rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  line-height: 1.5;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.textarea:focus {
  background: #fff;
  border-color: #2563eb;
  box-shadow: 0 0 0 4rpx rgba(37, 99, 235, 0.1);
}

/* Add Button */
.add-btn {
  font-size: 22rpx;
  font-weight: 700;
  color: #2563eb;
  background: #eff6ff;
  padding: 8rpx 18rpx;
  border-radius: 10rpx;
}

/* Project List Edit */
.project-list-edit {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.project-item-edit {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 18rpx;
  background: #f8fafc;
  border-radius: 18rpx;
  border: 2rpx solid #f1f5f9;
}

.project-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}

.project-icon.indigo {
  background: linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%);
}

.project-icon.rose {
  background: linear-gradient(135deg, #ffe4e6 0%, #fecdd3 100%);
}

.project-content {
  flex: 1;
  min-width: 0;
}

.project-title-edit {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #111;
}

.project-value-edit {
  display: block;
  font-size: 20rpx;
  color: #94a3b8;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.project-actions {
  display: flex;
  gap: 10rpx;
}

.delete-btn {
  font-size: 24rpx;
  padding: 6rpx;
}

/* Video List Edit */
.video-list-edit {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.video-item-edit {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 18rpx;
  background: #f8fafc;
  border-radius: 18rpx;
  border: 2rpx solid #f1f5f9;
}

.video-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}

.video-icon.orange {
  background: linear-gradient(135deg, #ffedd5 0%, #fed7aa 100%);
}

.video-content {
  flex: 1;
  min-width: 0;
}

.video-title-edit {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #111;
}

.video-value-edit {
  display: block;
  font-size: 20rpx;
  color: #94a3b8;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.video-actions {
  display: flex;
  gap: 10rpx;
}

/* Tags */
.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 18rpx;
  background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
  color: #2563eb;
  border-radius: 14rpx;
  font-size: 22rpx;
  font-weight: 600;
  border: 1rpx solid #bfdbfe;
}

.tag-remove {
  font-size: 24rpx;
  color: #93c5fd;
}

.add-tag-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 18rpx;
  border: 2rpx dashed #cbd5e1;
  border-radius: 14rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #94a3b8;
}

/* Danger Section */
.danger-section {
  border: 2rpx solid #fee2e2;
}

.danger-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  width: 100%;
  height: 88rpx;
  background: #fef2f2;
  color: #ef4444;
  border: 2rpx solid #fecaca;
  border-radius: 18rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.danger-icon {
  font-size: 28rpx;
}

/* Bottom Spacer */
.bottom-spacer {
  height: 100rpx;
}

/* Action Section */
.action-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 28rpx calc(16rpx + var(--safe-bottom));
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  box-shadow: 0 -2rpx 20rpx rgba(0, 0, 0, 0.04);
}

.save-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #111 0%, #333 100%);
  color: #fff;
  border: none;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.15);
}

/* 响应式调整 */
@media (max-width: 320px) {
  .edit-scroll {
    padding: 16rpx;
  }
  
  .form-section {
    padding: 24rpx;
    border-radius: 24rpx;
  }
  
  .type-option {
    min-width: 100rpx;
    padding: 14rpx 10rpx;
  }
  
  .avatar-preview-wrapper {
    width: 140rpx;
    height: 140rpx;
  }
  
  .banner-upload {
    height: 160rpx;
  }
}

@media (min-width: 400px) {
  .edit-scroll {
    padding: 28rpx;
  }
  
  .form-section {
    padding: 36rpx;
    border-radius: 36rpx;
    margin-bottom: 28rpx;
  }
  
  .type-option {
    min-width: 150rpx;
    padding: 24rpx 20rpx;
  }
  
  .avatar-preview-wrapper {
    width: 200rpx;
    height: 200rpx;
  }
  
  .banner-upload {
    height: 280rpx;
  }
}
