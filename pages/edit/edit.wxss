/**edit.wxss - 优化版 **/

.edit-container {
  min-height: 100vh;
  background-color: #f8fafc;
}

/* Header */
.edit-header {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 24rpx 24rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20px);
  border-bottom: 2rpx solid #f1f5f9;
}

.header-left {
  width: 80rpx;
}

.back-icon {
  font-size: 40rpx;
  color: #64748b;
}

.header-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #111;
}

.header-right {
  width: 120rpx;
  text-align: right;
}

.save-btn {
  font-size: 28rpx;
  font-weight: 700;
  color: #2563eb;
  background: #eff6ff;
  padding: 12rpx 24rpx;
  border-radius: 9999rpx;
  display: inline-block;
}

/* Scroll */
.edit-scroll {
  padding: 24rpx;
  padding-bottom: 160rpx;
}

/* Form Section */
.form-section {
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.02);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.label-dot {
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, #2563eb 0%, #4f46e5 100%);
  border-radius: 4rpx;
}

.label-dot.blue { background: linear-gradient(180deg, #2563eb 0%, #4f46e5 100%); }
.label-dot.purple { background: linear-gradient(180deg, #8b5cf6 0%, #a855f7 100%); }
.label-dot.pink { background: linear-gradient(180deg, #ec4899 0%, #f472b6 100%); }
.label-dot.gold { background: linear-gradient(180deg, #f59e0b 0%, #fbbf24 100%); }
.label-dot.green { background: linear-gradient(180deg, #10b981 0%, #34d399 100%); }
.label-dot.red { background: linear-gradient(180deg, #ef4444 0%, #f87171 100%); }

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #111;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.section-title.danger {
  color: #ef4444;
}

/* AI Section */
.ai-section {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.ai-section .section-title {
  color: #fff;
}

.ai-tip {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 16rpx;
}

.ai-input {
  width: 100%;
  height: 180rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 20rpx;
  font-size: 28rpx;
  line-height: 1.5;
  box-sizing: border-box;
  margin-bottom: 16rpx;
  border: none;
}

.ai-generate-btn {
  width: 100%;
  height: 88rpx;
  background: #fff;
  color: #667eea;
  border: none;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.ai-btn-icon {
  font-size: 32rpx;
}

/* Type Selector */
.type-selector {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  overflow-x: auto;
  padding-bottom: 8rpx;
}

.type-option {
  flex: 1;
  min-width: 140rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 16rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 20rpx;
}

.type-option.active {
  background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
  border-color: #2563eb;
}

.type-icon {
  font-size: 36rpx;
}

.type-name {
  font-size: 22rpx;
  font-weight: 700;
  color: #64748b;
}

.type-option.active .type-name {
  color: #2563eb;
}

/* Avatar Section */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 32rpx;
}

.avatar-upload {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.avatar-preview-wrapper {
  position: relative;
  width: 192rpx;
  height: 192rpx;
}

.avatar-preview {
  width: 100%;
  height: 100%;
  border-radius: 40rpx;
  border: 6rpx solid #fff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.avatar-edit-btn {
  position: absolute;
  bottom: -8rpx;
  right: -8rpx;
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #2563eb 0%, #4f46e5 100%);
  border-radius: 20rpx;
  border: 4rpx solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.avatar-tip {
  font-size: 22rpx;
  color: #94a3b8;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

/* Banner Upload */
.banner-upload {
  position: relative;
  width: 100%;
  height: 240rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.banner-preview {
  width: 100%;
  height: 100%;
}

.upload-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.banner-upload:active .upload-mask {
  opacity: 1;
}

.upload-icon {
  font-size: 48rpx;
}

.upload-text {
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
}

/* Form Items */
.form-item {
  margin-bottom: 24rpx;
}

.label {
  font-size: 24rpx;
  color: #64748b;
  font-weight: 600;
  display: block;
  margin-bottom: 10rpx;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.ai-opt-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: #d97706;
}

.ai-opt-icon {
  font-size: 20rpx;
}

.input {
  width: 100%;
  height: 96rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 20rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.input:focus {
  background: #fff;
  border-color: #2563eb;
  box-shadow: 0 0 0 4rpx rgba(37, 99, 235, 0.1);
}

.input-row {
  display: flex;
  gap: 16rpx;
}

.input.half {
  flex: 1;
}

.input-with-icon {
  position: relative;
  display: flex;
  align-items: center;
}

.input-icon {
  position: absolute;
  left: 24rpx;
  font-size: 32rpx;
  z-index: 1;
}

.input-with-icon .input {
  padding-left: 72rpx;
}

.textarea {
  width: 100%;
  height: 180rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  line-height: 1.5;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.textarea:focus {
  background: #fff;
  border-color: #2563eb;
  box-shadow: 0 0 0 4rpx rgba(37, 99, 235, 0.1);
}

/* Add Button */
.add-btn {
  font-size: 24rpx;
  font-weight: 700;
  color: #2563eb;
  background: #eff6ff;
  padding: 10rpx 20rpx;
  border-radius: 12rpx;
}

/* Project List Edit */
.project-list-edit {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.project-item-edit {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  background: #f8fafc;
  border-radius: 20rpx;
  border: 2rpx solid #f1f5f9;
}

.project-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.project-icon.indigo {
  background: linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%);
}

.project-icon.rose {
  background: linear-gradient(135deg, #ffe4e6 0%, #fecdd3 100%);
}

.project-content {
  flex: 1;
  min-width: 0;
}

.project-title-edit {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #111;
}

.project-value-edit {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.project-actions {
  display: flex;
  gap: 12rpx;
}

.delete-btn {
  font-size: 28rpx;
  padding: 8rpx;
}

/* Tags */
.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
  color: #2563eb;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 600;
  border: 1rpx solid #bfdbfe;
}

.tag-remove {
  font-size: 28rpx;
  color: #93c5fd;
}

.add-tag-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  border: 2rpx dashed #cbd5e1;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #94a3b8;
}

/* Danger Section */
.danger-section {
  border: 2rpx solid #fee2e2;
}

.danger-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 100%;
  height: 96rpx;
  background: #fef2f2;
  color: #ef4444;
  border: 2rpx solid #fecaca;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.danger-icon {
  font-size: 32rpx;
}

/* Bottom Spacer */
.bottom-spacer {
  height: 120rpx;
}

/* Action Section */
.action-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx 40rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20px);
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.save-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #111 0%, #333 100%);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
}
