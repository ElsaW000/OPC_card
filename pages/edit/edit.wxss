/**edit.wxss**/

.edit-container {
  padding: 32rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.form-section {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111;
  margin-bottom: 24rpx;
  display: block;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-header .section-title {
  margin-bottom: 0;
}

/* 模板选择 */
.template-list {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.template-item {
  padding: 16rpx 32rpx;
  background-color: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  text-align: center;
}

.template-item.active {
  background-color: #2563eb;
  border-color: #2563eb;
}

.template-item .template-name {
  font-size: 26rpx;
  color: #6b7280;
}

.template-item.active .template-name {
  color: #fff;
}

/* 自定义卡片 */
.tip-text {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 16rpx;
}

.custom-card-item {
  margin-bottom: 24rpx;
  padding: 24rpx;
  background-color: #f9fafb;
  border-radius: 16rpx;
  border: 1rpx solid #f3f4f6;
}

.custom-card-form .form-item:last-child {
  margin-bottom: 0;
}

.add-btn {
  font-size: 24rpx;
  color: #2563eb;
  background-color: #eff6ff;
  border: none;
  border-radius: 9999rpx;
  padding: 12rpx 24rpx;
}

/* Banner & Avatar */
.banner-upload, .avatar-upload {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.banner-preview {
  width: 100%;
  height: 200rpx;
  border-radius: 16rpx;
}

.avatar-preview {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
}

.upload-btn {
  font-size: 24rpx;
  color: #2563eb;
  background-color: #eff6ff;
  border: none;
  border-radius: 8rpx;
  padding: 12rpx 24rpx;
}

/* Form Items */
.form-item {
  margin-bottom: 24rpx;
}

.label {
  font-size: 26rpx;
  color: #6b7280;
  display: block;
  margin-bottom: 8rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.textarea {
  width: 100%;
  height: 160rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

/* Project Item */
.project-item {
  margin-bottom: 24rpx;
  padding: 24rpx;
  background-color: #f9fafb;
  border-radius: 16rpx;
  border: 1rpx solid #f3f4f6;
}

.project-form .form-item:last-child {
  margin-bottom: 0;
}

.remove-btn {
  font-size: 24rpx;
  color: #ef4444;
  background-color: #fef2f2;
  border: none;
  border-radius: 8rpx;
  padding: 12rpx 24rpx;
  margin-top: 16rpx;
}

/* Action */
.action-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  background-color: #fff;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.save-btn {
  width: 100%;
  height: 96rpx;
  background-color: #111;
  color: #fff;
  border: none;
  border-radius: 9999rpx;
  font-size: 32rpx;
  font-weight: 500;
}
