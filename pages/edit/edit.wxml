<!--edit.wxml - 按照 Figma 设计重构 -->
<view class="edit-container">
  <!-- AI 一键生成 -->
  <view class="form-section ai-section">
    <text class="section-title">🤖 AI 一键生成名片</text>
    <text class="ai-tip">输入一段关于你的介绍，AI 自动填入各个字段</text>
    <textarea 
      class="ai-input" 
      value="{{aiInput}}" 
      data-field="aiInput" 
      bindinput="onAIInputChange" 
      placeholder="例如：我是一名独立开发者，8年工作经验，擅长 Python 和 AI，现居深圳，做过多个开源项目..."
    />
    <button class="ai-generate-btn" bindtap="generateFromAI">AI 自动填充</button>
  </view>

  <!-- 模板选择 -->
  <view class="form-section">
    <text class="section-title">选择模板</text>
    <view class="template-list">
      <view 
        class="template-item {{currentTemplate === 'universal' ? 'active' : ''}}" 
        data-id="universal" 
        bindtap="selectTemplate"
      >
        <text class="template-name">通用</text>
      </view>
      <view 
        class="template-item {{currentTemplate === 'developer' ? 'active' : ''}}" 
        data-id="developer" 
        bindtap="selectTemplate"
      >
        <text class="template-name">程序员</text>
      </view>
      <view 
        class="template-item {{currentTemplate === 'designer' ? 'active' : ''}}" 
        data-id="designer" 
        bindtap="selectTemplate"
      >
        <text class="template-name">设计师</text>
      </view>
      <view 
        class="template-item {{currentTemplate === 'boss' ? 'active' : ''}}" 
        data-id="boss" 
        bindtap="selectTemplate"
      >
        <text class="template-name">老板</text>
      </view>
    </view>
  </view>

  <!-- Banner 设置 -->
  <view class="form-section">
    <text class="section-title">Banner 图片</text>
    <view class="banner-upload">
      <image class="banner-preview" src="{{bannerUrl}}" mode="aspectFill" />
      <button class="upload-btn" bindtap="chooseBanner">更换 Banner</button>
    </view>
  </view>

  <!-- 头像设置 -->
  <view class="form-section">
    <text class="section-title">头像</text>
    <view class="avatar-upload">
      <image class="avatar-preview" src="{{avatarUrl}}" mode="aspectFill" />
      <button class="upload-btn" bindtap="chooseAvatar">更换头像</button>
    </view>
  </view>

  <!-- 基本信息（通用字段） -->
  <view class="form-section">
    <text class="section-title">基本信息</text>
    
    <view class="form-item">
      <text class="label required">姓名 *</text>
      <input class="input" value="{{name}}" data-field="name" bindinput="onInputChange" placeholder="请输入姓名" />
    </view>
    
    <view class="form-item">
      <text class="label">英文名</text>
      <input class="input" value="{{nameEn}}" data-field="nameEn" bindinput="onInputChange" placeholder="如：John Chen" />
    </view>
    
    <view class="form-item">
      <text class="label required">职位 *</text>
      <input class="input" value="{{role}}" data-field="role" bindinput="onInputChange" placeholder="请输入职位" />
    </view>
    
    <view class="form-item">
      <text class="label required">国家 *</text>
      <input class="input" value="{{locationCountry}}" data-field="locationCountry" bindinput="onInputChange" placeholder="如：中国" />
    </view>
    
    <view class="form-item">
      <text class="label required">省市 *</text>
      <input class="input" value="{{locationCity}}" data-field="locationCity" bindinput="onInputChange" placeholder="如：深圳" />
    </view>
    
    <view class="form-item">
      <text class="label">简介</text>
      <textarea class="textarea" value="{{bio}}" data-field="bio" bindinput="onInputChange" placeholder="请输入个人简介，或使用顶部 AI 一键生成" />
    </view>
  </view>

  <!-- 程序员专属字段 -->
  <view class="form-section" wx:if="{{currentTemplate === 'developer'}}">
    <text class="section-title">程序员信息</text>
    
    <view class="form-item">
      <text class="label">工作年限</text>
      <input class="input" value="{{years}}" data-field="years" bindinput="onInputChange" placeholder="如：8+" />
    </view>
    
    <view class="form-item">
      <text class="label">技术栈</text>
      <input class="input" value="{{techStack}}" data-field="techStack" bindinput="onInputChange" placeholder="如：React, Python, AI" />
    </view>
  </view>

  <!-- 设计师专属字段 -->
  <view class="form-section" wx:if="{{currentTemplate === 'designer'}}">
    <text class="section-title">设计师信息</text>
    
    <view class="form-item">
      <text class="label">作品集链接</text>
      <input class="input" value="{{portfolio}}" data-field="portfolio" bindinput="onInputChange" placeholder="请输入作品集链接" />
    </view>
    
    <view class="form-item">
      <text class="label">擅长风格</text>
      <input class="input" value="{{styles}}" data-field="styles" bindinput="onInputChange" placeholder="如：UI设计、品牌设计" />
    </view>
    
    <view class="form-item">
      <text class="label">从业年限</text>
      <input class="input" value="{{experience}}" data-field="experience" bindinput="onInputChange" placeholder="如：5年" />
    </view>
  </view>

  <!-- 老板专属字段 -->
  <view class="form-section" wx:if="{{currentTemplate === 'boss'}}">
    <text class="section-title">企业信息</text>
    
    <view class="form-item">
      <text class="label">公司名称</text>
      <input class="input" value="{{company}}" data-field="company" bindinput="onInputChange" placeholder="请输入公司名称" />
    </view>
    
    <view class="form-item">
      <text class="label">业务范围</text>
      <input class="input" value="{{business}}" data-field="business" bindinput="onInputChange" placeholder="请输入业务范围" />
    </view>
    
    <view class="form-item">
      <text class="label">合作方式</text>
      <input class="input" value="{{cooperation}}" data-field="cooperation" bindinput="onInputChange" placeholder="请输入合作方式" />
    </view>
    
    <view class="form-item">
      <text class="label">微信</text>
      <input class="input" value="{{wechat}}" data-field="wechat" bindinput="onInputChange" placeholder="请输入微信号" />
    </view>
  </view>

  <!-- 社交链接 -->
  <view class="form-section">
    <text class="section-title">社交链接</text>
    
    <view class="form-item">
      <text class="label">GitHub</text>
      <input class="input" value="{{githubUrl}}" data-field="githubUrl" bindinput="onInputChange" placeholder="https://github.com/username" />
    </view>
    
    <view class="form-item">
      <text class="label">Twitter</text>
      <input class="input" value="{{twitterUrl}}" data-field="twitterUrl" bindinput="onInputChange" placeholder="https://twitter.com/username" />
    </view>
    
    <!-- AI 读取 GitHub 自动生成项目 -->
    <view class="ai-github-section" wx:if="{{githubUrl}}">
      <button class="ai-btn" bindtap="fetchGitHubProjects">🤖 AI 一键读取我的 GitHub 项目</button>
    </view>
  </view>

  <!-- 数据统计 -->
  <view class="form-section">
    <text class="section-title">数据统计</text>
    
    <view class="form-item">
      <text class="label">上线产品</text>
      <input class="input" value="{{products}}" data-field="products" bindinput="onInputChange" placeholder="如：12" />
    </view>
    
    <view class="form-item">
      <text class="label">全球用户</text>
      <input class="input" value="{{users}}" data-field="users" bindinput="onInputChange" placeholder="如：25k" />
    </view>
  </view>

  <!-- 联系方式 -->
  <view class="form-section">
    <text class="section-title">联系方式</text>
    
    <view class="form-item">
      <text class="label">电话</text>
      <input class="input" value="{{phone}}" data-field="phone" bindinput="onInputChange" placeholder="请输入电话" type="number" />
    </view>
    
    <view class="form-item">
      <text class="label">邮箱</text>
      <input class="input" value="{{email}}" data-field="email" bindinput="onInputChange" placeholder="请输入邮箱" />
    </view>
  </view>
  
  <!-- 自定义卡片 -->
  <view class="form-section">
    <view class="section-header">
      <text class="section-title">自定义卡片</text>
      <button class="add-btn" bindtap="addCustomCard">添加卡片</button>
    </view>
    <view class="tip-text">如：MBTI、音乐创作、兴趣爱好等</view>
    
    <view class="custom-card-item" wx:for="{{customCards}}" wx:key="id">
      <view class="custom-card-form">
        <view class="form-item">
          <text class="label">标题</text>
          <input class="input" value="{{item.title}}" data-index="{{index}}" data-field="title" bindinput="onCustomCardChange" placeholder="如：MBTI" />
        </view>
        <view class="form-item">
          <text class="label">内容</text>
          <input class="input" value="{{item.content}}" data-index="{{index}}" data-field="content" bindinput="onCustomCardChange" placeholder="如：INTJ" />
        </view>
      </view>
      <button class="remove-btn" data-index="{{index}}" bindtap="removeCustomCard">删除</button>
    </view>
  </view>
  
  <!-- 底部联系模块 -->
  <view class="form-section">
    <text class="section-title">底部联系模块</text>
    
    <view class="form-item">
      <text class="label">标题</text>
      <input class="input" value="{{footerTitle}}" data-field="footerTitle" bindinput="onInputChange" placeholder="如：联系我" />
    </view>
    
    <view class="form-item">
      <text class="label">描述</text>
      <textarea class="textarea" value="{{footerDesc}}" data-field="footerDesc" bindinput="onInputChange" placeholder="如：有合作意向，欢迎通过以下方式联系" />
    </view>
  </view>
  
  <!-- 视频/短视频 -->
  <view class="form-section">
    <view class="section-header">
      <text class="section-title">产品演示 & 短视频</text>
      <button class="add-btn" bindtap="addVideo">添加视频</button>
    </view>
    
    <view class="project-item" wx:for="{{videos}}" wx:key="id">
      <view class="project-form">
        <view class="form-item">
          <text class="label">标题</text>
          <input class="input" value="{{item.title}}" data-index="{{index}}" data-field="title" bindinput="onVideoChange" placeholder="视频标题" />
        </view>
        <view class="form-item">
          <text class="label">封面图链接</text>
          <input class="input" value="{{item.thumbnail}}" data-index="{{index}}" data-field="thumbnail" bindinput="onVideoChange" placeholder="封面图 URL" />
        </view>
        <view class="form-item">
          <text class="label">视频链接</text>
          <input class="input" value="{{item.link}}" data-index="{{index}}" data-field="link" bindinput="onVideoChange" placeholder="视频/播放页链接" />
        </view>
        <view class="form-item">
          <text class="label">播放量</text>
          <input class="input" value="{{item.views}}" data-index="{{index}}" data-field="views" bindinput="onVideoChange" placeholder="如：12k" />
        </view>
        <view class="form-item">
          <text class="label">时长</text>
          <input class="input" value="{{item.duration}}" data-index="{{index}}" data-field="duration" bindinput="onVideoChange" placeholder="如：01:45" />
        </view>
      </view>
      <button class="remove-btn" data-index="{{index}}" bindtap="removeVideo">删除</button>
    </view>
  </view>
  
  <!-- 产品/项目 -->
  <view class="form-section">
    <view class="section-header">
      <text class="section-title">产品/项目</text>
      <button class="add-btn" bindtap="addProject">添加产品</button>
    </view>
    
    <view class="project-item" wx:for="{{projects}}" wx:key="id">
      <view class="project-form">
        <view class="form-item">
          <text class="label">标题</text>
          <input class="input" value="{{item.title}}" data-index="{{index}}" data-field="title" bindinput="onProjectChange" placeholder="产品名称" />
        </view>
        <view class="form-item">
          <text class="label">描述</text>
          <textarea class="textarea" value="{{item.description}}" data-index="{{index}}" data-field="description" bindinput="onProjectChange" placeholder="产品描述" />
        </view>
        <view class="form-item">
          <text class="label">链接</text>
          <input class="input" value="{{item.link}}" data-index="{{index}}" data-field="link" bindinput="onProjectChange" placeholder="在线地址" />
        </view>
        <view class="form-item">
          <text class="label">GitHub</text>
          <input class="input" value="{{item.github}}" data-index="{{index}}" data-field="github" bindinput="onProjectChange" placeholder="GitHub 链接（可选）" />
        </view>
        <view class="form-item">
          <text class="label">标签</text>
          <input class="input" value="{{item.tags}}" data-index="{{index}}" data-field="tags" bindinput="onProjectChange" placeholder="用逗号分隔，如：AI, React, SaaS" />
        </view>
      </view>
      <button class="remove-btn" data-index="{{index}}" bindtap="removeProject">删除</button>
    </view>
  </view>
  
  <!-- 保存按钮 -->
  <view class="action-section">
    <button class="save-btn" bindtap="saveCard">保存名片</button>
  </view>
</view>