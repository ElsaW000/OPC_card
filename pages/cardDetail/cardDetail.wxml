<view class="detail-page" wx:if="{{card}}">
  <view class="hero">
    <image class="hero-banner" src="{{card.bannerUrl}}" mode="aspectFill" />
    <view class="hero-overlay"></view>
  </view>

  <view class="profile-shell">
    <view class="profile-top">
      <view class="avatar-wrap">
        <image class="avatar" src="{{card.avatarUrl}}" mode="aspectFill" />
      </view>
      <view class="hero-actions" wx:if="{{!isPublicView}}">
        <view class="circle-action" bindtap="setDefaultCard">
          <image class="circle-action-icon" src="{{card.isDefault ? '/images/icons/default-selected.png' : '/images/icons/default-unselected.png'}}" mode="aspectFit" />
        </view>
        <view class="circle-action share-action" bindtap="previewQrcode">
          <image class="circle-action-icon" src="/images/icons/qr.png" mode="aspectFit" />
        </view>
        <view class="primary-action" bindtap="editCard">{{labels.editCard}}</view>
      </view>
    </view>

    <view class="profile-main">
      <view class="name-row">
        <text class="profile-name">{{card.name}}</text>
        <text class="profile-name-en" wx:if="{{card.nameEn}}">({{card.nameEn}})</text>
      </view>
      <view class="meta-row">
        <text class="profile-role">{{card.role}}</text>
        <text class="profile-location" wx:if="{{card.location}}">{{card.location}}</text>
      </view>
      <text class="profile-company" wx:if="{{card.company}}">{{card.company}}</text>
      <text class="profile-bio">{{card.bio}}</text>
    </view>

    <view class="stats-grid">
      <view class="stat-pill" wx:for="{{card.stats}}" wx:key="key">
        <text class="stat-value">{{item.value}}</text>
        <text class="stat-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="section tags-section" wx:if="{{card.tags && card.tags.length}}">
    <view class="tag-chip" wx:for="{{card.tags}}" wx:key="index">{{item}}</view>
  </view>

  <view class="section custom-section" wx:if="{{card.customCards && card.customCards.length}}">
    <view class="custom-list">
      <view class="custom-card" wx:for="{{card.customCards}}" wx:key="id">
        <text class="custom-title">{{item.title}}</text>
        <text class="custom-content">{{item.content}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">{{labels.projectTitle}}</text>
      <text class="section-more">{{labels.projectMore}}</text>
    </view>
    <view class="portfolio-list">
      <view class="portfolio-card" wx:for="{{card.projects}}" wx:key="id">
        <view class="portfolio-hero">
          <image class="portfolio-cover" src="{{item.thumbnail}}" mode="aspectFill" />
          <view class="portfolio-fab">
            <image class="portfolio-fab-icon" src="/images/icons/qr.png" mode="aspectFit" />
          </view>
        </view>
        <view class="portfolio-body">
          <view class="portfolio-tags" wx:if="{{item.tags && item.tags.length}}">
            <text class="portfolio-tag" wx:for="{{item.tags}}" wx:key="index">{{item}}</text>
          </view>
          <text class="portfolio-title">{{item.title}}</text>
          <text class="portfolio-desc">{{item.description}}</text>
          <view class="portfolio-links">
            <text class="portfolio-link" wx:if="{{item.link}}">{{item.link}}</text>
            <text class="portfolio-link secondary" wx:if="{{item.github}}">{{item.github}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="section video-section">
    <view class="section-head">
      <text class="section-title">{{labels.videoTitle}}</text>
      <text class="section-more">{{labels.videoMore}}</text>
    </view>
    <scroll-view class="video-scroll" scroll-x="true" show-scrollbar="false">
      <view class="video-row">
        <view class="video-card" wx:for="{{card.videos}}" wx:key="id">
          <image class="video-cover" src="{{item.thumbnail}}" mode="aspectFill" />
          <view class="video-overlay"></view>
          <view class="video-duration">
            <view class="video-dot"></view>
            <text class="video-duration-text">{{item.duration}}</text>
          </view>
          <view class="video-info">
            <text class="video-title">{{item.title}}</text>
            <view class="video-meta">
              <text class="video-meta-text">{{item.views}}</text>
              <text class="video-meta-text">QR</text>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="section contact-block" wx:if="{{contactItems.length}}">
    <view class="section-head compact">
      <text class="section-title">{{card.footerTitle || labels.contactTitle}}</text>
    </view>
    <text class="contact-desc">{{card.footerDesc || labels.contactDesc}}</text>
    <view class="contact-list">
      <view class="contact-card" wx:for="{{contactItems}}" wx:key="key">
        <view class="contact-left">
          <view class="contact-icon-wrap" wx:if="{{item.icon}}">
            <image class="contact-icon" src="{{item.icon}}" mode="aspectFit" />
          </view>
          <view class="contact-icon-wrap emoji" wx:else>{{item.emoji}}</view>
          <text class="contact-label">{{item.label}}</text>
        </view>
        <text class="contact-value">{{item.value}}</text>
      </view>
    </view>
  </view>

  <view class="floating-dock" wx:if="{{!isPublicView}}">
    <view class="dock-primary" bindtap="exchangeCard">
      <text class="dock-primary-label">{{labels.exchangeCard}}</text>
    </view>
  </view>
</view>