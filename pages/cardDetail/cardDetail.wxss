/* cardDetail.wxss */

page {
  --primary: #2563EB;
  --primary-light: rgba(37, 99, 235, 0.1);
  --deep: #121212;
  --text-main: #121212;
  --text-sub: #64748B;
  --text-light: #94A3B8;
  --bg: #F8F9FA;
  background-color: var(--bg);
}

.container { width: 100%; min-height: 100vh; box-sizing: border-box; }

/* Banner */
.banner { position: relative; width: 100%; height: 480rpx; }
.banner-img { width: 100%; height: 100%; object-fit: cover; }
.banner-mask { position: absolute; width: 100%; height: 100%; top: 0; left: 0; }
.banner-mask.tech { background: linear-gradient(135deg, rgba(59, 130, 246, 0.85) 0%, rgba(29, 78, 216, 0.9) 100%); }
.banner-mask.biz { background: linear-gradient(135deg, rgba(30, 41, 59, 0.9) 0%, rgba(15, 23, 42, 0.95) 100%); }
.banner-mask.social { background: linear-gradient(135deg, rgba(16, 185, 129, 0.85) 0%, rgba(5, 150, 105, 0.9) 100%); }

/* 顶部操作 */
.banner-top { position: absolute; top: 80rpx; left: 32rpx; right: 32rpx; display: flex; justify-content: space-between; z-index: 10; }
.back-btn { width: 64rpx; height: 64rpx; background: rgba(0,0,0,0.3); border-radius: 50%; display: flex; align-items: center; justify-content: center; }
.back-btn text { color: #fff; font-size: 32rpx; }
.qr-btn { width: 64rpx; height: 64rpx; background: rgba(255,255,255,0.25); border-radius: 16rpx; display: flex; align-items: center; justify-content: center; border: 1rpx solid rgba(255,255,255,0.3); }
.qr-icon { width: 36rpx; height: 36rpx; }

/* 名片主体 */
.card-main { position: relative; margin: -140rpx 32rpx 0; padding: 40rpx; background: #fff; border-radius: 32rpx; box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.1); display: flex; justify-content: space-between; align-items: flex-end; }
.card-info { flex: 1; }
.card-name { font-size: 52rpx; font-weight: 700; color: var(--deep); display: block; }
.card-role { font-size: 28rpx; color: var(--text-sub); margin-top: 8rpx; display: block; }
.card-company { font-size: 24rpx; color: var(--text-light); margin-top: 4rpx; display: block; }
.card-avatar { width: 160rpx; height: 160rpx; border-radius: 28rpx; overflow: hidden; border: 4rpx solid #fff; box-shadow: 0 12rpx 32rpx rgba(0,0,0,0.15); flex-shrink: 0; margin-left: 24rpx; }
.card-avatar image { width: 100%; height: 100%; }

/* 操作按钮 */
.action-buttons { display: flex; gap: 16rpx; padding: 24rpx 32rpx; }
.action-btn { flex: 1; display: flex; align-items: center; justify-content: center; gap: 10rpx; padding: 24rpx; background: #fff; border-radius: 16rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04); }
.action-icon { width: 36rpx; height: 36rpx; }
.action-text { font-size: 24rpx; font-weight: 500; color: var(--text-main); }

/* 标签 */
.tags-section { display: flex; gap: 12rpx; padding: 0 32rpx 24rpx; }
.tag { padding: 12rpx 24rpx; background: var(--primary-light); color: var(--primary); font-size: 24rpx; font-weight: 500; border-radius: 12rpx; }

/* 联系方式 */
.contact-section { padding: 0 32rpx 48rpx; }
.contact-item { display: flex; align-items: center; padding: 24rpx; background: #fff; border-radius: 16rpx; margin-bottom: 12rpx; }
.contact-icon { font-size: 32rpx; margin-right: 16rpx; }
.contact-text { width: 80rpx; font-size: 24rpx; color: var(--text-light); }
.contact-value { flex: 1; font-size: 28rpx; color: var(--text-main); font-weight: 500; text-align: right; }
