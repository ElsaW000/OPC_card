<!--index.wxml - 优化版 -->
<view class="container">
  <!-- Banner -->
  <view class="banner">
    <image class="banner-img" src="{{bannerUrl}}" mode="aspectFill" />
    <view class="banner-overlay"></view>
  </view>

  <!-- 个人信息区域 -->
  <view class="profile-section">
    <view class="profile-header">
      <view class="avatar-wrapper">
        <image class="avatar" src="{{avatarUrl}}" mode="aspectFill" />
      </view>
      <view class="social-buttons">
        <button class="social-btn github" bindtap="openLink" data-link="{{githubUrl}}">
          <text class="iconfont icon-github">GH</text>
        </button>
        <button class="social-btn twitter" bindtap="openLink" data-link="{{twitterUrl}}">
          <text class="iconfont icon-twitter">𝕏</text>
        </button>
        <button class="follow-btn" bindtap="saveContact">关注</button>
      </view>
    </view>

    <view class="profile-info">
      <view class="name-row">
        <text class="name">{{name}}</text>
        <text class="name-en" wx:if="{{nameEn}}">({{nameEn}})</text>
      </view>
      <view class="role-location">
        <text class="role">{{role}}</text>
        <text class="separator">|</text>
        <text class="location">{{locationCountry}}，{{locationCity}}</text>
      </view>
      
      <view class="quick-contact">
        <view class="contact-btn phone" bindtap="callPhone" wx:if="{{phone}}">
          <text class="contact-icon">📱</text>
          <text class="contact-text">{{phone}}</text>
        </view>
        <view class="contact-btn wechat" bindtap="copyWechat" wx:if="{{wechat}}">
          <text class="contact-icon">💬</text>
          <text class="contact-text">{{wechat}}</text>
        </view>
        <view class="contact-btn email" bindtap="copyEmail" data-text="{{email}}" wx:if="{{email}}">
          <text class="contact-icon">✉️</text>
          <text class="contact-text">{{email}}</text>
        </view>
      </view>
      
      <text class="bio">{{bio}}</text>
    </view>

    <!-- 快捷统计数据 -->
    <view class="stats-grid">
      <view class="stat-card">
        <text class="stat-value">{{years || '8+'}}</text>
        <text class="stat-label">开发年限</text>
      </view>
      <view class="stat-card">
        <text class="stat-value">{{products || '12'}}</text>
        <text class="stat-label">上线产品</text>
      </view>
      <view class="stat-card">
        <text class="stat-value">{{users || '25k'}}</text>
        <text class="stat-label">全球用户</text>
      </view>
    </view>
  </view>

  <!-- 产品作品集 -->
  <view class="portfolio-section">
    <view class="section-header">
      <text class="section-title">产品作品集</text>
      <text class="view-all">View All</text>
    </view>
    <view class="project-list">
      <view class="project-card" wx:for="{{projects}}" wx:key="id" bindtap="openLink" data-link="{{item.link}}">
        <image class="project-thumb" src="{{item.thumbnail}}" mode="aspectFill" />
        <view class="project-overlay"></view>
        <view class="project-info">
          <view class="project-tags">
            <text class="tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
          </view>
          <text class="project-title">{{item.title}}</text>
          <text class="project-desc">{{item.description}}</text>
          <view class="project-links">
            <text class="link-item" wx:if="{{item.link}}">🌐 在线地址</text>
            <text class="link-item" wx:if="{{item.github}}">🐙 GitHub</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 视频/短视频 -->
  <view class="video-section" wx:if="{{videos.length > 0}}">
    <view class="section-header">
      <text class="section-title">产品演示 & 短视频</text>
      <text class="view-all">Recent</text>
    </view>
    <scroll-view class="video-scroll" scroll-x="true">
      <view class="video-list">
        <view class="video-card" wx:for="{{videos}}" wx:key="id" bindtap="openLink" data-link="{{item.link}}">
          <image class="video-thumb" src="{{item.thumbnail}}" mode="aspectFill" />
          <view class="video-overlay"></view>
          <view class="play-btn">
            <text class="play-icon">▶</text>
          </view>
          <view class="video-duration-tag">{{item.duration}}</view>
          <view class="video-info">
            <text class="video-title">{{item.title}}</text>
            <view class="video-meta">
              <text class="video-views">👁 {{item.views}} views</text>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 底部联系模块 -->
  <view class="footer-section">
    <view class="footer-title">{{footerTitle || '联系我'}}</view>
    <text class="footer-desc" wx:if="{{footerDesc}}">{{footerDesc}}</text>
    <view class="footer-contact">
      <view class="contact-item-row" bindtap="copyWechat" wx:if="{{wechat}}">
        <text class="contact-row-icon">💬</text>
        <view class="contact-row-info">
          <text class="contact-row-label">微信 (WeChat)</text>
          <text class="contact-row-value">{{wechat}}</text>
        </view>
        <text class="copy-hint">复制</text>
      </view>
      <view class="contact-item-row" bindtap="copyEmail" data-text="{{email}}" wx:if="{{email}}">
        <text class="contact-row-icon">✉️</text>
        <view class="contact-row-info">
          <text class="contact-row-label">邮箱 (Email)</text>
          <text class="contact-row-value">{{email}}</text>
        </view>
        <text class="copy-hint">复制</text>
      </view>
    </view>
  </view>

  <!-- 底部操作 -->
  <view class="action-bar">
    <button class="action-btn primary" bindtap="editCard">编辑名片</button>
    <button class="action-btn secondary" bindtap="shareCard">分享名片</button>
  </view>

  <!-- 浮动操作按钮 -->
  <view class="fab-container">
    <view class="fab-main" bindtap="exchangeCard">
      <text class="fab-icon">🔄</text>
      <text class="fab-text">交换名片</text>
    </view>
    <view class="fab-small" bindtap="saveContact">
      <text class="fab-icon-small">👤</text>
    </view>
    <view class="fab-small" bindtap="showQRCode">
      <text class="fab-icon-small">📱</text>
    </view>
  </view>

  <!-- 分享按钮 -->
  <view class="share-btn" bindtap="shareCard">
    <text>📤</text>
  </view>
</view>
