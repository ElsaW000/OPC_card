/**index.wxss - 按照 Figma 设计重构**/

/* 容器 */
.container {
  min-height: 100vh;
  background-color: #fff;
}

/* Banner */
.banner {
  position: relative;
  width: 100%;
  height: 384rpx; /* 192px */
  overflow: hidden;
}

.banner-img {
  width: 100%;
  height: 100%;
}

.banner-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: linear-gradient(to bottom, transparent, rgba(0, 0, 0, 0.3));
}

/* 个人信息区域 */
.profile-section {
  position: relative;
  padding: 0 48rpx 48rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.profile-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-top: -96rpx;
  margin-bottom: 32rpx;
}

.avatar-wrapper {
  width: 192rpx;
  height: 192rpx;
  border-radius: 24rpx;
  overflow: hidden;
  border: 8rpx solid #fff;
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.1);
}

.avatar {
  width: 100%;
  height: 100%;
}

.social-buttons {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.social-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background-color: #eff6ff;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
}

.social-btn.github {
  color: #2563eb;
}

.social-btn.twitter {
  color: #2563eb;
}

.follow-btn {
  height: 72rpx;
  padding: 0 32rpx;
  background-color: #2563eb;
  color: #fff;
  border-radius: 9999rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 4rpx 8rpx rgba(37, 99, 235, 0.3);
}

/* 个人信息 */
.profile-info {
  margin-bottom: 48rpx;
}

.name {
  font-size: 48rpx;
  font-weight: 700;
  color: #111;
  display: block;
  margin-bottom: 8rpx;
}

.role-location {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 28rpx;
  color: #6b7280;
  margin-bottom: 24rpx;
}

.separator {
  color: #d1d5db;
}

.bio {
  font-size: 30rpx;
  color: #4b5563;
  line-height: 1.6;
}

/* 模板专属信息 */
.template-info {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  padding: 24rpx;
  background-color: #f9fafb;
  border-radius: 16rpx;
  margin-bottom: 32rpx;
}

.template-info .info-item {
  flex: 1;
  min-width: 200rpx;
}

.template-info .info-label {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
  margin-bottom: 4rpx;
}

.template-info .info-value {
  display: block;
  font-size: 28rpx;
  color: #111;
  font-weight: 500;
}

.template-info .info-value.link {
  color: #2563eb;
}

/* 快捷联系方式 */
.quick-contact {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin: 24rpx 0;
}

.contact-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background-color: #f3f4f6;
  border-radius: 9999rpx;
}

.contact-btn.phone .contact-text {
  color: #2563eb;
}

.contact-btn.wechat .contact-text {
  color: #07c160;
}

.contact-btn.email .contact-text {
  color: #4b5563;
}

.contact-icon {
  font-size: 24rpx;
}

.contact-text {
  font-size: 26rpx;
  color: #4b5563;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 自定义卡片 */
.custom-cards {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.custom-card {
  display: flex;
  flex-direction: column;
  padding: 20rpx 28rpx;
  background-color: #fef3c7;
  border-radius: 16rpx;
  border: 1rpx solid #fcd34d;
}

.custom-card-title {
  font-size: 22rpx;
  color: #92400e;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.custom-card-content {
  font-size: 28rpx;
  color: #111;
}

/* 数据卡片 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32rpx;
  margin-bottom: 32rpx;
}

.stat-card {
  background-color: #f9fafb;
  border-radius: 24rpx;
  padding: 24rpx;
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #111;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #6b7280;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

/* 产品作品集 */
.portfolio-section {
  padding: 48rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 48rpx;
}

.section-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #111;
}

.view-all {
  font-size: 28rpx;
  color: #9ca3af;
}

.project-list {
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

.project-card {
  background-color: #fff;
  border-radius: 32rpx;
  overflow: hidden;
  border: 1rpx solid #f3f4f6;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.project-thumb {
  width: 100%;
  height: 320rpx;
}

.project-info {
  padding: 40rpx;
}

.project-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.tag {
  padding: 8rpx 20rpx;
  font-size: 22rpx;
  font-weight: 600;
  background-color: #f9fafb;
  color: #6b7280;
  border-radius: 9999rpx;
  border: 1rpx solid #f3f4f6;
  text-transform: uppercase;
}

.project-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #111;
  margin-bottom: 16rpx;
}

.project-desc {
  display: block;
  font-size: 28rpx;
  color: #6b7280;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.project-links {
  display: flex;
  gap: 32rpx;
}

.link-item {
  font-size: 28rpx;
  font-weight: 500;
  color: #2563eb;
}

/* 联系方式 */
.contact-section {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rpx;
  background-color: #f3f4f6;
  margin: 0 48rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.contact-item {
  background-color: #fff;
  padding: 32rpx 16rpx;
  text-align: center;
}

.contact-label {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 8rpx;
}

.contact-value {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #111;
}

/* 底部操作 */
.action-bar {
  display: flex;
  gap: 24rpx;
  padding: 48rpx;
}

.action-btn {
  flex: 1;
  height: 96rpx;
  border-radius: 9999rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}

.action-btn.primary {
  background-color: #111;
  color: #fff;
}

.action-btn.secondary {
  background-color: #f3f4f6;
  color: #111;
}
