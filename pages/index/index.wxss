/**index.wxss - 优化版 + 响应式适配 **/

/* 全局重置 */
page {
  background-color: #fff;
  --safe-top: env(safe-area-inset-top);
  --safe-bottom: env(safe-area-inset-bottom);
}

/* 容器 */
.container {
  min-height: 100vh;
  min-height: calc(100vh + var(--safe-top));
  background-color: #fff;
  padding-bottom: calc(200rpx + var(--safe-bottom));
  box-sizing: border-box;
}

/* Banner */
.banner {
  position: relative;
  width: 100%;
  height: 360rpx;
  overflow: hidden;
}

.banner-img {
  width: 100%;
  height: 100%;
}

.banner-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 140rpx;
  background: linear-gradient(to bottom, transparent, rgba(0, 0, 0, 0.35));
}

/* 个人信息区域 */
.profile-section {
  position: relative;
  padding: 0 32rpx 40rpx;
  background: #fff;
  border-bottom-left-radius: 40rpx;
  border-bottom-right-radius: 40rpx;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.03);
  margin-bottom: 12rpx;
}

.profile-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-top: -80rpx;
  margin-bottom: 24rpx;
}

.avatar-wrapper {
  width: 168rpx;
  height: 168rpx;
  border-radius: 32rpx;
  overflow: hidden;
  border: 6rpx solid #fff;
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.1);
}

.avatar {
  width: 100%;
  height: 100%;
}

.social-buttons {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
  align-items: center;
}

.social-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
  font-size: 18rpx;
  font-weight: 700;
  color: #2563eb;
}

.social-btn.github {
  background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
}

.social-btn.twitter {
  background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
}

.follow-btn {
  height: 64rpx;
  padding: 0 28rpx;
  background: linear-gradient(135deg, #2563eb 0%, #4f46e5 100%);
  color: #fff;
  border-radius: 9999rpx;
  font-size: 24rpx;
  font-weight: 700;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(37, 99, 235, 0.3);
}

/* 个人信息 */
.profile-info {
  margin-bottom: 32rpx;
}

.name {
  font-size: 48rpx;
  font-weight: 900;
  color: #111;
  display: inline-block;
  letter-spacing: -1rpx;
}

.name-en {
  font-size: 28rpx;
  color: #6b7280;
  margin-left: 10rpx;
  font-weight: 500;
}

.role-location {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: #6b7280;
  margin-top: 10rpx;
  flex-wrap: wrap;
}

.separator {
  color: #d1d5db;
}

.bio {
  font-size: 28rpx;
  color: #4b5563;
  line-height: 1.7;
  margin-top: 20rpx;
}

/* 快捷联系方式 */
.quick-contact {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 20rpx 0;
}

.contact-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
  border-radius: 9999rpx;
  border: 1rpx solid #e2e8f0;
}

.contact-btn.phone .contact-text {
  color: #2563eb;
  font-weight: 600;
}

.contact-btn.wechat .contact-text {
  color: #07c160;
  font-weight: 600;
}

.contact-btn.email .contact-text {
  color: #4b5563;
  font-weight: 500;
}

.contact-icon {
  font-size: 22rpx;
}

.contact-text {
  font-size: 24rpx;
  max-width: 180rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 统计数据 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #f1f5f9;
}

.stat-card {
  background: linear-gradient(135deg, #f8fafc 0%, #f0f9ff 100%);
  border-radius: 20rpx;
  padding: 20rpx 12rpx;
  text-align: center;
  border: 1rpx solid #e0f2fe;
}

.stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: 900;
  color: #111;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 18rpx;
  color: #64748b;
  text-transform: uppercase;
  letter-spacing: 1rpx;
  font-weight: 600;
}

/* 产品作品集 */
.portfolio-section {
  padding: 36rpx 32rpx;
  background: #fff;
  margin: 12rpx 0;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 900;
  color: #111;
}

.view-all {
  font-size: 24rpx;
  color: #94a3b8;
  font-weight: 600;
}

.project-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.project-card {
  position: relative;
  background-color: #fff;
  border-radius: 32rpx;
  overflow: hidden;
  border: 2rpx solid #f1f5f9;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.project-thumb {
  width: 100%;
  height: 280rpx;
}

.project-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.5) 0%, transparent 40%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.project-card:active .project-overlay {
  opacity: 1;
}

.project-info {
  padding: 24rpx;
}

.project-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.tag {
  padding: 6rpx 16rpx;
  font-size: 18rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
  color: #2563eb;
  border-radius: 9999rpx;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.project-title {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: #111;
  margin-bottom: 10rpx;
}

.project-desc {
  display: block;
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.5;
  margin-bottom: 20rpx;
}

.project-links {
  display: flex;
  gap: 24rpx;
}

.link-item {
  font-size: 24rpx;
  font-weight: 600;
  color: #2563eb;
}

/* 视频模块 */
.video-section {
  padding: 36rpx 32rpx;
  background: linear-gradient(135deg, #f8fafc 0%, #f0f9ff 100%);
  margin: 12rpx 0;
}

.video-scroll {
  width: 100%;
  white-space: nowrap;
}

.video-list {
  display: flex;
  gap: 20rpx;
}

.video-card {
  position: relative;
  width: 320rpx;
  flex-shrink: 0;
  height: 460rpx;
  border-radius: 28rpx;
  overflow: hidden;
  background-color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.06);
}

.video-thumb {
  width: 100%;
  height: 100%;
}

.video-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 30%, transparent 60%, rgba(0,0,0,0.3) 100%);
}

.play-btn {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}

.play-icon {
  color: #fff;
  font-size: 28rpx;
  margin-left: 4rpx;
}

.video-duration-tag {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  padding: 6rpx 12rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.video-info {
  position: absolute;
  bottom: 20rpx;
  left: 20rpx;
  right: 20rpx;
}

.video-title {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.video-meta {
  display: flex;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 底部联系模块 */
.footer-section {
  padding: 36rpx 32rpx;
  background-color: #fff;
  margin: 12rpx 0;
}

.footer-title {
  font-size: 36rpx;
  font-weight: 900;
  color: #111;
  margin-bottom: 6rpx;
}

.footer-desc {
  display: block;
  font-size: 26rpx;
  color: #64748b;
  margin-bottom: 24rpx;
}

.footer-contact {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.contact-item-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #f8fafc 0%, #f0f9ff 100%);
  border-radius: 20rpx;
  border: 1rpx solid #e0f2fe;
}

.contact-row-icon {
  font-size: 36rpx;
}

.contact-row-info {
  flex: 1;
  min-width: 0;
}

.contact-row-label {
  display: block;
  font-size: 20rpx;
  font-weight: 700;
  color: #111;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.contact-row-value {
  display: block;
  font-size: 26rpx;
  color: #64748b;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.copy-hint {
  font-size: 20rpx;
  color: #2563eb;
  font-weight: 600;
  padding: 8rpx 16rpx;
  background: #fff;
  border-radius: 9999rpx;
  border: 1rpx solid #e0f2fe;
  flex-shrink: 0;
}

/* 底部操作 */
.action-bar {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  background: #fff;
  position: fixed;
  bottom: calc(100rpx + var(--safe-bottom));
  left: 0;
  right: 0;
  box-shadow: 0 -2rpx 20rpx rgba(0, 0, 0, 0.03);
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #111 0%, #333 100%);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.15);
}

.action-btn.secondary {
  background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
  color: #111;
  border: 2rpx solid #e2e8f0;
}

/* 浮动操作按钮 */
.fab-container {
  position: fixed;
  bottom: calc(140rpx + var(--safe-bottom));
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 16rpx;
  z-index: 100;
}

.fab-main {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 20rpx 32rpx;
  background: linear-gradient(135deg, #2563eb 0%, #4f46e5 100%);
  color: #fff;
  border-radius: 9999rpx;
  font-weight: 700;
  font-size: 26rpx;
  box-shadow: 0 12rpx 40rpx rgba(37, 99, 235, 0.35);
  border: none;
}

.fab-icon {
  font-size: 28rpx;
}

.fab-small {
  width: 84rpx;
  height: 84rpx;
  background: #fff;
  border: 2rpx solid #f1f5f9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.fab-icon-small {
  font-size: 32rpx;
}

/* 分享按钮 */
.share-btn {
  position: fixed;
  bottom: calc(280rpx + var(--safe-bottom));
  right: 24rpx;
  width: 80rpx;
  height: 80rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.08);
  border: 2rpx solid #f1f5f9;
  z-index: 100;
  font-size: 32rpx;
}

/* 响应式调整 */
@media (max-width: 320px) {
  .banner {
    height: 280rpx;
  }
  
  .profile-section {
    padding: 0 24rpx 32rpx;
  }
  
  .avatar-wrapper {
    width: 140rpx;
    height: 140rpx;
  }
  
  .name {
    font-size: 40rpx;
  }
  
  .project-thumb {
    height: 220rpx;
  }
  
  .video-card {
    width: 280rpx;
    height: 400rpx;
  }
}

@media (min-width: 400px) {
  .banner {
    height: 420rpx;
  }
  
  .profile-section {
    padding: 0 48rpx 48rpx;
  }
  
  .avatar-wrapper {
    width: 192rpx;
    height: 192rpx;
  }
  
  .name {
    font-size: 56rpx;
  }
  
  .project-thumb {
    height: 340rpx;
  }
  
  .video-card {
    width: 380rpx;
    height: 540rpx;
  }
}
