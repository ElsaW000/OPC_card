/**index.wxss - 优化版 **/

/* 容器 */
.container {
  min-height: 100vh;
  background-color: #fff;
  padding-bottom: 240rpx;
}

/* Banner */
.banner {
  position: relative;
  width: 100%;
  height: 384rpx;
  overflow: hidden;
}

.banner-img {
  width: 100%;
  height: 100%;
}

.banner-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 160rpx;
  background: linear-gradient(to bottom, transparent, rgba(0, 0, 0, 0.4));
}

/* 个人信息区域 */
.profile-section {
  position: relative;
  padding: 0 48rpx 48rpx;
  background: #fff;
  border-bottom-left-radius: 48rpx;
  border-bottom-right-radius: 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 16rpx;
}

.profile-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-top: -96rpx;
  margin-bottom: 32rpx;
}

.avatar-wrapper {
  width: 192rpx;
  height: 192rpx;
  border-radius: 40rpx;
  overflow: hidden;
  border: 8rpx solid #fff;
  box-shadow: 0 16rpx 32rpx rgba(0, 0, 0, 0.12);
}

.avatar {
  width: 100%;
  height: 100%;
}

.social-buttons {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
  align-items: center;
}

.social-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
  font-size: 20rpx;
  font-weight: 700;
  color: #2563eb;
}

.social-btn.github {
  background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
  color: #2563eb;
}

.social-btn.twitter {
  background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
  color: #000;
}

.follow-btn {
  height: 72rpx;
  padding: 0 36rpx;
  background: linear-gradient(135deg, #2563eb 0%, #4f46e5 100%);
  color: #fff;
  border-radius: 9999rpx;
  font-size: 26rpx;
  font-weight: 700;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.35);
}

/* 个人信息 */
.profile-info {
  margin-bottom: 40rpx;
}

.name {
  font-size: 52rpx;
  font-weight: 900;
  color: #111;
  display: inline-block;
  letter-spacing: -1rpx;
}

.name-en {
  font-size: 32rpx;
  color: #6b7280;
  margin-left: 12rpx;
  font-weight: 500;
}

.role-location {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 28rpx;
  color: #6b7280;
  margin-top: 12rpx;
  flex-wrap: wrap;
}

.separator {
  color: #d1d5db;
}

.bio {
  font-size: 30rpx;
  color: #4b5563;
  line-height: 1.7;
  margin-top: 24rpx;
}

/* 快捷联系方式 */
.quick-contact {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin: 24rpx 0;
}

.contact-btn {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
  border-radius: 9999rpx;
  border: 1rpx solid #e2e8f0;
}

.contact-btn.phone .contact-text {
  color: #2563eb;
  font-weight: 600;
}

.contact-btn.wechat .contact-text {
  color: #07c160;
  font-weight: 600;
}

.contact-btn.email .contact-text {
  color: #4b5563;
  font-weight: 500;
}

.contact-icon {
  font-size: 24rpx;
}

.contact-text {
  font-size: 26rpx;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 统计数据 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-top: 32rpx;
  padding-top: 32rpx;
  border-top: 2rpx solid #f1f5f9;
}

.stat-card {
  background: linear-gradient(135deg, #f8fafc 0%, #f0f9ff 100%);
  border-radius: 24rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  border: 1rpx solid #e0f2fe;
}

.stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: 900;
  color: #111;
  margin-bottom: 8rpx;
  letter-spacing: -1rpx;
}

.stat-label {
  font-size: 20rpx;
  color: #64748b;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  font-weight: 600;
}

/* 产品作品集 */
.portfolio-section {
  padding: 48rpx;
  background: #fff;
  margin: 16rpx 0;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 40rpx;
  font-weight: 900;
  color: #111;
  letter-spacing: -1rpx;
}

.view-all {
  font-size: 26rpx;
  color: #94a3b8;
  font-weight: 600;
}

.project-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.project-card {
  position: relative;
  background-color: #fff;
  border-radius: 40rpx;
  overflow: hidden;
  border: 2rpx solid #f1f5f9;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.project-thumb {
  width: 100%;
  height: 320rpx;
}

.project-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 50%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.project-card:active .project-overlay {
  opacity: 1;
}

.project-card:active .project-thumb {
  transform: scale(1.02);
  transition: transform 0.3s ease;
}

.project-info {
  padding: 32rpx;
}

.project-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.tag {
  padding: 8rpx 20rpx;
  font-size: 20rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
  color: #2563eb;
  border-radius: 9999rpx;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.project-title {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  color: #111;
  margin-bottom: 12rpx;
  letter-spacing: -0.5rpx;
}

.project-desc {
  display: block;
  font-size: 28rpx;
  color: #64748b;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.project-links {
  display: flex;
  gap: 32rpx;
}

.link-item {
  font-size: 26rpx;
  font-weight: 600;
  color: #2563eb;
}

/* 视频模块 */
.video-section {
  padding: 48rpx;
  background: linear-gradient(135deg, #f8fafc 0%, #f0f9ff 100%);
  margin: 16rpx 0;
}

.video-scroll {
  width: 100%;
  white-space: nowrap;
}

.video-list {
  display: flex;
  gap: 24rpx;
}

.video-card {
  position: relative;
  width: 360rpx;
  flex-shrink: 0;
  height: 520rpx;
  border-radius: 32rpx;
  overflow: hidden;
  background-color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.video-card:active {
  transform: scale(0.98);
}

.video-thumb {
  width: 100%;
  height: 100%;
}

.video-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 40%, transparent 60%, rgba(0,0,0,0.4) 100%);
}

.play-btn {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 96rpx;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10px);
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}

.play-icon {
  color: #fff;
  font-size: 32rpx;
  margin-left: 6rpx;
}

.video-duration-tag {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.video-info {
  position: absolute;
  bottom: 24rpx;
  left: 24rpx;
  right: 24rpx;
}

.video-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.video-meta {
  display: flex;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 底部联系模块 */
.footer-section {
  padding: 48rpx;
  background-color: #fff;
  margin: 16rpx 0;
}

.footer-title {
  font-size: 40rpx;
  font-weight: 900;
  color: #111;
  margin-bottom: 8rpx;
  letter-spacing: -1rpx;
}

.footer-desc {
  display: block;
  font-size: 28rpx;
  color: #64748b;
  margin-bottom: 32rpx;
}

.footer-contact {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.contact-item-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, #f8fafc 0%, #f0f9ff 100%);
  border-radius: 24rpx;
  border: 1rpx solid #e0f2fe;
}

.contact-row-icon {
  font-size: 40rpx;
}

.contact-row-info {
  flex: 1;
}

.contact-row-label {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  color: #111;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.contact-row-value {
  display: block;
  font-size: 28rpx;
  color: #64748b;
  margin-top: 4rpx;
}

.copy-hint {
  font-size: 22rpx;
  color: #2563eb;
  font-weight: 600;
  padding: 8rpx 20rpx;
  background: #fff;
  border-radius: 9999rpx;
  border: 1rpx solid #e0f2fe;
}

/* 底部操作 */
.action-bar {
  display: flex;
  gap: 24rpx;
  padding: 32rpx 48rpx;
  background: #fff;
  position: fixed;
  bottom: 120rpx;
  left: 0;
  right: 0;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.action-btn {
  flex: 1;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 700;
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #111 0%, #333 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
}

.action-btn.secondary {
  background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
  color: #111;
  border: 2rpx solid #e2e8f0;
}

/* 浮动操作按钮 */
.fab-container {
  position: fixed;
  bottom: 160rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 20rpx;
  z-index: 100;
}

.fab-main {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 40rpx;
  background: linear-gradient(135deg, #2563eb 0%, #4f46e5 100%);
  color: #fff;
  border-radius: 9999rpx;
  font-weight: 700;
  font-size: 28rpx;
  box-shadow: 0 16rpx 48rpx rgba(37, 99, 235, 0.4);
  border: none;
}

.fab-icon {
  font-size: 32rpx;
}

.fab-text {
  color: #fff;
}

.fab-small {
  width: 96rpx;
  height: 96rpx;
  background: #fff;
  border: 2rpx solid #f1f5f9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.08);
}

.fab-icon-small {
  font-size: 36rpx;
}

/* 分享按钮 */
.share-btn {
  position: fixed;
  bottom: 320rpx;
  right: 32rpx;
  width: 88rpx;
  height: 88rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  border: 2rpx solid #f1f5f9;
  z-index: 100;
  font-size: 36rpx;
}
