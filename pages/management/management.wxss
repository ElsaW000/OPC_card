/* management.wxss */

page {
  background-color: #f8f9fa;
}

.container {
  min-height: 100vh;
  padding: 32rpx;
  padding-bottom: 200rpx;
}

/* 顶部个人信息卡片 */
.profile-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.profile-left {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.profile-avatar {
  width: 100%;
  height: 100%;
}

.profile-middle {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
}

.profile-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #000;
}

.profile-role {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.profile-right {
  padding: 16rpx;
}

.arrow-icon {
  font-size: 40rpx;
  color: #ccc;
  font-weight: 300;
}

/* 功能列表 */
.menu-card {
  margin-top: 32rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  font-size: 28rpx;
  color: #333;
}

.menu-divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 0 32rpx;
}

/* 版本信息 */
.version-info {
  margin-top: 48rpx;
  text-align: center;
}

.version-info text {
  font-size: 22rpx;
  color: #ccc;
}
