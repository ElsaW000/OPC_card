/* management.wxss */

page {
  background-color: #f8fafc;
}

.container {
  width: 100%;
  min-height: 100vh;
  padding: 24rpx 32rpx 120rpx;
  box-sizing: border-box;
  overflow-x: hidden;
}

.profile-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.profile-left {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.profile-avatar {
  width: 100%;
  height: 100%;
}

.profile-middle {
  flex: 1;
  margin-left: 20rpx;
}

.profile-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #111;
}

.profile-role {
  font-size: 24rpx;
  color: #64748b;
  margin-top: 4rpx;
}

.menu-card {
  margin-top: 24rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  font-size: 28rpx;
  color: #333;
}

.version-info {
  margin-top: 48rpx;
  text-align: center;
}

.version-info text {
  font-size: 22rpx;
  color: #cbd5e1;
}

@media (max-width: 375px) {
  .container {
    padding-left: 20rpx;
    padding-right: 20rpx;
  }
}
