/* management.wxss */

page { background-color: #f8f9fa; }
.container { min-height: 100vh; padding-bottom: 120rpx; }

/* Profile */
.profile-card { display: flex; align-items: center; background: #fff; margin: 24rpx; padding: 32rpx; border-radius: 24rpx; }
.profile-avatar { width: 120rpx; height: 120rpx; border-radius: 50%; margin-right: 24rpx; }
.profile-info { flex: 1; }
.profile-name { display: block; font-size: 32rpx; font-weight: bold; color: #000; }
.profile-phone { display: block; font-size: 26rpx; color: #666; margin-top: 8rpx; }
.profile-wechat { display: block; font-size: 24rpx; color: #999; margin-top: 6rpx; }
.info-list .menu-item { justify-content: space-between; }
.info-value { max-width: 420rpx; font-size: 25rpx; color: #6b7280; text-align: right; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* Group label */
.group-label { margin: 32rpx 24rpx 12rpx; font-size: 24rpx; color: #999; font-weight: 500; }

/* Menu */
.menu-list { margin: 0 24rpx; background: #fff; border-radius: 24rpx; }
.menu-item { display: flex; align-items: center; padding: 28rpx 24rpx; border-bottom: 1rpx solid #f0f0f0; }
.menu-item:last-child { border-bottom: none; }
.menu-icon { font-size: 32rpx; margin-right: 20rpx; }
.menu-text { flex: 1; font-size: 28rpx; color: #000; }
.menu-arrow { font-size: 32rpx; color: #ccc; }
.menu-tag { padding: 8rpx 20rpx; background: linear-gradient(135deg, #ffd700, #ffb700); border-radius: 20rpx; font-size: 22rpx; color: #000; font-weight: bold; }

/* Logout */
.logout-btn { margin: 48rpx 24rpx; padding: 28rpx; background: #fff; border-radius: 24rpx; text-align: center; }
.logout-btn text { color: #ef4444; font-size: 28rpx; }

/* Picker */
.picker-val { display: flex; align-items: center; }
.picker-text { font-size: 26rpx; color: #666; margin-right: 8rpx; }

/* API settings */
.api-url-preview { font-size: 24rpx; color: #999; max-width: 360rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.api-edit-row { display: flex; align-items: center; padding: 16rpx 24rpx; border-top: 1rpx solid #f0f0f0; }
.api-input { flex: 1; font-size: 24rpx; color: #333; background: #f8f9fa; border-radius: 12rpx; padding: 12rpx 16rpx; }
.api-save-btn { margin-left: 16rpx; padding: 12rpx 24rpx; background: #2563EB; color: #fff; font-size: 24rpx; border-radius: 12rpx; }

/* Version */
.menu-version { font-size: 26rpx; color: #999; }

/* Avatar placeholder */
.avatar-placeholder { background: #e5e7eb; display: flex; align-items: center; justify-content: center; }
.avatar-initial { font-size: 48rpx; color: #666; }
