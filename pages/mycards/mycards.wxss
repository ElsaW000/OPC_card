/* mycards.wxss */

page { background-color: #f8f9fa; }
.container { min-height: 100vh; padding: 32rpx; padding-bottom: 120rpx; }

/* Header */
.header { margin-bottom: 32rpx; }
.header-title { font-size: 44rpx; font-weight: bold; color: #000; display: block; }
.header-subtitle { font-size: 20rpx; color: #999; text-transform: uppercase; letter-spacing: 2rpx; margin-top: 8rpx; display: block; }

/* Card List */
.card-list { display: flex; flex-direction: column; gap: 32rpx; }

/* Card Item */
.card-item { border-radius: 32rpx; overflow: hidden; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06); position: relative; }
.card-bg { position: absolute; inset: 0; }
.card-bg image { width: 100%; height: 100%; }
.card-bg.tech { background: linear-gradient(135deg, #3b82f6, #1d4ed8); }
.card-bg.biz { background: linear-gradient(135deg, #475569, #334155); }
.card-bg.social { background: linear-gradient(135deg, #10b981, #059669); }

.card-content { position: relative; z-index: 2; padding: 32rpx; color: #fff; min-height: 280rpx; display: flex; flex-direction: column; justify-content: space-between; }

/* Card Header */
.card-header { display: flex; justify-content: space-between; align-items: center; }
.card-type { display: flex; align-items: center; gap: 12rpx; }
.type-name { font-size: 20rpx; opacity: 0.8; }
.card-default { padding: 8rpx 20rpx; background: #2563eb; border-radius: 20rpx; font-size: 20rpx; }

/* Card Body */
.card-body { display: flex; justify-content: space-between; align-items: flex-end; }
.card-info { flex: 1; }
.card-name { display: block; font-size: 44rpx; font-weight: bold; }
.card-role { display: block; font-size: 26rpx; opacity: 0.9; margin-top: 8rpx; }
.card-company { display: block; font-size: 22rpx; opacity: 0.7; margin-top: 4rpx; }
.card-avatar { width: 120rpx; height: 120rpx; border-radius: 24rpx; overflow: hidden; border: 4rpx solid rgba(255,255,255,0.5); }
.card-avatar image { width: 100%; height: 100%; }

/* Card Actions */
.card-actions { position: relative; z-index: 2; display: flex; justify-content: space-around; padding: 24rpx; background: #fff; }
.action-btn { display: flex; flex-direction: column; align-items: center; gap: 4rpx; }
.action-icon { font-size: 32rpx; }
.action-text { font-size: 20rpx; color: #666; }
.action-btn.active .action-text { color: #2563eb; }

/* Add Button */
.add-btn { position: fixed; bottom: 200rpx; right: 32rpx; width: 100rpx; height: 100rpx; background: #2563eb; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 16rpx 48rpx rgba(37,99,235,0.3); z-index: 100; }
.add-btn text { font-size: 60rpx; color: #fff; font-weight: 300; }
