/**mycards.wxss - 优化版 **/

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
}

/* Header */
.header {
  position: sticky;
  top: 0;
  z-index: 40;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20px);
  padding: 48rpx 40rpx 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  border-bottom: 2rpx solid #f1f5f9;
}

.header-content {
  flex: 1;
}

.header-title {
  font-size: 52rpx;
  font-weight: 900;
  color: #111;
  display: block;
  letter-spacing: -1rpx;
}

.header-subtitle {
  font-size: 20rpx;
  font-weight: 700;
  color: #94a3b8;
  letter-spacing: 0.2em;
  display: block;
  margin-top: 8rpx;
}

.add-btn {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #2563eb 0%, #4f46e5 100%);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(37, 99, 235, 0.3);
}

.add-icon {
  font-size: 48rpx;
  color: #fff;
  font-weight: 300;
}

/* Cards Scroll */
.cards-scroll {
  padding: 40rpx;
  padding-bottom: 200rpx;
}

.cards-list {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

.card-item {
  position: relative;
}

/* ID Card */
.id-card {
  position: relative;
  height: 448rpx;
  border-radius: 48rpx;
  overflow: hidden;
  box-shadow: 0 24rpx 64rpx rgba(0, 0, 0, 0.15);
}

.card-bg {
  position: absolute;
  width: 100%;
  height: 100%;
  filter: blur(4rpx);
}

.card-overlay {
  position: absolute;
  width: 100%;
  height: 100%;
  z-index: 10;
}

/* Color Classes */
.gradient-blue {
  background: linear-gradient(135deg, #2563eb 0%, #4f46e5 100%);
}
.gradient-blue .card-overlay { background: linear-gradient(135deg, rgba(37, 99, 235, 0.85) 0%, rgba(79, 70, 229, 0.9) 100%); }

.gradient-slate {
  background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
}
.gradient-slate .card-overlay { background: linear-gradient(135deg, rgba(30, 41, 59, 0.9) 0%, rgba(15, 23, 42, 0.95) 100%); }

.gradient-emerald {
  background: linear-gradient(135deg, #10b981 0%, #14b8a6 100%);
}
.gradient-emerald .card-overlay { background: linear-gradient(135deg, rgba(16, 185, 129, 0.85) 0%, rgba(20, 184, 166, 0.9) 100%); }

.gradient-purple {
  background: linear-gradient(135deg, #8b5cf6 0%, #a855f7 100%);
}
.gradient-purple .card-overlay { background: linear-gradient(135deg, rgba(139, 92, 246, 0.85) 0%, rgba(168, 85, 247, 0.9) 100%); }

.gradient-orange {
  background: linear-gradient(135deg, #f97316 0%, #fb923c 100%);
}
.gradient-orange .card-overlay { background: linear-gradient(135deg, rgba(249, 115, 22, 0.85) 0%, rgba(251, 146, 60, 0.9) 100%); }

.gradient-pink {
  background: linear-gradient(135deg, #ec4899 0%, #f472b6 100%);
}
.gradient-pink .card-overlay { background: linear-gradient(135deg, rgba(236, 72, 153, 0.85) 0%, rgba(244, 114, 182, 0.9) 100%); }

/* Card Content */
.card-content {
  position: relative;
  z-index: 20;
  height: 100%;
  padding: 56rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  color: #fff;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.card-type {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.type-icon-box {
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10px);
  padding: 12rpx;
  border-radius: 16rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.type-icon {
  font-size: 28rpx;
}

.type-label {
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  opacity: 0.85;
}

.default-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10px);
  border-radius: 9999rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.star {
  font-size: 20rpx;
}

.default-text {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.card-name {
  font-size: 48rpx;
  font-weight: 900;
  display: block;
  margin-bottom: 8rpx;
  letter-spacing: -1rpx;
}

.card-role {
  font-size: 28rpx;
  font-weight: 600;
  opacity: 0.85;
  display: block;
  margin-bottom: 12rpx;
}

.card-company {
  display: flex;
  align-items: center;
  gap: 8rpx;
  opacity: 0.6;
}

.company-icon {
  font-size: 22rpx;
}

.company-text {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.card-avatar-box {
  width: 120rpx;
  height: 120rpx;
  border-radius: 28rpx;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
}

.card-avatar {
  width: 100%;
  height: 100%;
}

/* Chip Decoration */
.chip-decoration {
  position: absolute;
  top: 45%;
  right: -24rpx;
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10px);
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

/* Card Actions */
.card-actions {
  margin-top: 24rpx;
  padding: 0 8rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.actions-left {
  display: flex;
  gap: 32rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.action-icon {
  font-size: 24rpx;
  color: #94a3b8;
}

.action-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #94a3b8;
}

.action-btn.active .action-icon,
.action-btn.active .action-text {
  color: #2563eb;
}

.action-text.active {
  color: #2563eb;
}

.actions-right {
  display: flex;
  gap: 16rpx;
}

.icon-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f8fafc;
  border-radius: 16rpx;
  font-size: 28rpx;
}

.icon-btn.delete {
  background: #fef2f2;
}

/* Add Card Placeholder */
.add-card-placeholder {
  width: 100%;
  height: 200rpx;
  border-radius: 48rpx;
  border: 4rpx dashed #cbd5e1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background: #fafafa;
}

.placeholder-icon-box {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f1f5f9;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 36rpx;
  color: #94a3b8;
  font-weight: 300;
}

.placeholder-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #94a3b8;
  letter-spacing: 0.2em;
  text-transform: uppercase;
}

/* Tips Box */
.tips-box {
  margin-top: 32rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx;
  border: 2rpx solid #f1f5f9;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.02);
}

.tips-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.tips-icon {
  font-size: 24rpx;
}

.tips-title {
  font-size: 24rpx;
  font-weight: 800;
  color: #111;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.tips-content {
  font-size: 22rpx;
  color: #64748b;
  line-height: 1.8;
  font-weight: 500;
}

/* Bottom Nav Spacer */
.bottom-nav-spacer {
  height: 140rpx;
}
