/* mycards.wxss */

page {
  background-color: #f8f9fa;
}

.container {
  min-height: 100vh;
  background-color: #f8f9fa;
  padding-bottom: 200rpx;
}

/* 顶部标题 */
.header {
  padding: 48rpx 32rpx 32rpx;
  background: #fff;
}

.header-titles {
  display: flex;
  flex-direction: column;
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #000000;
}

.header-subtitle {
  font-size: 20rpx;
  color: #999999;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-top: 8rpx;
}

/* 名片列表 */
.cards-list {
  padding: 0 32rpx 32rpx;
}

.card-item {
  margin-bottom: 32rpx;
}

/* ID Card */
.id-card {
  position: relative;
  height: 200rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

/* 右侧背景图 - 仅占右侧50% */
.card-bg-area {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 50%;
  overflow: hidden;
}

.card-bg-img {
  width: 100%;
  height: 100%;
}

/* 左侧内容 */
.card-left {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  z-index: 2;
}

.card-type {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.type-icon {
  font-size: 20rpx;
}

.type-label {
  font-size: 18rpx;
  font-weight: 600;
  color: #666;
}

.default-badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  background: #fef3c7;
  border-radius: 9999rpx;
}

.default-text {
  font-size: 16rpx;
  font-weight: 600;
  color: #92400e;
}

.card-info {
  display: flex;
  flex-direction: column;
}

.card-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #000;
}

.card-role {
  font-size: 22rpx;
  color: #666;
  margin-top: 4rpx;
}

.card-company {
  font-size: 20rpx;
  color: #999;
  margin-top: 2rpx;
}

/* 右侧头像 */
.card-right {
  width: 140rpx;
  height: 100%;
  z-index: 2;
}

.card-avatar {
  width: 100%;
  height: 100%;
}

/* 底部操作栏 */
.card-actions {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.action-primary {
  padding: 16rpx 32rpx;
  background: #2563eb;
  border-radius: 12rpx;
}

.action-primary-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
}

.action-icons {
  display: flex;
  gap: 12rpx;
}

.icon-circle {
  width: 64rpx;
  height: 64rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.icon-circle text {
  font-size: 28rpx;
}

/* 添加新名片 */
.add-card-placeholder {
  height: 120rpx;
  border-radius: 24rpx;
  border: 2rpx dashed #ddd;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: #fff;
}

.placeholder-icon {
  font-size: 40rpx;
  color: #999;
}

.placeholder-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #999;
  letter-spacing: 1rpx;
}

/* Tips Box */
.tips-box {
  margin: 32rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
}

.tips-title {
  font-size: 22rpx;
  font-weight: 600;
  color: #000;
  display: block;
  margin-bottom: 12rpx;
}

.tips-content {
  font-size: 20rpx;
  color: #666;
  line-height: 1.6;
}
