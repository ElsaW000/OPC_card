/* mycards.wxss */

page { background-color: #f8f9fa; }
.container { min-height: 100vh; background-color: #f8f9fa; padding-bottom: 200rpx; }

/* 顶部标题 */
.header { padding: 48rpx 32rpx 24rpx; background: #fff; }
.header-title { font-size: 40rpx; font-weight: bold; color: #000; }
.header-subtitle { font-size: 20rpx; color: #999; text-transform: uppercase; letter-spacing: 2rpx; margin-top: 8rpx; }

/* 名片切换 tabs */
.card-tabs { background: #fff; padding: 0 32rpx 24rpx; border-bottom: 1rpx solid #f0f0f0; }
.tabs-scroll { white-space: nowrap; }
.tabs-list { display: inline-flex; gap: 16rpx; }
.tab-item { display: inline-flex; align-items: center; justify-content: center; width: 64rpx; height: 64rpx; background: #f1f5f9; border-radius: 16rpx; }
.tab-item.active { background: #2F65EE; }
.tab-item.add { background: #fff; border: 2rpx dashed #ddd; }
.tab-num { font-size: 28rpx; font-weight: 600; color: #666; }
.tab-item.active .tab-num { color: #fff; }

/* 名片预览 */
.card-preview { padding: 32rpx; }
.preview-card { position: relative; height: 320rpx; border-radius: 32rpx; overflow: hidden; box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.1); }
.preview-bg { position: absolute; inset: 0; }
.preview-bg image { width: 100%; height: 100%; filter: blur(8rpx); }
.preview-content { position: relative; z-index: 2; height: 100%; padding: 32rpx; display: flex; flex-direction: column; justify-content: space-between; color: #fff; }
.preview-header { display: flex; justify-content: space-between; align-items: center; }
.preview-type { display: flex; align-items: center; gap: 12rpx; }
.type-name { font-size: 20rpx; font-weight: 600; opacity: 0.8; }
.preview-default { padding: 8rpx 20rpx; background: rgba(255,255,255,0.25); border-radius: 20rpx; font-size: 20rpx; }
.preview-body { display: flex; justify-content: space-between; align-items: flex-end; }
.preview-info { flex: 1; }
.preview-name { display: block; font-size: 44rpx; font-weight: bold; }
.preview-role { display: block; font-size: 26rpx; opacity: 0.9; margin-top: 8rpx; }
.preview-company { display: block; font-size: 22rpx; opacity: 0.7; margin-top: 4rpx; }
.preview-avatar { width: 120rpx; height: 120rpx; border-radius: 24rpx; overflow: hidden; border: 4rpx solid rgba(255,255,255,0.5); }
.preview-avatar image { width: 100%; height: 100%; }

/* 底部操作 */
.preview-actions { display: flex; gap: 16rpx; margin-top: 24rpx; }
.action-primary { flex: 1; padding: 20rpx; background: #2F65EE; border-radius: 16rpx; text-align: center; }
.action-primary text { color: #fff; font-size: 28rpx; font-weight: 600; }
.action-icon-btn { width: 80rpx; height: 80rpx; background: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08); font-size: 32rpx; }

/* 名片列表 */
.card-list-section { padding: 0 32rpx; }
.section-title { font-size: 24rpx; font-weight: 600; color: #666; margin-bottom: 16rpx; display: block; }
.card-list { background: #fff; border-radius: 24rpx; overflow: hidden; }
.list-item { display: flex; align-items: center; padding: 24rpx; border-bottom: 1rpx solid #f5f5f5; }
.list-item:last-child { border-bottom: none; }
.list-info { flex: 1; }
.list-name { display: block; font-size: 28rpx; font-weight: 600; color: #000; }
.list-role { display: block; font-size: 22rpx; color: #999; margin-top: 4rpx; }
.list-badge { padding: 6rpx 16rpx; background: #fef3c7; border-radius: 8rpx; font-size: 20rpx; color: #92400e; margin-right: 16rpx; }
.list-delete { padding: 8rpx 16rpx; font-size: 28rpx; }

/* 添加按钮 */
.add-card-btn { margin: 32rpx; padding: 32rpx; background: #fff; border-radius: 24rpx; text-align: center; border: 2rpx dashed #ddd; }
.add-card-btn text { font-size: 28rpx; color: #999; font-weight: 600; }
