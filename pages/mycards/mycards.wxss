/* mycards.wxss */

.container {
  min-height: 100vh;
  background-color: #f9fafb;
}

.header {
  padding: 48rpx 32rpx 32rpx;
  background-color: #fff;
}

.header-title {
  font-size: 48rpx;
  font-weight: 900;
  color: #111;
}

.header-subtitle {
  font-size: 24rpx;
  font-weight: 700;
  color: #9ca3af;
  text-transform: uppercase;
  letter-spacing: 4rpx;
  margin-top: 8rpx;
}

.card-list {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.card-item {
  position: relative;
  height: 400rpx;
  border-radius: 40rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.15);
}

.card-bg {
  position: absolute;
  inset: 0;
  opacity: 0.9;
}

.card-bg.bg-blue {
  background: linear-gradient(135deg, #2563eb, #4f46e5);
}

.card-bg.bg-slate {
  background: linear-gradient(135deg, #1e293b, #0f172a);
}

.card-bg.bg-green {
  background: linear-gradient(135deg, #10b981, #0d9488);
}

.card-bg.bg-purple {
  background: linear-gradient(135deg, #8b5cf6, #7c3aed);
}

.card-bg-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  filter: blur(4rpx);
}

.card-content {
  position: relative;
  z-index: 1;
  height: 100%;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-type {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 20rpx;
  background-color: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(8rpx);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.type-icon {
  font-size: 24rpx;
}

.type-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.card-default {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  background-color: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(8rpx);
  border-radius: 9999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.default-tag {
  font-size: 20rpx;
  font-weight: 700;
  color: #fff;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.card-body {
  display: flex;
  align-items: flex-end;
  gap: 24rpx;
}

.card-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  overflow: hidden;
  border: 4rpx solid #fff;
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.2);
}

.card-avatar image {
  width: 100%;
  height: 100%;
}

.card-info {
  flex: 1;
}

.card-name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.card-role {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 4rpx;
}

.card-location {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 4rpx;
}

.card-actions {
  position: absolute;
  bottom: 32rpx;
  right: 32rpx;
  display: flex;
  gap: 12rpx;
}

.action-btn {
  padding: 12rpx 24rpx;
  background-color: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(8rpx);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.action-btn text {
  font-size: 22rpx;
  font-weight: 600;
  color: #fff;
}

.action-btn.delete {
  background-color: rgba(239, 68, 68, 0.3);
  border-color: rgba(239, 68, 68, 0.5);
}

/* 添加按钮 */
.add-card-btn {
  position: fixed;
  bottom: 48rpx;
  left: 32rpx;
  right: 32rpx;
  height: 100rpx;
  background-color: #111;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
}

.add-icon {
  font-size: 40rpx;
  color: #fff;
  font-weight: 300;
}

.add-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}
