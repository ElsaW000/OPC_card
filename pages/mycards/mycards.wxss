/* mycards.wxss */
page { background-color: #f8fafc; }
.container { min-height: 100vh; background-color: #f8fafc; padding-bottom: 140rpx; }
.header { padding: 32rpx; background: #fff; }
.header-title { font-size: 44rpx; font-weight: 900; color: #111; }
.header-subtitle { font-size: 20rpx; color: #94a3b8; letter-spacing: 2rpx; margin-top: 8rpx; display: block; }
.card-list { padding: 24rpx 32rpx; display: flex; flex-direction: column; gap: 24rpx; }
.card-item { position: relative; border-radius: 32rpx; overflow: hidden; box-shadow: 0 16rpx 48rpx rgba(47,101,238,0.25); }
.card-banner { position: absolute; width: 100%; height: 100%; top: 0; left: 0; }
.banner-img { width: 100%; height: 100%; object-fit: cover; }
.banner-mask { position: absolute; width: 100%; height: 100%; top: 0; left: 0; }
.banner-mask.tech { background: linear-gradient(135deg, rgba(59,130,246,0.88), rgba(29,78,216,0.92)); }
.banner-mask.biz { background: linear-gradient(135deg, rgba(30,41,59,0.92), rgba(15,23,42,0.96)); }
.banner-mask.social { background: linear-gradient(135deg, rgba(16,185,129,0.88), rgba(5,150,105,0.92)); }
.card-content { position: relative; z-index: 2; padding: 32rpx; min-height: 280rpx; display: flex; flex-direction: column; }
.card-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: auto; }
.card-type { display: flex; align-items: center; gap: 10rpx; }
.type-icon { font-size: 24rpx; }
.type-name { font-size: 20rpx; font-weight: 600; color: rgba(255,255,255,0.9); text-transform: uppercase; }
.card-actions-right { display: flex; align-items: center; gap: 12rpx; }
.icon-btn { width: 56rpx; height: 56rpx; display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,0.25); border-radius: 16rpx; }
.btn-icon { width: 32rpx; height: 32rpx; }
.default-badge { padding: 8rpx 20rpx; background: rgba(255,255,255,0.25); border-radius: 9999rpx; }
.badge-text { font-size: 20rpx; font-weight: 600; color: #fff; }
.card-body { display: flex; justify-content: space-between; align-items: flex-end; margin-top: auto; }
.card-info { flex: 1; }
.card-name { font-size: 48rpx; font-weight: 700; color: #fff; display: block; }
.card-role { font-size: 26rpx; color: rgba(255,255,255,0.85); margin-top: 8rpx; display: block; }
.card-company { font-size: 22rpx; color: rgba(255,255,255,0.6); margin-top: 4rpx; display: block; }
.card-avatar { width: 112rpx; height: 112rpx; border-radius: 24rpx; overflow: hidden; border: 4rpx solid rgba(255,255,255,0.5); }
.card-avatar image { width: 100%; height: 100%; }
.card-operations { display: flex; gap: 16rpx; padding: 20rpx 24rpx; background: #fff; }
.op-btn { flex: 1; display: flex; align-items: center; justify-content: center; gap: 8rpx; padding: 20rpx; background: #f8fafc; border-radius: 16rpx; border: none; line-height: normal; }
.op-btn::after { border: none; }
.op-btn.active { background: rgba(37,99,235,0.1); }
.op-icon { width: 32rpx; height: 32rpx; }
.op-text { font-size: 24rpx; font-weight: 500; color: #64748b; }
.op-btn.active .op-text { color: #2563eb; font-weight: 600; }
.add-card-btn { margin: 24rpx 32rpx; padding: 32rpx; background: #fff; border-radius: 24rpx; text-align: center; border: 2rpx dashed #cbd5e1; }
.add-card-btn text { font-size: 28rpx; color: #94a3b8; font-weight: 600; }
.card-item { animation: slideUp 0.5s ease-out forwards; opacity: 0; }
.card-item:nth-child(1){animation-delay:0ms}
.card-item:nth-child(2){animation-delay:100ms}
.card-item:nth-child(3){animation-delay:200ms}
@keyframes slideUp{from{opacity:0;transform:translateY(40rpx)}to{opacity:1;transform:translateY(0)}}
@media (max-width:375px){.header,.card-list,.add-card-btn{padding-left:20rpx;padding-right:20rpx}}
/* ===== 交换名片悬浮按钮 ===== */
.exchange-fab {
  position: fixed;
  bottom: calc(env(safe-area-inset-bottom) + 120rpx);
  left: 50%;
  transform: translateX(-50%);
  background: #2563EB;
  color: #fff;
  border-radius: 9999rpx;
  padding: 28rpx 72rpx;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 0.02em;
  box-shadow: 0 16rpx 48rpx rgba(37,99,235,0.45);
  z-index: 100;
  white-space: nowrap;
}

.exchange-fab-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
}
