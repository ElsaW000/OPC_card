/* mycards.wxss */

page {
  background-color: #f8f9fa;
}

.container {
  min-height: 100vh;
  background-color: #f8f9fa;
  padding-bottom: 200rpx;
}

.header {
  position: sticky;
  top: 0;
  z-index: 40;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  padding: 48rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-title {
  font-size: 48rpx;
  font-weight: 900;
  color: #111;
}

.header-subtitle {
  font-size: 20rpx;
  font-weight: 700;
  color: #94a3b8;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  margin-top: 8rpx;
}

.add-btn {
  width: 96rpx;
  height: 96rpx;
  background: #2563eb;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 48rpx rgba(37, 99, 235, 0.3);
}

.add-icon {
  font-size: 56rpx;
  color: #fff;
  font-weight: 300;
}

.cards-list {
  padding: 32rpx;
}

.card-item {
  margin-bottom: 32rpx;
}

/* ID Card - 简化版 */
.id-card {
  position: relative;
  height: 220rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

/* 左侧内容 */
.card-left {
  flex: 1;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  z-index: 2;
}

.card-type {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.type-icon {
  font-size: 24rpx;
}

.type-label {
  font-size: 20rpx;
  font-weight: 700;
  color: #64748b;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.default-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 16rpx;
  background: #fef3c7;
  border-radius: 9999rpx;
}

.star-icon {
  font-size: 18rpx;
}

.default-text {
  font-size: 18rpx;
  font-weight: 600;
  color: #92400e;
}

.card-info {
  display: flex;
  flex-direction: column;
}

.card-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #111;
}

.card-role {
  font-size: 24rpx;
  color: #64748b;
  margin-top: 4rpx;
  letter-spacing: 0.05em;
}

.card-company {
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 4rpx;
}

/* 右侧头像 */
.card-right {
  width: 180rpx;
  height: 100%;
  position: relative;
  z-index: 2;
}

.card-avatar {
  width: 100%;
  height: 100%;
}

/* Card Actions */
.card-actions {
  margin-top: 16rpx;
  padding: 0 8rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.actions-left {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  padding: 12rpx 16rpx;
  background: #f1f5f9;
  border-radius: 12rpx;
}

.action-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #64748b;
  letter-spacing: 0.05em;
}

.actions-right {
  display: flex;
  gap: 16rpx;
}

.icon-btn {
  padding: 12rpx 16rpx;
  background: #f1f5f9;
  border-radius: 12rpx;
}

.btn-icon {
  font-size: 24rpx;
}

/* Add Card Placeholder */
.add-card-placeholder {
  height: 160rpx;
  border-radius: 24rpx;
  border: 4rpx dashed #e2e8f0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: #fff;
  color: #94a3b8;
}

.placeholder-icon {
  font-size: 48rpx;
}

.placeholder-text {
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
}

/* Tips Box */
.tips-box {
  margin: 32rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
}

.tips-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #111;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  display: block;
  margin-bottom: 16rpx;
}

.tips-content {
  font-size: 22rpx;
  color: #64748b;
  line-height: 1.8;
}
