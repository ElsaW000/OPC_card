/* mycards.wxss */

page {
  background-color: #f8fafc;
}

.container {
  width: 100%;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* Header */
.header {
  width: 100%;
  padding: 32rpx;
  background: #fff;
  box-sizing: border-box;
}

.header-title {
  font-size: 44rpx;
  font-weight: 900;
  color: #111;
}

.header-subtitle {
  font-size: 20rpx;
  color: #94a3b8;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-top: 8rpx;
}

/* Tabs */
.card-tabs {
  background: #fff;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.tabs-list {
  display: flex;
  gap: 16rpx;
}

.tab-item {
  width: 64rpx;
  height: 64rpx;
  background: #f1f5f9;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-item.active {
  background: #2563eb;
}

.tab-num {
  font-size: 28rpx;
  font-weight: 600;
  color: #64748b;
}

.tab-item.active .tab-num {
  color: #fff;
}

/* Preview Card - 重要！ */
.card-preview {
  padding: 32rpx;
  width: 100%;
  box-sizing: border-box;
}

.preview-card {
  position: relative;
  height: 400rpx;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.15);
}

.preview-bg {
  position: absolute;
  width: 100%;
  height: 100%;
}

.preview-bg image {
  width: 100%;
  height: 100%;
}

.preview-content {
  position: absolute;
  width: 100%;
  height: 100%;
  padding: 36rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  color: #fff;
  z-index: 2;
}

.preview-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.preview-type {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.type-name {
  font-size: 22rpx;
  font-weight: 700;
  opacity: 0.9;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.preview-default {
  padding: 8rpx 20rpx;
  background: rgba(255,255,255,0.25);
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.preview-body {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.preview-info {
  flex: 1;
}

.preview-name {
  font-size: 52rpx;
  font-weight: 900;
}

.preview-role {
  font-size: 28rpx;
  opacity: 0.9;
  margin-top: 8rpx;
}

.preview-company {
  font-size: 22rpx;
  opacity: 0.7;
  margin-top: 4rpx;
}

.preview-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 28rpx;
  overflow: hidden;
  border: 4rpx solid rgba(255,255,255,0.5);
}

.preview-avatar image {
  width: 100%;
  height: 100%;
}

/* Actions */
.preview-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.action-primary {
  flex: 1;
  padding: 24rpx;
  background: #2563eb;
  border-radius: 20rpx;
  text-align: center;
}

.action-primary text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}

.action-icon-btn {
  width: 96rpx;
  height: 96rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
  font-size: 40rpx;
}

/* List */
.card-list-section {
  padding: 0 32rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #374151;
  margin-bottom: 16rpx;
  display: block;
}

.card-list {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.list-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.list-item:last-child {
  border-bottom: none;
}

.list-info {
  flex: 1;
}

.list-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #111;
}

.list-role {
  font-size: 22rpx;
  color: #64748b;
  margin-top: 4rpx;
}

.list-badge {
  padding: 6rpx 16rpx;
  background: #fef3c7;
  border-radius: 8rpx;
  font-size: 20rpx;
  color: #92400e;
  font-weight: 600;
  margin-right: 16rpx;
}

.list-delete {
  font-size: 28rpx;
}

/* Add Button */
.add-card-btn {
  margin: 32rpx;
  padding: 32rpx;
  background: #fff;
  border-radius: 24rpx;
  text-align: center;
  border: 2rpx dashed #cbd5e1;
}

.add-card-btn text {
  font-size: 28rpx;
  color: #94a3b8;
  font-weight: 600;
}
