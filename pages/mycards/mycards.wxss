/**mycards.wxss - 响应式 **/

page {
  background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
  --safe-top: env(safe-area-inset-top);
  --safe-bottom: env(safe-area-inset-bottom);
}

.container {
  min-height: 100vh;
  min-height: 100dvh;
  display: flex;
  flex-direction: column;
  padding-bottom: calc(100rpx + var(--safe-bottom));
  box-sizing: border-box;
}

/* Header */
.header {
  position: sticky;
  top: 0;
  z-index: 40;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  padding: calc(24rpx + var(--safe-top)) 32rpx 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #f1f5f9;
}

.header-content {
  flex: 1;
}

.header-title {
  font-size: 44rpx;
  font-weight: 900;
  color: #111;
  display: block;
}

.header-subtitle {
  font-size: 18rpx;
  font-weight: 700;
  color: #94a3b8;
  letter-spacing: 0.15em;
  display: block;
  margin-top: 4rpx;
}

.add-btn {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #2563eb 0%, #4f46e5 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.3);
  flex-shrink: 0;
}

.add-icon {
  font-size: 40rpx;
  color: #fff;
  font-weight: 300;
}

/* Cards Scroll - 使用 flex: 1 自适应 */
.cards-scroll {
  flex: 1;
  padding: 24rpx 32rpx;
  overflow-y: auto;
}

.cards-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.card-item {
  width: 100%;
}

/* ID Card - 全宽 */
.id-card {
  width: 100%;
  height: 380rpx;
  border-radius: 36rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.1);
  position: relative;
}

.card-bg {
  position: absolute;
  width: 100%;
  height: 100%;
  left: 0;
  top: 0;
}

.card-overlay {
  position: absolute;
  width: 100%;
  height: 100%;
  left: 0;
  top: 0;
  z-index: 10;
}

/* Color Classes */
.gradient-blue .card-overlay { background: linear-gradient(135deg, rgba(37, 99, 235, 0.88) 0%, rgba(79, 70, 229, 0.92) 100%); }
.gradient-slate .card-overlay { background: linear-gradient(135deg, rgba(30, 41, 59, 0.92) 0%, rgba(15, 23, 42, 0.96) 100%); }
.gradient-emerald .card-overlay { background: linear-gradient(135deg, rgba(16, 185, 129, 0.88) 0%, rgba(20, 184, 166, 0.92) 100%); }
.gradient-purple .card-overlay { background: linear-gradient(135deg, rgba(139, 92, 246, 0.88) 0%, rgba(168, 85, 247, 0.92) 100%); }
.gradient-orange .card-overlay { background: linear-gradient(135deg, rgba(249, 115, 22, 0.88) 0%, rgba(251, 146, 60, 0.92) 100%); }
.gradient-pink .card-overlay { background: linear-gradient(135deg, rgba(236, 72, 153, 0.88) 0%, rgba(244, 114, 182, 0.92) 100%); }

/* Card Content - 使用 flex 布局 */
.card-content {
  position: relative;
  z-index: 20;
  height: 100%;
  padding: 36rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  color: #fff;
  box-sizing: border-box;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.card-type {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.type-icon-box {
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10px);
  padding: 8rpx;
  border-radius: 12rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.type-icon {
  font-size: 24rpx;
}

.type-label {
  font-size: 18rpx;
  font-weight: 900;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  opacity: 0.85;
}

.default-badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 16rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10px);
  border-radius: 9999rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.default-text {
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

/* Card Footer - 使用 flex */
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.card-info {
  flex: 1;
  min-width: 0;
}

.card-name {
  font-size: 42rpx;
  font-weight: 900;
  display: block;
  margin-bottom: 4rpx;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-role {
  font-size: 26rpx;
  font-weight: 600;
  opacity: 0.85;
  display: block;
  margin-bottom: 8rpx;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-company {
  display: flex;
  align-items: center;
  gap: 6rpx;
  opacity: 0.6;
}

.company-text {
  font-size: 18rpx;
  font-weight: 700;
  text-transform: uppercase;
  max-width: 180rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-avatar-box {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.2);
  flex-shrink: 0;
}

.card-avatar {
  width: 100%;
  height: 100%;
}

/* Chip Decoration */
.chip-decoration {
  position: absolute;
  top: 40%;
  right: -18rpx;
  width: 56rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

/* Card Actions - 使用 flex */
.card-actions {
  margin-top: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.actions-left {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.action-icon {
  font-size: 22rpx;
  color: #94a3b8;
}

.action-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #94a3b8;
}

.action-btn.active .action-icon,
.action-btn.active .action-text {
  color: #2563eb;
}

.actions-right {
  display: flex;
  gap: 10rpx;
}

.icon-btn {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f8fafc;
  border-radius: 14rpx;
  font-size: 26rpx;
}

.icon-btn.delete {
  background: #fef2f2;
}

/* Add Card Placeholder - 全宽 */
.add-card-placeholder {
  width: 100%;
  height: 160rpx;
  border-radius: 36rpx;
  border: 3rpx dashed #cbd5e1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  background: #fafafa;
}

.placeholder-icon-box {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #f1f5f9;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 32rpx;
  color: #94a3b8;
  font-weight: 300;
}

.placeholder-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #94a3b8;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

/* Tips Box */
.tips-box {
  margin-top: 24rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 24rpx;
  border: 2rpx solid #f1f5f9;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.02);
}

.tips-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.tips-title {
  font-size: 22rpx;
  font-weight: 800;
  color: #111;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.tips-content {
  font-size: 20rpx;
  color: #64748b;
  line-height: 1.7;
  font-weight: 500;
}

/* Bottom Spacer */
.bottom-nav-spacer {
  height: 20rpx;
}

/* 响应式 */
@media (max-width: 320px) {
  .header {
    padding: 20rpx 20rpx 16rpx;
  }
  
  .header-title {
    font-size: 36rpx;
  }
  
  .cards-scroll {
    padding: 16rpx 20rpx;
  }
  
  .id-card {
    height: 340rpx;
  }
  
  .card-content {
    padding: 28rpx;
  }
  
  .card-name {
    font-size: 36rpx;
  }
  
  .card-avatar-box {
    width: 80rpx;
    height: 80rpx;
  }
}

@media (min-width: 400px) {
  .header {
    padding: 32rpx 40rpx 24rpx;
  }
  
  .header-title {
    font-size: 52rpx;
  }
  
  .cards-scroll {
    padding: 32rpx 40rpx;
  }
  
  .id-card {
    height: 420rpx;
  }
  
  .card-content {
    padding: 48rpx;
  }
  
  .card-name {
    font-size: 52rpx;
  }
  
  .card-avatar-box {
    width: 120rpx;
    height: 120rpx;
  }
}
