/**mycards.wxss - 响应式 **/

page {
  background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
}

.container {
  width: 100%;
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: 120rpx;
  overflow-x: hidden;
}

/* Header */
.header {
  position: sticky;
  top: 0;
  z-index: 40;
  width: 100%;
  background: rgba(255, 255, 255, 0.95);
  padding: 24rpx 32rpx 20rpx;
  box-sizing: border-box;
  border-bottom: 1rpx solid #f1f5f9;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-title {
  font-size: 44rpx;
  font-weight: 900;
  color: #111;
}

.header-subtitle {
  font-size: 18rpx;
  font-weight: 700;
  color: #94a3b8;
  letter-spacing: 0.15em;
}

.add-btn {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #2563eb 0%, #4f46e5 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 40rpx;
  color: #fff;
}

/* Cards List */
.cards-list {
  width: 100%;
  padding: 24rpx 32rpx;
  box-sizing: border-box;
}

.card-item {
  width: 100%;
}

/* ID Card */
.id-card {
  width: 100%;
  height: 380rpx;
  border-radius: 36rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.1);
}

/* Tips Box */
.tips-box {
  margin: 0 32rpx 24rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 24rpx;
  border: 2rpx solid #f1f5f9;
  box-sizing: border-box;
  width: calc(100% - 64rpx);
}

/* 响应式 */
@media (max-width: 375px) {
  .header, .cards-list {
    padding-left: 20rpx;
    padding-right: 20rpx;
  }
  
  .tips-box {
    margin-left: 20rpx;
    margin-right: 20rpx;
    width: calc(100% - 40rpx);
  }
  
  .id-card {
    height: 340rpx;
  }
}

@media (min-width: 400px) {
  .header, .cards-list {
    padding-left: 40rpx;
    padding-right: 40rpx;
  }
  
  .tips-box {
    margin-left: 40rpx;
    margin-right: 40rpx;
    width: calc(100% - 80rpx);
  }
}
