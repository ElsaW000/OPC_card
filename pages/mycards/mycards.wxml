<view class="container">
  <view class="header">
    <text class="header-title">{{labels.title}}</text>
    <text class="header-subtitle">{{labels.subtitle}}</text>
  </view>

  <view class="session-banner session-banner-{{sessionView.tone}}">
    <text class="session-banner-title">{{sessionView.title}}</text>
    <text class="session-banner-text">{{sessionView.text}}</text>
  </view>

  <view class="card-list">
    <block wx:for="{{cards}}" wx:key="id">
      <view class="card-item" bindtap="goToDetail" data-id="{{item.id}}">
        <view class="card-banner">
          <image class="banner-img" src="{{item.bannerUrl}}" mode="aspectFill" />
          <view class="banner-mask {{item.type}}"></view>
        </view>
        <view class="card-content">
          <view class="card-top">
            <view class="card-type">
              <text class="type-icon">{{item.typeIcon}}</text>
              <text class="type-name">{{item.title}}</text>
            </view>
            <view class="card-actions-right">
              <view class="icon-btn" catchtap="showQRCode" data-id="{{item.id}}" bindtap="stopPropagation">
                <image class="btn-icon" src="/images/icons/qr-white.png" mode="aspectFit" />
              </view>
              <view class="default-badge" wx:if="{{item.isDefault}}">
                <text class="badge-text">{{labels.defaultBadge}}</text>
              </view>
            </view>
          </view>
          <view class="card-body">
            <view class="card-info">
              <text class="card-name">{{item.name}}</text>
              <text class="card-role">{{item.role}}</text>
              <text class="card-company" wx:if="{{item.company}}">{{item.company}}</text>
            </view>
            <view class="card-avatar">
              <image src="{{item.avatarUrl}}" mode="aspectFill" />
            </view>
          </view>
        </view>
      </view>
      <view class="card-operations">
        <view class="op-btn {{item.isDefault ? 'active' : ''}}" bindtap="setDefault" data-id="{{item.id}}">
          <image class="op-icon" src="{{item.isDefault ? '/images/icons/default-selected.png' : '/images/icons/default-unselected.png'}}" mode="aspectFit" />
          <text class="op-text">{{item.isDefault ? labels.currentDefault : labels.setDefault}}</text>
        </view>
        <view class="op-btn" bindtap="editCard" data-id="{{item.id}}">
          <image class="op-icon" src="/images/icons/edit.png" mode="aspectFit" />
          <text class="op-text">{{labels.edit}}</text>
        </view>
        <view class="op-btn share-btn" bindtap="showQRCode" data-id="{{item.id}}">
          <image class="op-icon" src="/images/icons/qr.png" mode="aspectFit" />
          <text class="op-text">{{labels.share}}</text>
        </view>
      </view>
    </block>
  </view>

  <view class="add-card-btn" bindtap="addCard">
    <view class="add-icon-box">
      <text class="add-icon">+</text>
    </view>
    <text class="add-text">{{labels.addIdentity}}</text>
  </view>

  <view class="exchange-fab" bindtap="goToExchange">
    <text class="exchange-fab-text">{{labels.exchangeBtn}}</text>
  </view>
</view>
