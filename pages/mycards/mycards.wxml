<!--mycards.wxml - 名片夹管理 -->
<view class="container">
  <!-- 顶部标题 -->
  <view class="header">
    <view class="header-titles">
      <text class="header-title">我的名片</text>
      <text class="header-subtitle">MULTI-IDENTITY MANAGEMENT</text>
    </view>
  </view>

  <!-- 名片列表 -->
  <view class="cards-list">
    <block wx:for="{{cards}}" wx:key="id">
      <view class="card-item">
        <!-- ID Card -->
        <view class="id-card" bindtap="editCard" data-id="{{item.id}}">
          <!-- 右侧背景图 -->
          <view class="card-bg-area">
            <image class="card-bg-img" src="{{item.bannerUrl}}" mode="aspectFill"></image>
          </view>
          
          <!-- 左侧内容 -->
          <view class="card-left">
            <view class="card-type">
              <text class="type-icon">{{item.typeIcon}}</text>
              <text class="type-label">{{item.title}}</text>
            </view>
            <view class="default-badge" wx:if="{{item.isDefault}}">
              <text class="default-text">默认</text>
            </view>
            
            <view class="card-info">
              <text class="card-name">{{item.name}}</text>
              <text class="card-role">{{item.role}}</text>
              <text class="card-company" wx:if="{{item.company}}">{{item.company}}</text>
            </view>
          </view>
          
          <!-- 右侧头像 -->
          <view class="card-right">
            <image class="card-avatar" src="{{item.avatarUrl}}" mode="aspectFill"></image>
          </view>
        </view>

        <!-- 底部操作栏 -->
        <view class="card-actions">
          <view class="action-primary" catchtap="exchangeCard" data-id="{{item.id}}">
            <text class="action-primary-text">交换名片</text>
          </view>
          <view class="action-icons">
            <view class="icon-circle" catchtap="shareCard" data-id="{{item.id}}">
              <text>📤</text>
            </view>
            <view class="icon-circle" catchtap="editCard" data-id="{{item.id}}">
              <text>✎</text>
            </view>
          </view>
        </view>
      </view>
    </block>

    <!-- 添加新名片 -->
    <view class="add-card-placeholder" bindtap="addCard">
      <text class="placeholder-icon">+</text>
      <text class="placeholder-text">创建新身份</text>
    </view>
  </view>

  <!-- Tips -->
  <view class="tips-box">
    <text class="tips-title">💡 多重身份建议</text>
    <text class="tips-content">根据不同社交场景切换名片：技术名片、商务名片、社交名片。默认名片将作为二维码分享时的首选。</text>
  </view>
</view>
