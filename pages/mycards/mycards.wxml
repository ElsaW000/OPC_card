<!--mycards.wxml - 名片管理 -->
<view class="container">
  <!-- 顶部标题 -->
  <view class="header">
    <text class="header-title">我的名片</text>
    <text class="header-subtitle">MULTI-IDENTITY MANAGEMENT</text>
  </view>

  <!-- 名片切换指示器 -->
  <view class="card-tabs">
    <scroll-view scroll-x="true" class="tabs-scroll">
      <view class="tabs-list">
        <block wx:for="{{cards}}" wx:key="id">
          <view 
            class="tab-item {{currentIndex === index ? 'active' : ''}}" 
            bindtap="switchCard" 
            data-index="{{index}}"
          >
            <text class="tab-num">{{index + 1}}</text>
          </view>
        </block>
        <view class="tab-item add" bindtap="addCard">
          <text class="tab-num">+</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 当前名片预览 -->
  <view class="card-preview" wx:if="{{cards.length > 0}}">
    <view class="preview-card">
      <view class="preview-bg">
        <image src="{{cards[currentIndex].bannerUrl}}" mode="aspectFill"></image>
      </view>
      <view class="preview-content">
        <view class="preview-header">
          <view class="preview-type">
            <text>{{cards[currentIndex].typeIcon}}</text>
            <text class="type-name">{{cards[currentIndex].title}}</text>
          </view>
          <view class="preview-default" wx:if="{{cards[currentIndex].isDefault}}">
            <text>默认</text>
          </view>
        </view>
        <view class="preview-body">
          <view class="preview-info">
            <text class="preview-name">{{cards[currentIndex].name}}</text>
            <text class="preview-role">{{cards[currentIndex].role}}</text>
            <text class="preview-company" wx:if="{{cards[currentIndex].company}}">{{cards[currentIndex].company}}</text>
          </view>
          <view class="preview-avatar">
            <image src="{{cards[currentIndex].avatarUrl}}" mode="aspectFill"></image>
          </view>
        </view>
      </view>
    </view>

    <!-- 底部操作 -->
    <view class="preview-actions">
      <view class="action-primary" bindtap="editCard" data-id="{{cards[currentIndex].id}}">
        <text>编辑名片</text>
      </view>
      <view class="action-icon-btn" bindtap="shareCard" data-id="{{cards[currentIndex].id}}">
        <text>📤</text>
      </view>
      <view class="action-icon-btn" bindtap="setDefault" data-id="{{cards[currentIndex].id}}" wx:if="{{!cards[currentIndex].isDefault}}">
        <text>⭐</text>
      </view>
    </view>
  </view>

  <!-- 名片列表（可删除） -->
  <view class="card-list-section">
    <text class="section-title">所有名片</text>
    <view class="card-list">
      <block wx:for="{{cards}}" wx:key="id">
        <view class="list-item" bindtap="switchCard" data-index="{{index}}">
          <view class="list-info">
            <text class="list-name">{{item.name}}</text>
            <text class="list-role">{{item.role}}</text>
          </view>
          <view class="list-badge" wx:if="{{item.isDefault}}">默认</view>
          <view class="list-delete" catchtap="deleteCard" data-id="{{item.id}}" wx:if="{{cards.length > 1}}">🗑</view>
        </view>
      </block>
    </view>
  </view>

  <!-- 添加按钮 -->
  <view class="add-card-btn" bindtap="addCard">
    <text>+ 创建新身份</text>
  </view>
</view>
