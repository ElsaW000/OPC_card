<!--mycards.wxml - My Cards Page -->
<view class="container">
  <view class="header">
    <text class="header-title">My Cards</text>
    <text class="header-subtitle">MULTI-IDENTITY MANAGEMENT</text>
  </view>

  <view class="card-list">
    <block wx:for="{{cards}}" wx:key="id">
      <view class="card-item" bindtap="goToDetail" data-id="{{item.id}}">
        <view class="card-bg {{item.type}}"></view>
        <view class="card-content">
          <view class="card-header">
            <view class="card-type">
              <text class="type-icon">{{item.typeIcon}}</text>
              <text class="type-name">{{item.title}}</text>
            </view>
            <view class="card-default" wx:if="{{item.isDefault}}">Default</view>
          </view>
          <view class="card-body">
            <view class="card-info">
              <text class="card-name">{{item.name}}</text>
              <text class="card-role">{{item.role}}</text>
              <text class="card-company">{{item.company}}</text>
            </view>
            <view class="card-avatar">
              <image src="{{item.avatarUrl}}" mode="aspectFill"></image>
            </view>
          </view>
        </view>
        <view class="card-actions">
          <view class="action-btn" bindtap="setDefault" data-id="{{item.id}}" wx:if="{{!item.isDefault}}">
            <text class="action-text">Set Default</text>
          </view>
          <view class="action-btn active" wx:else>
            <text class="action-text">Current</text>
          </view>
          <view class="action-btn" bindtap="editCard" data-id="{{item.id}}">
            <text class="action-text">Edit</text>
          </view>
          <view class="action-btn" bindtap="shareCard" data-id="{{item.id}}">
            <text class="action-text">Share</text>
          </view>
        </view>
      </view>
    </block>
  </view>

  <view class="add-btn" bindtap="addCard">
    <text class="add-icon">+</text>
  </view>
</view>
