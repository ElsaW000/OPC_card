<!--contacts.wxml-->
<view class="container">
  <!-- Search -->
  <view class="search-bar">
    <text class="search-icon">&#x641C;</text>
    <input class="search-input" placeholder="&#x641C;&#x7D22;&#x8054;&#x7CFB;&#x4EBA;" />
  </view>

  <!-- Tags -->
  <view class="tags-row">
    <view class="tag-item active">&#x5168;&#x90E8;</view>
    <view class="tag-item">AI</view>
    <view class="tag-item">B&#x7AEF;&#x4EA7;&#x54C1;</view>
    <view class="tag-item">&#x51FA;&#x6D77;</view>
    <view class="tag-item">Flutter</view>
  </view>

  <!-- Recent Exchange -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">&#x6700;&#x8FD1;&#x4EA4;&#x6362;</text>
    </view>
    <view class="contact-list">
      <view class="contact-item">
        <image class="contact-avatar" src="https://images.unsplash.com/photo-1573164713791-0dfcd2a183a7?w=200" />
        <view class="contact-info">
          <view class="contact-top">
            <text class="contact-name">Sarah Zhang</text>
            <text class="contact-time">10&#x5206;&#x949F;&#x524D;</text>
          </view>
          <text class="contact-role">&#x4EA7;&#x54C1;&#x7BA1;&#x7406; @ ByteDance</text>
        </view>
      </view>
    </view>
  </view>

  <!-- All Contacts -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">&#x5168;&#x90E8;&#x8054;&#x7CFB;&#x4EBA;</text>
    </view>
    <view class="contact-list">
      <block wx:for="{{contacts}}" wx:key="id">
        <view class="contact-item">
          <image class="contact-avatar" src="{{item.avatar}}" />
          <view class="contact-info">
            <view class="contact-top">
              <text class="contact-name">{{item.name}}</text>
              <text class="contact-time">{{item.time}}</text>
            </view>
            <text class="contact-role">{{item.role}}</text>
            <view class="contact-tags">
              <text class="contact-tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
            </view>
          </view>
          <view class="contact-actions">
            <view class="action-chat">&#x804A;&#x5929;</view>
            <view class="action-call">&#x7535;&#x8BDD;</view>
          </view>
        </view>
      </block>
    </view>
  </view>
</view>
