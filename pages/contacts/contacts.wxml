<!--contacts.wxml-->
<view class="container">
  <view class="header">
    <text class="header-title">{{labels.title}}</text>
    <text class="header-subtitle">CONNECTIONS</text>
  </view>

  <view class="search-section">
    <view class="search-bar">
      <text class="search-icon">{{labels.searchIcon}}</text>
      <input class="search-input" placeholder="{{labels.searchPlaceholder}}" placeholder-class="search-placeholder" bindinput="onSearchInput" value="{{searchKeyword}}" />
    </view>
  </view>

  <view class="tags-section">
    <scroll-view scroll-x="true" class="tags-scroll">
      <view class="tags-list">
        <block wx:for="{{filterTags}}" wx:key="index">
          <view class="tag-item {{activeTag === item ? 'active' : ''}}" bindtap="selectTag" data-tag="{{item}}">{{item}}</view>
        </block>
      </view>
    </scroll-view>
  </view>

  <view class="pending-section" wx:if="{{pendingRequests.length}}">
    <view class="section-header">
      <text class="section-title">{{labels.pendingSection}}</text>
      <text class="section-count">{{pendingRequests.length}}</text>
    </view>
    <view class="contact-list">
      <block wx:for="{{pendingRequests}}" wx:key="id">
        <view class="contact-card pending-card">
          <view class="card-left">
            <image class="contact-avatar" src="{{item.avatar}}" />
            <view class="contact-info">
              <view class="contact-top">
                <text class="contact-name">{{item.name}}</text>
              </view>
              <text class="contact-role">{{item.role}}</text>
            </view>
          </view>
          <view class="card-right">
            <view class="action-buttons">
              <view class="action-btn approve-btn" bindtap="approveRequest" data-id="{{item.id}}">{{labels.approve}}</view>
              <view class="action-btn reject-btn" bindtap="rejectRequest" data-id="{{item.id}}">{{labels.reject}}</view>
            </view>
          </view>
        </view>
      </block>
    </view>
  </view>

  <view class="section" wx:if="{{recentContacts.length}}">
    <view class="section-header">
      <text class="section-title">{{labels.recentSection}}</text>
    </view>
    <view class="contact-list">
      <block wx:for="{{recentContacts}}" wx:key="id">
        <view class="contact-card">
          <view class="card-left" bindtap="openContactCard" data-id="{{item.id}}" data-card-id="{{item.cardId}}">
            <image class="contact-avatar" src="{{item.avatar}}" />
            <view class="contact-info">
              <view class="contact-top">
                <text class="contact-name">{{item.name}}</text>
              </view>
              <text class="contact-role">{{item.role}}</text>
            </view>
          </view>
          <view class="card-right">
            <text class="contact-time">{{item.time}}</text>
            <view class="action-buttons">
              <view class="action-btn" bindtap="toggleStar" data-id="{{item.id}}">{{item.actionText}}</view>
            </view>
          </view>
        </view>
      </block>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">{{labels.allSection}}</text>
      <text class="section-count">{{totalCount}}</text>
    </view>
    <view class="contact-list">
      <block wx:for="{{filteredContacts}}" wx:key="id">
        <view class="contact-card">
          <view class="card-left" bindtap="openContactCard" data-id="{{item.id}}" data-card-id="{{item.cardId}}">
            <image class="contact-avatar" src="{{item.avatar}}" />
            <view class="contact-info">
              <view class="contact-top">
                <text class="contact-name">{{item.name}}</text>
              </view>
              <text class="contact-role">{{item.role}}</text>
              <view class="contact-tags" wx:if="{{item.tags.length}}">
                <text class="tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:for-index="tagIndex" wx:key="tagIndex">{{tag}}</text>
              </view>
            </view>
          </view>
          <view class="card-right">
            <text class="contact-time">{{item.time}}</text>
            <view class="action-buttons">
              <view class="action-btn" bindtap="toggleStar" data-id="{{item.id}}">{{item.actionText}}</view>
            </view>
          </view>
        </view>
      </block>
    </view>
  </view>
</view>
