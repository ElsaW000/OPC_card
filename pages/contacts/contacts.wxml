<!--contacts.wxml-->
<view class="container">
  <!-- Search -->
  <view class="search-bar">
    <text class="search-icon">Search</text>
    <input class="search-input" placeholder="Search contacts" />
  </view>

  <!-- Tags -->
  <view class="tags-row">
    <view class="tag-item active">All</view>
    <view class="tag-item">AI</view>
    <view class="tag-item">B2B</view>
    <view class="tag-item">Oversea</view>
    <view class="tag-item">Flutter</view>
  </view>

  <!-- Recent Exchange -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">Recent Exchanges</text>
    </view>
    <view class="contact-list">
      <view class="contact-item">
        <image class="contact-avatar" src="https://images.unsplash.com/photo-1573164713791-0dfcd2a183a7?w=200" />
        <view class="contact-info">
          <view class="contact-top">
            <text class="contact-name">Sarah Zhang</text>
            <text class="contact-time">10m ago</text>
          </view>
          <text class="contact-role">PM @ ByteDance</text>
        </view>
      </view>
      <view class="contact-item">
        <image class="contact-avatar" src="https://images.unsplash.com/photo-1664101606938-e664f5852fac?w=200" />
        <view class="contact-info">
          <view class="contact-top">
            <text class="contact-name">David Li</text>
            <text class="contact-time">2h ago</text>
          </view>
          <text class="contact-role">Indie Developer</text>
        </view>
      </view>
    </view>
  </view>

  <!-- All Contacts -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">All Contacts</text>
    </view>
    <view class="contact-list">
      <block wx:for="{{contacts}}" wx:key="id">
        <view class="contact-item">
          <image class="contact-avatar" src="{{item.avatar}}" />
          <view class="contact-info">
            <view class="contact-top">
              <text class="contact-name">{{item.name}}</text>
              <text class="contact-time">{{item.time}}</text>
            </view>
            <text class="contact-role">{{item.role}}</text>
            <view class="contact-tags">
              <text class="contact-tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
            </view>
          </view>
          <view class="contact-actions">
            <view class="action-chat">Chat</view>
            <view class="action-call">Call</view>
          </view>
        </view>
      </block>
    </view>
  </view>
</view>
