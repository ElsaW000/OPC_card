/* contacts.wxss */

page { background-color: #f8f9fa; }
.container { min-height: 100vh; padding-bottom: 120rpx; }

/* Search */
.search-bar { display: flex; align-items: center; background: #fff; margin: 24rpx; padding: 20rpx 24rpx; border-radius: 24rpx; }
.search-icon { font-size: 28rpx; margin-right: 16rpx; }
.search-input { flex: 1; font-size: 28rpx; }

/* Tags */
.tags-row { display: flex; gap: 16rpx; padding: 0 24rpx 24rpx; overflow-x: auto; }
.tag-item { padding: 12rpx 24rpx; background: #fff; border-radius: 32rpx; font-size: 24rpx; color: #666; white-space: nowrap; }
.tag-item.active { background: #2563eb; color: #fff; }

/* Section */
.section { padding: 0 24rpx; margin-bottom: 32rpx; }
.section-header { margin-bottom: 16rpx; }
.section-title { font-size: 28rpx; font-weight: bold; color: #000; }

/* Contact List */
.contact-list { display: flex; flex-direction: column; gap: 16rpx; }
.contact-item { display: flex; align-items: center; background: #fff; padding: 24rpx; border-radius: 24rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06); }
.contact-avatar { width: 96rpx; height: 96rpx; border-radius: 16rpx; margin-right: 20rpx; flex-shrink: 0; }
.contact-info { flex: 1; min-width: 0; }
.contact-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 4rpx; }
.contact-name { font-size: 28rpx; font-weight: bold; color: #000; }
.contact-time { font-size: 22rpx; color: #999; }
.contact-role { font-size: 24rpx; color: #666; display: block; margin-bottom: 8rpx; }
.contact-tags { display: flex; gap: 8rpx; flex-wrap: wrap; }
.contact-tag { padding: 4rpx 12rpx; background: #f0f9ff; color: #2563eb; border-radius: 8rpx; font-size: 20rpx; }

/* Contact Actions */
.contact-actions { display: flex; gap: 16rpx; flex-shrink: 0; }
.action-chat { padding: 12rpx 32rpx; border: 2rpx solid #2563eb; border-radius: 16rpx; color: #2563eb; font-size: 24rpx; }
.action-call { padding: 12rpx; font-size: 32rpx; }
