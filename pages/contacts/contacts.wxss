/* contacts.wxss */

.container {
  min-height: 100vh;
  background-color: #f9fafb;
}

.search-bar {
  padding: 24rpx 32rpx;
  background-color: #fff;
}

.search-input {
  width: 100%;
  height: 72rpx;
  background-color: #f3f4f6;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.tags-scroll {
  background-color: #fff;
  padding-bottom: 16rpx;
  white-space: nowrap;
}

.tags-list {
  display: inline-flex;
  gap: 16rpx;
  padding: 0 32rpx;
}

.tag-item {
  display: inline-block;
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: #6b7280;
  background-color: #f3f4f6;
  border-radius: 9999rpx;
}

.tag-item.active {
  background-color: #111;
  color: #fff;
}

.contact-list {
  padding: 24rpx 32rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx;
  background-color: #fff;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.contact-avatar {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  flex-shrink: 0;
}

.contact-avatar image {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
}

.starred-icon {
  position: absolute;
  bottom: -8rpx;
  right: -8rpx;
  font-size: 24rpx;
}

.contact-info {
  flex: 1;
  min-width: 0;
}

.contact-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.contact-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #111;
}

.contact-location {
  font-size: 24rpx;
  color: #9ca3af;
}

.contact-role {
  display: block;
  font-size: 26rpx;
  color: #6b7280;
  margin-top: 4rpx;
}

.contact-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}

.contact-tags .tag {
  font-size: 20rpx;
  color: #6b7280;
  background-color: #f3f4f6;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.contact-active {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
  margin-top: 8rpx;
}

.contact-actions {
  display: flex;
  gap: 16rpx;
}

.action-icon {
  font-size: 36rpx;
  padding: 8rpx;
}

.empty-state {
  padding: 120rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
}
