/* contacts.wxss */

page {
  background-color: #f8fafc;
}

.container {
  width: 100%;
  min-height: 100vh;
  box-sizing: border-box;
  overflow-x: hidden;
}

.search-bar {
  width: 100%;
  padding: 20rpx 32rpx 20rpx;
  background-color: #fff;
  box-sizing: border-box;
}

.search-input {
  width: 100%;
  height: 80rpx;
  background-color: #f8fafc;
  border-radius: 20rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  border: 2rpx solid #f1f5f9;
  box-sizing: border-box;
}

.tags-scroll {
  width: 100%;
  background-color: #fff;
  padding-bottom: 16rpx;
  box-sizing: border-box;
}

.tags-list {
  display: flex;
  gap: 12rpx;
  padding: 0 32rpx;
  overflow-x: auto;
}

.tag-item {
  flex-shrink: 0;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: #64748b;
  background-color: #f1f5f9;
  border-radius: 9999rpx;
}

.tag-item.active {
  background: #111;
  color: #fff;
}

.contact-list {
  width: 100%;
  padding: 24rpx 32rpx 120rpx;
  box-sizing: border-box;
}

.contact-item {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background-color: #fff;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
  box-sizing: border-box;
}

.contact-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.contact-info {
  flex: 1;
  min-width: 0;
}

.contact-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #111;
}

.contact-role {
  font-size: 26rpx;
  color: #64748b;
  margin-top: 4rpx;
}

.contact-actions {
  display: flex;
  gap: 16rpx;
}

.action-icon {
  font-size: 36rpx;
}

@media (max-width: 375px) {
  .search-bar, .tags-list, .contact-list {
    padding-left: 20rpx;
    padding-right: 20rpx;
  }
}
