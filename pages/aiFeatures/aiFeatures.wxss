/* pages/aiFeatures/aiFeatures.wxss */

.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F8FAFC;
}

.chat-header {
  padding: 48rpx 40rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #F1F5F9;
}

.chat-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #0F172A;
  letter-spacing: -0.5rpx;
}

.chat-subtitle {
  display: block;
  font-size: 26rpx;
  color: #94A3B8;
  margin-top: 8rpx;
}

.provider-row {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.trace-panel {
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  background: #EFF6FF;
  border: 1rpx solid #BFDBFE;
}

.trace-title {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #1D4ED8;
  margin-bottom: 8rpx;
}

.trace-source {
  display: block;
  margin-bottom: 10rpx;
  font-size: 22rpx;
  color: #1E40AF;
}

.trace-line,
.trace-summary {
  display: block;
  font-size: 22rpx;
  line-height: 1.6;
  color: #334155;
}

.trace-summary {
  margin-top: 10rpx;
  color: #1E3A8A;
}

.provider-pill {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #EFF6FF;
  border: 1rpx solid #DBEAFE;
}

.provider-pill-active {
  background: #2563EB;
  border-color: #2563EB;
}

.provider-pill-text {
  font-size: 22rpx;
  color: #2563EB;
  font-weight: 600;
}

.provider-pill-text-active {
  color: #FFFFFF;
}

.chat-body {
  flex: 1;
  overflow: hidden;
}

.message-list {
  padding: 32rpx 24rpx 24rpx;
}

/* Quick prompts */
.quick-actions {
  margin-bottom: 40rpx;
}

.quick-hint {
  display: block;
  font-size: 26rpx;
  color: #94A3B8;
  margin-bottom: 20rpx;
}

.quick-btn {
  background: #fff;
  border: 1rpx solid #E2E8F0;
  border-radius: 20rpx;
  padding: 20rpx 28rpx;
  margin-bottom: 16rpx;
}

.quick-btn-text {
  font-size: 28rpx;
  color: #2563EB;
}

/* Message rows */
.msg-row {
  display: flex;
  align-items: flex-end;
  margin-bottom: 24rpx;
  gap: 16rpx;
}

.msg-left {
  flex-direction: row;
}

.msg-right {
  flex-direction: row-reverse;
}

.msg-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2563EB, #7C3AED);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.msg-avatar-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
}

.msg-bubble {
  max-width: 72%;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  position: relative;
}

.bubble-ai {
  background: #fff;
  border-bottom-left-radius: 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.bubble-user {
  background: #2563EB;
  border-bottom-right-radius: 8rpx;
}

.msg-text {
  display: block;
  font-size: 30rpx;
  line-height: 1.6;
  color: #0F172A;
}

.bubble-user .msg-text {
  color: #fff;
}

.msg-time {
  display: block;
  font-size: 22rpx;
  color: #94A3B8;
  margin-top: 8rpx;
}

.bubble-user .msg-time {
  color: rgba(255, 255, 255, 0.6);
  text-align: right;
}

/* Loading dots */
.bubble-loading {
  padding: 28rpx 32rpx;
}

.loading-dots {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #CBD5E1;
  animation: bounce 1.2s infinite ease-in-out;
}

.dot2 { animation-delay: 0.2s; }
.dot3 { animation-delay: 0.4s; }

.loading-status {
  display: block;
  margin-top: 14rpx;
  font-size: 26rpx;
  color: #334155;
}

.loading-hint {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #64748B;
}

@keyframes bounce {
  0%, 60%, 100% { transform: translateY(0); }
  30% { transform: translateY(-10rpx); }
}

/* Footer */
.chat-footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #F1F5F9;
  gap: 12rpx;
}

.footer-model-row {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.footer-model-label {
  font-size: 22rpx;
  color: #475569;
}

.footer-input-row {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.chat-input {
  flex: 1;
  background: #F8FAFC;
  border: 1rpx solid #E2E8F0;
  border-radius: 48rpx;
  padding: 20rpx 32rpx;
  font-size: 30rpx;
  color: #0F172A;
}

.send-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #E2E8F0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: background 0.2s;
}

.send-active {
  background: #2563EB;
}

.send-icon {
  font-size: 36rpx;
  color: #fff;
  font-weight: 700;
}
